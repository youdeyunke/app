.details-box{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 15rpx 30rpx 15rpx 30rpx;
  box-sizing: border-box !important;
  display: inline-block;
  border-bottom: 1rpx solid #DEDEDE;
  border-right: 3rpx solid #DEDEDE;
  margin-bottom: 18rpx;
}

.details-left{
  width:174rpx ;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size:26rpx ;
  color: #666666;
  display: flex;
  flex-direction: column;
  text-align: center;
  box-sizing: border-box;
}
.details-box view:nth-of-type(1){
  color: #1989FA;
  font-weight: bold;
}
.details-box view:nth-of-type(2){
  color: #666666;
}
.details-box view:nth-of-type(3){
  color: #00B2FF;
}
.details-box view:nth-of-type(4){
  color: #FF0000;
}
