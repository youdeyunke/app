<view class="image-box">
  <image class="image1" src="{{buildingdata.post.cover}}" mode="widthFix"></image>
  <view class="box">
    <view class="text1">{{buildingdata.post.title}}</view>
  </view>
</view>
<view class="building-box">
  <view class="building-message" bindtap="unfoldSearch">
    <view class="building-message-nav">
      <view class="nav-top">
        <text>单位价格</text>
        <image class="image2" src="../../images/4.png"></image>
      </view>
      <view class="nav-bottom">{{formdata.price}}</view>
    </view>
    <view class="building-message-nav">
      <view class="nav-top">
        <text>面积</text>
      <image class="image2" src="../../images/4.png"></image>
      </view>
      <view class="nav-bottom">{{formdata.areaprice}}</view>
    </view>
    <view class="building-message-nav">
      <view class="nav-top">
        <text>区间</text>
      <image class="image2" src="../../images/4.png"></image>
      </view>
      <view class="nav-bottom">{{formdata.area}}</view>
    </view>
  </view>
  <van-popup show="{{searchShow}}" position="top">
    <view class="search-box">
      <view class="search-price">
        <view class="search-top">
          <text>筛选</text>
          <text bindtap="resetHandle">重置</text>
        </view>
        <view class="search-price_between">
          <text>总价格区间</text>
          <text>(万元)</text>
        </view>
        <view class="price_between-class">
          <block wx:for="{{price_between}}" >
            <view class="{{item.select===true?'select':'notselect'}}" bindtap="priceHandle" data-index="{{index}}" data-key="price">{{item.value}}</view>
          </block>
        </view>
        <view class="search-price_between">
          <text>单位面积价格</text>
          <text>(元/平)</text>
        </view>
        <view class="price_between-class">
          <block wx:for="{{area_price}}">
            <view class="{{item.select===true?'select':'notselect'}}" data-key="areaprice" bindtap="areapriceHandle" data-index="{{index}}">{{item.value}}</view>
          </block>
        </view>
        <view class="search-price_between">
          <text>总面积</text>
          <text>(平)</text>
        </view>
        <view class="price_between-class">
          <block wx:for="{{area}}">
            <view class="{{item.select===true?'select':'notselect'}}" data-key="area" data-index="{{index}}" bindtap="areaHandle">{{item.value}}</view>
          </block>
        </view>
      </view>
      <view class="search-confirm"  bindtap="submitHanle">确定</view>
      <view class="search-cancel"  bindtap="closeSearch">取消</view>
    </view>
  </van-popup>
  <ud-tabs tabs="{{tabs}}" bind:change='tabChangeHandle' model:active-index='{{tabIndex}}' mytabs="newtabs" myborder="newborder"></ud-tabs>
  <view class="building">
    <building wx:if="{{buildingShow==true}}" bindchangestatus="mystatus" wx:for="{{floorRooms}}" value="{{item}}"
      num="{{building_num}}" average="{{average}}" formdata="{{formdata}}" result="{{resultShow}}" ></building>
  </view>
</view>