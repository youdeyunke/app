/* pkgYfyj/pages/yfyj/room-item.wxss */

.room-item {
    background: #57BE92;
    color: #fff;
    border: 1px solid #fff;
    width: 180rpx;
    height: 180rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-size:24rpx;
}

.name { 
    font-size:28rpx;
    margin-bottom:8rpx;
}
.room-item.selected{
    border-color:red;
}