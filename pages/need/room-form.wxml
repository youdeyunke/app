<form bindsubmit='submitHandle'  >
        <box padding="30" wx:if="{{!userInfo.mobile}}">
            <navigator url="/pages/myself/index" open-type='switchTab' hover-class='hover-class'>
                  为了便于联系，请先绑定手机号，点击此处， <text  class="bind">开始绑定</text>
            </navigator>
            
        </box>

        <card hat title="定制类型">
					<van-radio-group value="{{ cat }}" >
						<van-cell-group>
							<van-cell
						    wx:for="{{cats}}"
								title="{{item.label}}"
								clickable
								data-name="{{item.value}}"
								bind:click="catClick"
							>
              <van-radio name="{{item.value}}" />
							</van-cell>
						</van-cell-group>
				  </van-radio-group> 
					
        </card>
        <card hat title="预算范围">
            <van-field 
                        label="最低" 
                        required
                        bind:change="inputChange"
                        placeholder="单位：{{priceUnit}}"
                        data-name="budget_min" />

                <van-field 
                        label="最高" 
                        required
                        autosize
                        bind:change="inputChange"
                        placeholder="单位：{{priceUnit}}"
                        type="textarea"
                        data-name="budget_max" />

        </card>

        <card hat title="基础意向">
                <van-field 
                        label="区域" 
                        required
                        bind:change="inputChange"
                        value="{{position}}" 
                        data-name="position" />

                <van-field 
                        label="要求" 
                        autosize
                        bind:change="inputChange"
                        type="textarea"
                        value="{{content}}" 
                        data-name="content" />
        </card>

        <card hat title="选择符合您的3个标签">
           <view class="form-tags"> 
                <text  bindtap="purposeHandle" data-index="{{index}}" class="form-tag-item {{item.selected ? 'form-tag-item-active' : '' }}" wx:for="{{purposeList}}">{{item.name}}</text>
            </view>
        </card>


        <card hat title="联系方式">
          <van-cell-group>
                <van-field 
                        bindchange="inputChange" 
                        label="称呼" 
                        required
                        value="{{ contact_name }}" 
                        placeholder="怎么称呼您" 
                        data-name="contact_name"  />

                <van-field 
                        bindchange="inputChange" 
                        center
                        required
                        label="手机号" 
                        icon="question-o"
                        bind:click-icon="mobileIconClickHandle"
                        value="{{ contact_mobile }}" 
                        readonly="{{contact_mobile_lock}}"
                        disabled="{{contact_mobile_lock}}"
                        placeholder="用于经纪人联系您" 
                        data-name="contact_mobile">
                </van-field>

                <van-field 
                        bindchange="inputChange" 
                        label="微信" 
                        value="{{ contact_wechat }}" 
                        placeholder="可留空" 
                        data-name="contact_wechat"  />
          </van-cell-group> 
        </card>

  <view style="width:90%;margin:auto;">
    <button type="primary" form-type='submit'>填好了，提交</button>
  </view>

</form>
