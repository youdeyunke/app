<form bindsubmit='submitHandle' report-submit wx:if="{{!isDone}}">
    <view class="mycats" wx:if="{{cats.length >= 2}}">
        <van-tabs active="{{activeTabIndex}}" border="{{false}}" type="line" color="#1989fa" bind:change="catChange">
            <van-tab wx:for="{{cats}}" title="{{item.label}}"></van-tab>
        </van-tabs>
    </view>
    <card width="710" hat="{{false}}" title="{{ cat == 'buy' ? '买房' : '租房'}}预算" subtitle="请拖动滑块选择预算范围">
        <view class="range-value">
            <text class="number">{{ budget_min_value }}</text>
            <text class="unit">{{priceUnit}}</text>
            <text class="blank">～</text>
            <text class="number">{{ budget_max_value }}</text>
            <text class="unit">{{ priceUnit }}</text>
        </view>
        <range-slider width='670' height='80' block-size='50' min='{{budget_min}}' max='{{budget_max}}' values='{{[budget_min_value, budget_max_value]}}' bind:rangechange='budgetChange'>
            <view slot='minBlock' class='range-slider-block'></view>
            <view slot='maxBlock' class='range-slider-block'></view>
        </range-slider>
    </card>
    <card width="710" hat title="基础意向">
        <van-field label="区域" required bind:change="inputChange" value="{{position}}" data-name="position" />
        <van-field label="要求" autosize bind:change="inputChange" type="textarea" value="{{content}}" data-name="content" />
    </card>
    <card width="710" hat title="选择符合您的3个标签">
        <view class="tags-list">
            <view class="tag-item">
                <van-tag size="large" bindtap="purposeHandle" data-index="{{index}}" type="primary" plain="{{item.selected ? false : true}}" wx:for="{{purposeList}}">
                    {{item.name}}
                </van-tag>
            </view>
        </view>
    </card>
    <card width="710" hat title="联系方式">
        <van-cell-group>
            <van-field bindchange="inputChange" label="称呼" required value="{{ contact_name }}" placeholder="怎么称呼您" data-name="contact_name" />
            <van-field bindchange="inputChange" center required label="手机号" value="{{ contact_mobile }}" readonly="{{contact_mobile_lock}}" disabled="{{true}}" placeholder="用于经纪人联系您" data-name="contact_mobile">
                <mbutton wx:if="{{!contact_mobile}}" bind:change="mobileBind" slot="button" size="small" type="primary" />
            </van-field>
            <van-field bindchange="inputChange" label="微信" value="{{ contact_wechat }}" placeholder="可留空" data-name="contact_wechat" />
        </van-cell-group>
    </card>
    <view style="width:90%;margin:auto;">
        <button type="primary" form-type='submit'>填好了，提交</button>
    </view>
</form>
<form bindsubmit='formidHandle' report-submit wx:if="{{isDone}}">
    <view class="res">
        <icon type="success" size="100" />
        <view class="title">操作成功</view>
        <view class="desc">我们已经收到您的找房要求，系统正在为您匹配合适的经纪人，稍后会有专属经纪人与您电话联系，请注意接听</view>
        <view class="btns">
            <button type="default" form-type="submit" bindtap="gotoHome">返回首页</button>
        </view>
    </view>
</form>