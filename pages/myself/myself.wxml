<view class="container">
  <view class="userinfo">
    <button   wx:if="{{ !userInfo }}" bindtap="loginTapHandle"> 使用微信登录 </button>
    <block wx:else>
      <image bindtap="bindViewTap" class="userinfo-avatar" src="{{userInfo.avatar }}" background-size="cover"></image>
      <text class="userinfo-nickname">{{userInfo.nickname}}</text>


    </block>
  </view>

  <view class="useractions">
      <view class="item border" wx:if="{{userInfo}}">
        <text>手机号:</text>
        <button class="bind" open-type="getPhoneNumber"  wx:if="{{ !userInfo.mobile }}" bindgetphonenumber="bindMobileHandle"> 绑定手机号 </button>
        <block wx:else> <text wx:if="typeof userInfo.mobile">{{userInfo.mobile}}</text> </block>
    </view>

    <view bindtap="commingSoon"  class="item border" open-type='navigate' url="/pages/post/post">
      <text>我的关注</text>
      <text class="arrow">></text>
    </view>

    <view class="item border" open-type='navigate' url="/pages/post/post">
      <text bindtap="debugHandle">我的问答</text>
      <text class="arrow">></text>
    </view>    


  </view>
</view>
