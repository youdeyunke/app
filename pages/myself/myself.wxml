<import src="/tpls/posts/mini_listing.wxml"/>
<view class="container">
  <view class="userinfo">
        <button wx:if="{{ userInfo && !userInfo.mobile }}" class="bind" open-type="getPhoneNumber"  wx:if="{{ !userInfo.mobile }}" bindgetphonenumber="bindMobileHandle"> 注册/登录 </button>

    <block wx:else>
      <image bindtap="bindViewTap" class="userinfo-avatar" src="{{userInfo.custom_avatar.url || userInfo.avatar }}" background-size="cover"></image>
      <text class="userinfo-nickname">{{userInfo.nickname}}</text>

    </block>
  </view>

  <view class="useractions">
    <navigator class="item" wx:for="{{actions}}">
      <image class="icon"></image>
      <view>{{item.name}}</view>
    </navigator>
  </view>

  <view class="useractions useractions-b">
    <navigator class="item" wx:for="{{actionsB}}">
      <image class="icon"></image>
      <view>{{item.name}}</view>
    </navigator>
  </view>  

  <view class="last-view">
    <view>我的游览</view>
    <template is="miniposts"  data="{{ posts: [lastViewPost]  }}"></template>
  </view>
  
</view>
