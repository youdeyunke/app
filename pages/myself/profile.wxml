<form report-submit="{{true}}" bindsubmit="submitHandle">
<box padding="20" >

  <van-cell size="large" title="头像" bindtap="chooseImage">
    <image style="width:90rpx;height:90rpx;border-radius:90rpx;" slot="right-icon" src="{{userInfo.avatar}}" />
  </van-cell>

  <van-field
    size="large"
    label="昵称"
    value="{{ userInfo.nickname  }}"
    placeholder=""
    input-align="right"
    name="nickname"
  />

  <van-field
    size="large"
    label="姓名"
    value="{{ userInfo.name }}"
    placeholder=""
    input-align="right"
    name="name"
  />

  <van-field
    size="large"
    label="微信号码"
    value="{{ userInfo.wechat }}"
    placeholder=""
    input-align="right"
    name="wechat"
  />

  <van-cell size="large" title="手机号" value="{{ userInfo.mobile }}" border="{{false}}" />
</box>

  <button disabled="{{loading}}" style="width:710rpx;" type="primary" form-type="submit" >修改信息</button>
  <button bindtap="goBack" style="width:710rpx;margin-top:20rpx;" type="default"  >返回</button>

</form>
