page {
    background: url('http://qiniucdn.udeve.cn/04860.jpg') !important;
    background-size: 750rpx 466rpx !important;
    background-repeat: no-repeat !important;
    padding-top: 400rpx;
}

.header-block {
    position: absolute;
    top: 100rpx;
    left: 0rpx;
    right: 0rpx;

    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #fff;
    letter-spacing: 2.5rpx;
}

.header-block .title {
    font-size: 48rpx;
    margin-bottom: 20rpx;
}

.window {  
    margin-top:100rpx;
    padding: 20rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    box-sizing: border-box;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
}


.window .submit-btn {
    width: 100%;
}

.window .result{
    display: flex;
    flex-direction:column;
    justify-content: flex-start;
    align-items: center;
    box-sizing: border-box;
}

.window .result .icon{
  margin-top:30rpx;
  margin-bottom:30rpx;
}

.window .result .title {
  font-size:40rpx;
  color:#000;
  font-weight: bolder;
  margin-bottom:40rpx;
}

.window .result .text{
  color:#000;
  font-size:28rpx;
}

.plan {
    width: 100%;
    margin-top: 20rpx;
}

.steps {
    margin-top: 40rpx;
}
