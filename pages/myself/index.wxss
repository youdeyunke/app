
page{
  height:auto;
  min-height:100%;
  padding-top:0;
}

.user{
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 160rpx;
  width:100%;
}

.user .uinfo{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user .uinfo .avatar{
  margin-right:20rpx;
}

.user-login{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding:40rpx 0 50rpx 0;
  width:100%;
}

.user-login .avatar{
  margin-bottom:40rpx;
  margin-top:50rpx;
  border:2rpx solid #cecece;
}

.user-login .tip{
  font-size:24rpx;
  color:#999;
  height:80rpx;
  display:flex;
  justify-content:center;
  align-items:center;
}

.avatar, .avatar image{
  width: 120rpx;
  height: 120rpx;
  border-radius: 100%;
  overflow: hidden;
  margin-bottom:10rpx;
}



.van-cell image{
  width: 40rpx;
  height: 40rpx;
  margin-right:20rpx;
}