.outer{
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    background:#fff;
}

.header{
    background-size: 750rpx 410rpx;
    background-repeat: no-repeat;
    width: 750rpx; 
    height: 410rpx;

    box-sizing: border-box;
    padding: 120rpx 30rpx 0 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.header.default{
   
}

.header.broker{
    background-image: url('https://qiniucdn.udeve.net/fang/myself-2.png'); 
}

.header .avatar{
    width: 120rpx;
    height: 120rpx;
    border-radius: 60rpx;
    position: relative;


    margin-right:30rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}
.header .avatar .img{
    width: 120rpx; 
    height: 120rpx; 
    border-radius: 60rpx;
}

.header .avatar .border{
    border:4rpx solid #ffffff;
    box-sizing:border-box;
    width: 120rpx; 
    height: 120rpx;
    border-radius: 60rpx;
    position:absolute; 
    top:0; 
    left:0;
}

.header .login .img{
    width: 200rpx; 
    height: 80rpx;
}

.header .name-info{
    width: calc(690rpx - 120rpx - 30rpx - 150rpx);
    color:#fff;
    font-size:24rpx;
  
}

.header .name-info .name{
    font-size: 40rpx; 
    line-height: 40rpx;
    margin-bottom:10rpx;
}

.header .name-info .name .img{
    width: 110rpx; 
    height: 32rpx;
}

.header .edit{
    color:#fff;
    font-size: 24rpx;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.header .edit .img{
    width:25rpx; 
    height: 25rpx;
    margin-left:6rpx;
}

.body{
 

    box-sizing: border-box;
    padding:0;
    margin:-50rpx auto 0 auto;
    min-height: 400rpx;

    border-top-left-radius: 20rpx;
    border-top-right-radius: 20rpx;

}

.icons{
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    width: 710rpx;
}
.icons .icon-item{
    display: flex;
    flex-direction: column;
    align-items:center;
    justify-content: space-between;
    width: 100rpx;
    font-size: 24rpx; 
    color:#444;
    height: 90rpx;
    margin-bottom:40rpx;
    margin-right:42rpx;
}

.icons .icon-item:nth-child(5n){
  margin-right:0rpx;
}
.icons .icon-item:last-child{
  margin-right:0rpx;
}
.icons .icon-item:nth-last-child(-n+5) {
  /* 设置最后五个元素的特殊样式 */
  margin-bottom: 0;
  /* 添加其他特殊样式 */
}

.icons .icon-item .name{
  width: 100%; 
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.icons .icon-item .img{
    width: 50rpx; 
    height: 50rpx; 
    margin-bottom:8rpx;
}

.menu{
    width:710rpx; 
    margin:20rpx auto 0 auto;
}

.title{
    width: 750rpx; 
    box-sizing: border-box;
    padding-left:30rpx;
    color:#333; 
    font-size: 32rpx; 
    font-weight: 600;
    margin:10rpx 0 20rpx 0;
}

.blank{
    display: block;
    width: 100%; 
    height: 2rpx;
    margin: 30rpx 0;
}


.van-cell-title{
    display: flex;
    justify-content: flex-start;
    align-items: center;
    color:#333333;
    font-size: 28rpx;
}

.van-cell-icon{
    width: 40rpx;
    height:40rpx;
    margin-right:10rpx;
}

