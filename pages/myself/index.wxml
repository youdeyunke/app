

<view class="weui-panel  user-login" wx:if="{{!userInfo}}">
    <view class="avatar">
      <image src="/assets/images/default-avatar.png"></image>
    </view>  

    <text class="tip">登录账号，体验更多服务</text>
    <button type="primary" class="weui-btn "  open-type='getUserInfo' bindgetuserinfo='loginHandle'>使用微信登录</button>
</view>

<view class="weui-panel user" wx:if="{{userInfo}}">
  <view class="avatar">
    <image src="{{userInfo.avatar}}"></image>
  </view>
  <view class="nickname">{{userInfo.nickname}}</view>
</view>

<view class="weui-panel" wx:if="{{userInfo}}">
  <view class="actions">
      <view class="weui-cell weui-cell_access" wx:if="{{!userInfo.mobile}}">
          <view class="weui-cell__bd h1">绑定手机号</view>
          <view class="weui-cell__ft">
            <button class="weui-btn btn-mini" type="primary" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber" plain>马上绑定</button>
          </view>
      </view>
      
      <navigator url="/pages/myself/qa" hover-class="none" class="weui-cell weui-cell_access">
          <view class="weui-cell__hd">
            <image src="/assets/icons/m-qa.png"></image>
          </view>
          <view class="weui-cell__bd h1">我的咨询</view>
          <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </navigator>

      <navigator url="/pages/comments/index?myself=true&limit=10000" hover-class="none" class="weui-cell weui-cell_access">
          <view class="weui-cell__hd">
            <image src="/assets/icons/m-comment.png"></image>
          </view>      
          <view class="weui-cell__bd h1">我的评论</view>
          <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </navigator>

      <navigator url="/pages/myself/favposts" hover-class="none" class="weui-cell weui-cell_access">
          <view class="weui-cell__hd">
            <image src="/assets/icons/m-fav.png"></image>
          </view>          
          <view class="weui-cell__bd h1">我的关注</view>
          <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </navigator>

      <navigator hover-class="none"  class="weui-cell weui-cell_access">
          <view class="weui-cell__hd">
            <image src="/assets/icons/m-about.png"></image>
          </view>          
          <view class="weui-cell__bd h1">关于</view>
          <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </navigator>      

      <navigator hover-class="none"  class="weui-cell weui-cell_access">
                    <view class="weui-cell__hd">
            <image src="/assets/icons/m-call.png"></image>
          </view>    
          <view class="weui-cell__bd h1">联系客服</view>
          <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </navigator>     
    </view>
</view>
