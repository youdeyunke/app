<box padding="30" wx:if="{{!userInfo}}">
<view class="user-login" >
    <view class="avatar">
      <image src="/assets/images/default-avatar.png"></image>
    </view>  

    <text class="tip">登录账号，体验更多服务</text>
    <button type="primary" class="btn"  open-type='getUserInfo' bindgetuserinfo='loginHandle'>使用微信登录</button>
</view>
</box>

<box padding="30" wx:if="{{userInfo}}">
<view class="user">
  <view class="uinfo">
    <view class="avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="nickname">{{userInfo.nickname}}</view>
  </view>
  <avatar-sync />
</view>
</box>

<box    >
  <van-cell-group>
    <van-cell size="large" hover-class="none" title="绑定手机号"   center wx:if="{{userInfo && !userInfo.mobile}}">
         <button slot="right-icon" class="btn mini" type="primary" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber" plain>马上绑定</button>
    </van-cell>

    <van-cell size="large" wx:if="{{!item.loginRequired || ( item.loginRequired && userInfo)}}" hover-class="none" value="{{item.value || ''}}" wx:for="{{cells}}" title="{{item.name}}" bindtap="{{item.bindtap}}"  url="{{item.url}}"   is-link center>
      <view slot="icon" class="cell-icon-box">
        <image src="/assets/icons/myself/{{item.icon}}.png"></image>
      </view>
    </van-cell>

  </van-cell-group>

  <broker-join wx:if="{{!userInfo.is_broker}}" />
</box>
