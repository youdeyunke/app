
  <view class="user">
    <view class="uinfo">
      <view class="avatar">
        <open-data wx:if="{{userInfo.id}}" type="userAvatarUrl"></open-data>
        <image src="/assets/images/default-avatar.png"></image>
      </view>
      <view class="nickname">{{userInfo.nickname}}
      <navigator hover-class='none' class="mylink" url="/pages/auth/index" wx:if="{{!userInfo.id}}">请先登录  </navigator>      
      </view>
    </view>

    <view class="user-actions">
      <button class="mybutton"  wx:if="{{userInfo.id}}" hover-class="none"  open-type="getUserInfo" bindgetuserinfo="syncAvatar"> <van-icon name="exchange" /> </button>
    </view>
  </view>



<form report-submit bindsubmit="formidHandle"> 

  <view class="mybox" style="padding:0 20rpx;">
    <view class="menu"  >

      <button  bindtap="navigatetTo" data-url="/pages/need/room-form?cat=buy" form-type="submit" hover-class="none"  class="fake menu-item" >
        <van-icon color="#ff9501" size="58rpx" name="balance-list" />
        <view class="menu-item-name">我要买房 </view>
      </button>  


      <button  bindtap="navigatetTo" data-url="/pages/need/room-form?cat=rent" form-type="submit" hover-class="none"  class="fake menu-item" >
        <van-icon color="#5857CE" size="58rpx" name="balance-list" />
        <view class="menu-item-name">我要租房 </view>
      </button>    

      <button bindtap="navigatetTo" data-url="/pages/myself/favposts" form-type="submit" hover-class="none"   class="fake menu-item" >
        <van-icon color="#65CF9D" size="58rpx" name="star"  />
        <view class="menu-item-name">我的收藏 </view>
      </button>          

      <button  bindtap="navigatetTo" data-url="/pages/myself/broker" form-type="submit" hover-class="none"  class="fake menu-item" >
        <van-icon color="#E15C32" size="58rpx" name="add" />
        <view class="menu-item-name">经纪人入驻 </view>
      </button>  
                                          
    </view>
  </view>
</form>


<block>
  <box width="750" padding="20"  wx:if="{{userInfo.id && !userInfo.mobile}}">
      <van-cell border="{{false}}" size="large" hover-class="none" title="绑定手机号"   center>
            <van-button slot="right-icon" size="mini" plain type="primary" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">马上绑定</van-button>
        </van-cell>
  </box>

  <view class="mybox">  
    <van-cell icon="service-o" size="large" is-link  bindtap="callService"  hover-class="none" title="客服电话"  value="{{configs.service_mobile}}" />

    <van-cell icon="info-o" size="large" hover-class="none" title="当前版本" value="{{version}}"  > </van-cell>    

    <van-cell icon="brush-o"  bindtap="clearCache" size="large" hover-class="none" title="清除缓存" is-link value="{{cache.currentSize || 0}} Kb" > </van-cell>

    <van-cell icon="certificate" bindtap="openAuthSetting" size="large" hover-class="none" title="权限设置" is-link  > </van-cell>

    <van-cell  wx:if="{{userInfo.id}}" icon="close" border="{{false}}" size="large" is-link bindtap="logoutHandle" hover-class="none" title="退出登录" />                             
  </view>  


  <view class="mybox" style="padding:0rpx 20rpx;">
    <van-cell border="{{false}}" url="/pages/udeve/index" size="large" hover-class="none" title="做个一样的小程序"> 
	<van-icon size="30" name="http://qiniucdn.udeve.cn/xiaochengxu.png" slot="right-icon" />	
    </van-cell>
 </view>

</block>

