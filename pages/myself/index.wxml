<box padding="40" wx:if="{{userInfo}}">
<view class="user">
  <view class="uinfo">
    <view class="avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="nickname">{{userInfo.nickname}}</view>
  </view>

  <view class="user-actions">
    <button class="mybutton" hover-class="none"  open-type="getUserInfo" bindgetuserinfo="syncAvatar"> <van-icon name="exchange" /> </button>
  </view>
</view>
</box>


<block wx:if="{{userInfo}}">
  <box width="750" padding="20"  wx:if="{{userInfo && !userInfo.mobile}}">
      <van-cell border="{{false}}" size="large" hover-class="none" title="绑定手机号"   center>
            <van-button slot="right-icon" size="mini" plain type="primary" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">马上绑定</van-button>
        </van-cell>
  </box>

  <view class="cell-menu">
    <van-cell icon="like-o"  size="large" is-link url="/pages/myself/favposts"  hover-class="none" title="我的收藏" />   
    <van-cell icon="search" size="large" is-link url="/pages/need/room-form"  hover-class="none" title="帮我找房" />                            
  </view>

  <view class="cell-menu">  
    <van-cell icon="service-o" size="large" is-link  bindtap="callService"  hover-class="none" title="客服电话"  value="{{configs.service_mobile}}" />    
    <van-cell icon="setting-o"  size="large" is-link url="/pages/myself/setting"  hover-class="none" title="系统设置" /> 
    <van-cell icon="close" border="{{false}}" size="large" is-link bindtap="logoutHandle" hover-class="none" title="退出登录" />                             
  </view>  

</block>
