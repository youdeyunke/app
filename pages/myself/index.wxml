<view class="outer">
    <view
        style="background-image:url('{{ userInfo.is_broker === true ?  configs.ui.myself_broker_bg : configs.ui.myself_bg }}')"
        class="header {{ userInfo.is_broker == true ? 'broker' : 'default' }}">

        <block wx:if="{{userInfo.id}}">

            <view class="avatar">
                <view class="border"></view>
                <image class="img" src="{{userInfo.avatar}}"></image>
            </view>

            <view class="name-info">
                <view class="name">{{ userInfo.name }}
                    <image class="img" src="https://qiniucdn.udeve.net/fang/broker-level-{{ userInfo.level}}.png">
                    </image>
                </view>
                <view wx:if="{{userInfo.is_broker}}" class="desc">个性签名：{{ userInfo.desc || '未填写个人介绍' }}</view>
                <navigator url="/pkgMyself/pages/score/index" hover-class="none" class="score">我的积分：{{ userInfo.score }}
                </navigator>
            </view>
            <view class="qiandao-outer">
                <qiandao user="{{userInfo}}"></qiandao>
            </view>

        </block>
        <block wx:else>
            <view class="avatar">
                <view class="border"></view>
                <image class="img" src="https://qiniucdn.udeve.net/fang/myself-21.png"></image>
            </view>

            <view class="name-info">
                <view class="name">访客，您好

                </view>
                <view class="desc">登陆或注册账号，体验更多服务</view>
            </view>

            <view class="login" bindtap="gotoLoginPage">
                <image class="img" src="https://qiniucdn.udeve.net/fang/myself-20.png"></image>
            </view>

        </block>

    </view>


    <view class="body">

        <ud-card radius="20" width="730" title="工作台" wx:if="{{userInfo.is_broker}}">
            <view class="icons">
                <navigator bindtap="{{item.handle}}" hover-class="none" wx:for="{{brokerIcons}}"
                    url="{{item.url}}{{userInfo.broker_id}}" open-type="navigateTo" class="icon-item">
                    <image class="img" src="{{configs.ui[item.iconKey]}}"></image>
                    <view class="name">{{item.name}}</view>
                </navigator>
            </view>
        </ud-card>


        <ud-card radius="20" width="730"  title="我的服务">
            <view class="icons">
                <navigator wx:if="{{!userInfo.is_broker}}" hover-class="none" open-type="navigateTo"
                    url="/pkgBroker/pages/broker/join" class="icon-item">
                    <image class="img" src="{{configs.ui.myself_join}}"></image>
                    <view class="name">顾问入驻</view>
                </navigator>

                <navigator hover-class="none" wx:for="{{userIcons}}" url="{{item.url}}" open-type="navigateTo"
                    class="icon-item">
                    <image class="img" src="{{configs.ui[item.iconKey]}}"></image>
                    <view class="name">{{item.name}}</view>
                </navigator>
            </view>
        </ud-card>
        <ud-card radius="20" width="730"  title="">



            <van-cell-group inset>

                <van-cell center is-link url="/pkgMyself/pages/profile/index">
                    <view slot="title">
                        <view class="van-cell-title">
                            <image class="van-cell-icon" src="{{configs.ui.myself_edit}}"></image>
                            <view class="van-cell-text">修改资料</view>
                        </view>
                    </view>
                </van-cell>
                <van-cell is-link bindtap="clearCache" value="{{cache.currentSize}} kb">
                    <view slot="title">
                        <view class="van-cell-title">
                            <image class="van-cell-icon" src="{{configs.ui.myself_cache}}"></image>
                            <view class="van-cell-text">清理缓存</view>
                        </view>
                    </view>
                </van-cell>
                <van-cell is-link bindtap="openAuthSetting">
                    <view slot="title">
                        <view class="van-cell-title">
                            <image class="van-cell-icon" src="{{configs.ui.myself_quanxian}}"></image>
                            <view class="van-cell-text">微信权限</view>
                        </view>
                    </view>
                </van-cell>
                <van-cell is-link url="/pkgAbout/page/about/index" value="">
                    <view slot="title">
                        <view class="van-cell-title">
                            <image class="van-cell-icon" src="{{configs.ui.myself_about}}"></image>
                            <view class="van-cell-text">关于我们</view>
                        </view>
                    </view>
                </van-cell>
                <van-cell is-link bindtap="logoutHandle" border="{{false}}" value="">
                    <view slot="title">
                        <view class="van-cell-title">
                            <image class="van-cell-icon" src="{{configs.ui.myself_logout}}"></image>
                            <view class="van-cell-text">退出登陆</view>
                        </view>
                    </view>
                </van-cell>

            </van-cell-group>


        </ud-card>


    </view>


</view>