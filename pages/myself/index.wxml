<box>
<view class="user-login" wx:if="{{!userInfo}}">
    <view class="avatar">
      <image src="/assets/images/default-avatar.png"></image>
    </view>  

    <text class="tip">登录账号，体验更多服务</text>
    <button type="primary" class="btn"  open-type='getUserInfo' bindgetuserinfo='loginHandle'>使用微信登录</button>
</view>
</box>

<box  wx:if="{{userInfo}}">
<view class="user">
  <view class="avatar">
    <image src="{{userInfo.avatar}}"></image>
  </view>
  <view class="nickname">{{userInfo.nickname}}</view>
</view>
</box>

<box>
  <van-cell-group>
    <van-cell hover-class="none" title="绑定手机号"   center wx:if="{{userInfo && !userInfo.mobile}}">
         <button slot="right-icon" class="btn mini" type="primary" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber" plain>马上绑定</button>
    </van-cell>

    <van-cell hover-class="none" value="{{item.value || ''}}" wx:for="{{cells}}" title="{{item.name}}"  url="{{item.url}}"   is-link center>
        <image slot="icon" src="/assets/icons/{{item.icon}}"></image>
    </van-cell>

  </van-cell-group>
</box>
