<view class="outer">
    <view class="header {{ userInfo.is_broker == true ? 'broker' : 'default' }}">

        <block wx:if="{{userInfo.id}}">

            <view class="avatar">
            <view class="border"></view>
                <image class="img" src="{{userInfo.avatar}}"></image>
            </view>

            <view class="name-info">
                <view class="name">{{ userInfo.name }}
                    <image class="img" src="https://qiniucdn.udeve.net/fang/broker-level-{{ userInfo.level}}.png"></image>
                </view>
                <view wx:if="{{userInfo.is_broker}}" class="desc">个性签名：{{ userInfo.desc || '未填写个人介绍' }}</view>
                <navigator url="/pkgMyself/pages/score/index" hover-class="none" class="score">我的积分：{{ userInfo.score  }}</navigator>
            </view>
            <navigator url="/pkgMyself/pages/profile/index" class="edit">修改资料
                <image class="img" src="https://qiniucdn.udeve.net/fang/myself-edit.png"></image>
            </navigator>
        </block>
        <block wx:else>
            <view class="avatar">
                <view class="border"></view>
                <image class="img" src="https://qiniucdn.udeve.net/fang/myself-21.png"></image>
            </view>

            <view class="name-info">
                <view class="name">访客，您好
                  
                </view>
                <view class="desc">登陆或注册账号，体验更多服务</view>
            </view>

            <view class="login" bindtap="gotoLoginPage">
                <image class="img" src="https://qiniucdn.udeve.net/fang/myself-20.png"></image>
            </view>

        </block>

    </view>


    <view class="body">
  
        <block wx:if="{{userInfo.is_broker}}">
            <view class="title">工作台</view>
            <view class="icons">
                <navigator bindtap="{{item.handle}}" hover-class="none" wx:for="{{brokerIcons}}"
                    url="{{item.url}}{{userInfo.broker_id}}" open-type="navigateTo" class="icon-item">
                    <image class="img" src="https://qiniucdn.udeve.net/fang/{{item.icon}}"></image>
                    <view class="name">{{item.name}}</view>
                </navigator>
            </view>
            <view class="blank"></view>
        </block>

        <view class="title">我的服务</view>
        <view class="icons">
            <navigator wx:if="{{!userInfo.is_broker}}" hover-class="none"  open-type="navigateTo"url="/pkgBroker/pages/broker/join"    class="icon-item">
                    <image class="img" src="https://qiniucdn.udeve.net/fang/myself-10.png"></image>
                    <view class="name">顾问入驻</view>
                </navigator>

                <navigator hover-class="none" wx:for="{{userIcons}}" url="{{item.url}}" open-type="navigateTo"
                    class="icon-item">
                    <image class="img" src="https://qiniucdn.udeve.net/fang/{{item.icon}}"></image>
                    <view class="name">{{item.name}}</view>
                </navigator>
            </view>




        <view class="blank"></view>
        <view class="title">更多操作</view>
            <van-cell-group inset>
                <van-cell center  is-link url="/pkgMyself/pages/history/index" title="历史浏览"  />
                <van-cell is-link bindtap="clearCache" title="清理缓存" value="{{cache.currentSize}} kb" />
                <van-cell is-link bindtap="openAuthSetting" title="微信权限"  />
                <van-cell is-link url="/pkgAbout/page/about/index" title="关于我们" value="" />
                <van-cell is-link bindtap="logoutHandle" border="{{false}}" title="退出登陆" value="" />
            </van-cell-group>
      


    </view>


</view>