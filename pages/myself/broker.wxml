<view class="header-block">
    <view class="title">入驻平台，轻松招租</view>
    <view class="desc">轻松获得海量客源</view>
</view>
<view class="window" wx:if="{{ state=='new' || state == 'pending'}}">
    <view class="pending" wx:if="{{state == 'pending'}}">
        <text>你的入驻申请正在审核中，请耐心等待...</text>
        <image src="http://qiniucdn.udeve.cn/shenhezhong.png"></image>
    </view>
    <view wx:if="{{ state == 'pending' }}" class="back" bindtap="gotoEdit">返回修改资料</view>
    <form bindsubmit="submitHandle" wx:if="{{state == 'new'  }}">
        <van-field required label="姓名" value="{{broker.name}}" name="name" placeholder="你的真实姓名" />
        <van-field required label="电话" value="{{broker.mobile}}" name="mobile" placeholder="真实联系电话" />
        <van-field label="微信" value="{{broker.wechat}}" name="wechat" placeholder="微信账号" />
        <van-field label="公司" value="{{broker.company}}" name="company" placeholder="你所在的公司" />
        <van-field border="{{false}}" label="介绍" value="{{broker.desc}}" name="desc" placeholder="简短的个人介绍" />
        <button wx:if="{{state == 'new'}}" class="btn btn-primary submit-btn" type="primary" formType="submit"
            size="small">
            确认提交
        </button>
    </form>
</view>
<view class="steps" wx:if="{{state == 'new' || state == 'pending'}}">
    <flow-tips title="经纪人入驻流程" steps="{{steps}}" />
</view>
<view class="plan" wx:if="{{state == 'normal' || state == 'soon' }}">
    <van-cell icon="clock-o" title="经纪人权限" value="已开通" />
    <van-cell icon="clock-o" title="到期时间" value="剩余 {{broker.remain_days}}天" />
    <van-cell icon="bar-chart-o" title="每天可发布房源数" value="{{broker.per_day_limit}}套" />
    <van-cell icon="chart-trending-o" title="总共可发布房源数" value="{{broker.total_limit}}套" />
</view>
<view class="fixed-footer" wx:if="{{ state == 'soon' }}">
    <van-button bindtap="gotoBuy" size="large" disabled="{{state != 'soon'}}" type="primary">
        立即续费
    </van-button>
</view>