<view class="res">

<van-cell-group wx:for-index="cindex" wx:for-key="{{city.id}}" wx:for-items="{{cities}}" wx:for-item='city' wx:if="{{city.id && city.children.length}}">
  <view class="cname">{{city.text}}</view>
  <van-cell bindtap="districtClick" data-cindex="{{cindex}}" data-dindex="{{dindex}}" wx:for-index="dindex" wx:for-key="{{dis.id}}"  wx:if="{{dis.id}}" wx:for="{{city.children}}" wx:for-item="dis"  title="{{dis.text}}" is-link />
</van-cell-group>

</view>