<!-- pages/post/events-block.wxml -->
<mycard sub-title="{{value.more_title}}" url="{{value.more_url}}" hat="{{false}}" title-size="28" title="{{value.title || '楼盘动态'}}" sub-title="查看全部动态">
    <event wx:if="{{event && event.id}}" event="{{event}}"></event>
    <view class="empty"wx:else>没有动态</view>
    <navigator class="more-btn" hover-class="none" url="{{value.more_url}}">查看更多楼盘动态</navigator>
</mycard>