<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/mini_listing.wxml"/>

<view class="container ">
  <view class="myvideo">
      <video  controls poster="{{ post.cover.url}}" src="{{post.video}}" danmu-list="{{danmuList}}" enable-danmu danmu-btn controls></video>
   </view>

  <view class="box main">
    <view class="header">
      <view class="like item">
        <image src="/assets/icons/hart.png" ></image>
        <text>{{post.like_nums_base}}</text>
      </view>
      <text class="title">{{ post.title }}</text>
      <mytags items="{{ post.tags_list }}" ></mytags>

      <view wx-if="{{post.block_info && post.block_info.cate == 'block'}}">
              <view class="meta">
                <text class="label">板块均价</text>
                <text> {{post.block_info.block_average_price}}元/平米</text>
              </view>

              <view class="meta">
                <text class="label">板块供求</text>
                <text>{{ post.block_info.block_supply }}</text>
              </view>

              <view class="meta">
                <text class="label">板块亮点</text>
                <text> {{ post.block_info.block_features }}</text>
              </view>

      </view>

      <view wx-if="{{post.block_info && post.block_info.cate == 'item'}}">
          <view class="meta">
            <text class="label">开发商报价</text>
            <text>{{ post.block_info.item_price }} 元/㎡</text>
          </view>

          <view class="meta">
            <text class="label">参考总价</text>
            <text> {{ post.block_info.item_total_price_min }}万-{{ post.block_info.item_total_price_max }}万</text>
          </view>

          <view class="meta">
            <text class="label">主推户型</text>
            <text> {{ post.block_info.item_layout }}</text>
          </view>
        </view>

      <view class="meta">
        <text class="label">地址</text>
        <text> 松江-新桥-明兴路18弄</text>
      </view>      
    </view>
  </view>

  <audio poster="{{poster}}" name="{{name}}" author="{{author}}" src="{{src}}" id="audio" controls loop></audio>

  <navigator url='/pages/post/coupon' open-type='navigateTo' class="box coupon">
    <view class="icon">
      <image src="/assets/images/coupon.png"></image>
    </view>
    <view class="name">
      <text class="t">优惠券</text>
      <text class="d">{{post.coupon_desc || '专用优惠券' }}</text>
    </view>
    <view class="btn">优惠券</view>
  </navigator>  

  <text class="h1" >户型分析</text>
  <view class="box housetype" wx:if="{{post.housetype_name_a }}">
    <view class="poster">
      <image src="{{post.housetype_poster_a.url}}"></image>
    </view>
    <view class="meta">
      <view class="name">{{post.housetype_name_a}}</view>
      <view class="kv">朝向    {{post.housetype_position_a}}</view>
      <view class="kv">建面    {{post.housetype_area_a}}㎡</view>
      <view class="kvs">
        <view class="kv">单价    <text>{{post.housetype_price_a}}</text></view>
        <view class="kv">总价    <text>{{post.housetype_total_price_a}}</text></view>
      </view>
    </view>
  </view>

  <view class="box housetype" wx:if="{{post.housetype_name_b}}">
    <view class="poster">
      <image src="{{post.housetype_poster_b.url}}"></image>
    </view>
    <view class="meta">
      <view class="name">{{post.housetype_name_b}}</view>
      <view class="kv">朝向    {{post.housetype_position_b}}</view>
      <view class="kv">建面    {{post.housetype_area_b}}㎡</view>
      <view class="kvs">
        <view class="kv">单价    <text>{{post.housetype_price_b}}</text></view>
        <view class="kv">总价    <text>{{post.housetype_total_price_b}}</text></view>
      </view>
    </view>
  </view> 

  <view class="box html-content" hidden="{{readmore}}" wx:if="{{post.content_simple.length > 0}}">
    <view class="raw">
      <template is="wxParse" data="{{wxParseData:htmlContentSimple.nodes}}"/>
     <view class="readmore" bindtap='readMore'>展开全文</view>
    </view>
  </view>

  <view class="box html-content"  hidden="{{readmore == false && post.content_simple.length > 0}}">
    <view class="raw">
      <template is="wxParse" data="{{wxParseData:htmlContent.nodes}}"/>
    </view>
  </view>  

  <text class="h1" wx:if="{{posts.length > 0}}">好房推荐</text>
  <template is="miniposts"  data="{{ posts }}"></template>
</view>

<view class="footer-btns ">
   <button class="share" open-type="share">
    <image src="/assets/icons/share.png"></image>
    分享
   </button>
   <navigator open-type='navigateTo' class="qa" url="/pages/qa/new?postId={{post.id}}">
    我要提问<image src="/assets/icons/pen.png"></image>
   </navigator>
   <view class="call" bindtap="callMe">
    预约看房<image src="/assets/icons/call.png"></image>
   </view>
</view>