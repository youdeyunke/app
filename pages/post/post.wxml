<page-loading loading="{{loading}}" />
<van-transition duration="800" show="{{showViewCount}}" name="fade-left" custom-class="mypop">
    过去一周，有
    <text class="count">{{post.views_count}}人</text>
    查看了此房源
</van-transition>

<block wx:for="{{blocks}}" wx:for-item="block" wx:for-key="index">
    <images-block  wx:if="{{block.name == 'images' }}"  value="{{ block.value }}" />
    <meta-block  wx:if="{{block.name == 'meta' }}"  value="{{ block.value }}" />
    <van-notice-bar wx:if="{{ block.name == 'brokage' }}" left-icon="/assets/icons/yongjin.png" text="佣金：{{ value.brokage}} 详细规则：{{ value.brokage_desc || '无' }}" />
    <html-block wx:if="{{block.name == 'html'}}" block="{{block}}" />
    <desc-block wx:if="{{block.name == 'desc'}}" block="{{block}}" />
    <map-block wx:if="{{block.name == 'map'}}" block="{{block}}" />
    <brokers-block wx:if="{{block.name == 'brokers'}}" block="{{block}}" />
    <recoms-block wx:if="{{block.name == 'recoms'}}" block="{{block}}" />
    <btns-block wx:if="{{block.name == 'btns'}}" block="{{block}}" />
    <contact-block wx:if="{{block.name == 'contact'}}" block="{{block}}" />
    <safe-block wx:if="{{block.name == 'safe'}}" block="{{block}}" />
</block>


<view style="width:100%;" hidden="{{loading}}">

    <mycard width="750" title="配套设施" wx:if="{{post.group == 'rental' && post.facilities && post.facilities.length > 0 }}" hat="{{false}}">
        <view class="fac-items">
            <view class="fac-item" wx:for="{{post.facilities}}" wx:for-item="fac" wx:key="{{fac.id}}">
                <image class="fac-item-icon" src="{{fac.icon}}" mode="widthFix" />
                <view class="fac-item-name">{{ fac.name }}</view>
            </view>
        </view>
    </mycard>
    <mycard width="750" title="户型介绍" wx:if="{{post.group == 'new'}}" hat="{{false}}">
        <view class="housetype" wx:for="{{post.types}}" wx:key="{{item.id}}">
            <view class="poster">
                <image bindtap="viewTypeImage" data-index="{{index}}" src="{{item.image.url ? item.image.url + '?imageView2/2/w/300' : 'https://qiniucdn.udeve.cn/wefang-sass/type-image-none.jpg'  }}?imageView2/2/w/300"></image>
            </view>
            <view class="meta">
                <view class="name">{{item.name}}</view>
                <view class="kv">
                    <text decode="{{true}}">朝向&nbsp; &nbsp;&nbsp;{{item.position}}</text>
                </view>
                <view class="kv">
                    <text decode="{{true}}">建面&nbsp; &nbsp;&nbsp;{{item.area}} ㎡</text>
                </view>
                <view class="kv">
                    总价
                    <text decode="{{true}}" style="font-weight:bolder;color:#ff0000;">
                        &nbsp; &nbsp;&nbsp;{{item.total_price}} 万
                    </text>
                </view>
            </view>
        </view>
    </mycard>
    <block wx:if="{{mode == 1 && EXT.show_brokers_enable != false  }}">
    </block>
    <mycard title="推荐房源" padding="{{false}}" hat="{{false}}" wx:if="{{post.recoms.length >= 2}}">
        <view class="recoms">
            <scroll-view scroll-with-animation="{{true}}" scroll-x style="width:100%">
                <view class="items">
                    <item-block item="{{item}}" wx:key="{{item.id}}" wx:for="{{post.recoms}}" />
                </view>
            </scroll-view>
        </view>
    </mycard>
    <ad-link />
    <broker-btns wx:if="{{mode == 1}}" broker="{{post.broker_info}}" pid="{{post.id}}" post="{{post}}" bookingStatus="{{post.user_has_booking}}" />
    <contact wx:if="{{mode == 2}}" info="{{contactInfo}}" />
    <safe-tips cat="{{post.group}}" />
    <van-popup show="{{showShareBox }}" bind:close="closeShareBox" position="bottom">
        <view class="share-box">
            <view class="share-box-title">分享房源</view>
            <view class="share-box-items">
                <button plain bindtap="closeShareBox" open-type='share' class="share-box-item">
                    <image class="share-box-item-icon" src="/assets/icons/weixin.png"></image>
                    <view class="share-box-item-name">微信</view>
                </button>
                <view bindtap="onCreatePoster" class="share-box-item" wx:if="{{post.qr}}">
                    <image class="share-box-item-icon" src="/assets/icons/pengyouquan.png"></image>
                    <view class="share-box-item-name">海报</view>
                </view>
            </view>
        </view>
    </van-popup>
    <booking show="{{showBookingDialog}}" post-id="{{post.id}}" />
    <cr />
</view>
