<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/mini_listing.wxml"/>
<import src="/tpls/comment-item.wxml" />

<view class="container ">
  <view class="myvideo" >
      <image wx:if="{{true}}" class="poster" src="{{post.cover.url}}"></image>
      <video wx:if="{{false}}" controls poster="{{ post.cover.url}}" src="{{post.video}}" danmu-list="{{danmuList}}" enable-danmu danmu-btn controls></video>
   </view>

  <view class="box main">
    <view class="header">
      <myfav post="{{post}}"></myfav>
      <text class="title">{{ post.title }}</text>
      <mytags items="{{ post.tags_list }}" ></mytags>

      <view wx-if="{{post.block_info && post.block_info.cate == 'block'}}">
              <view class="meta">
                <text class="label">板块均价</text>
                <text> {{post.block_info.block_average_price}}元/平米</text>
              </view>

              <view class="meta">
                <text class="label">板块供求</text>
                <text>{{ post.block_info.block_supply }}</text>
              </view>

              <view class="meta">
                <text class="label">板块亮点</text>
                <text> {{ post.block_info.block_features }}</text>
              </view>

      </view>

      <view wx-if="{{post.block_info && post.block_info.cate == 'item'}}">
          <view class="meta">
            <text class="label">均价</text>
            <text>{{ post.block_info.item_price }} 元/㎡</text>
          </view>

          <view class="meta">
            <text class="label">总价</text>
            <text> {{ post.block_info.item_total_price_min }}万-{{ post.block_info.item_total_price_max }}万</text>
          </view>

        <view class="meta">
          <text class="label">地址</text>
          <text>{{ post.block_info.district.name }} {{post.block_info.street}}</text>
        </view> 
        
          <view class="meta">
            <text class="label">开盘</text>
            <text> {{ post.block_info.open_at }}</text>
          </view>
        </view>
    </view>
  </view>

  <myaudio wx:if="{{false}}"></myaudio>

  <navigator wx:if="{{post.coupon_desc}}" url="/pages/post/coupon?post_id={{post.id}}" open-type='navigateTo' class="box coupon">
    <view class="icon">
      <image src="/assets/images/coupon.png"></image>
    </view>
    <view class="name">
      <text class="t">优惠券</text>
      <text class="d">{{post.coupon_desc || '专用优惠券' }}</text>
    </view>
    <view class="btn">优惠券</view>
  </navigator>  

  <text class="h1" >户型分析</text>
  <view class="box housetype" wx:if="{{post.housetype_name_a }}">
    <view class="poster">
      <image bindtap="imageView" data-target="a" src="{{post.housetype_poster_a.url}}"></image>
    </view>
    <view class="meta">
      <view class="name">{{post.housetype_name_a}}</view>
      <view class="kv"><text decode="{{true}}">朝向&nbsp; &nbsp;&nbsp;{{post.housetype_position_a}}</text></view>
      <view class="kv"><text decode="{{true}}">建面&nbsp; &nbsp;&nbsp;{{post.housetype_area_a}}㎡</text></view>
      <view class="kvs">
        <view class="kv">单价<text decode="{{true}}">&nbsp; &nbsp;&nbsp;{{post.housetype_price_a}}</text></view>
        <view class="kv">总价    <text decode="{{true}}">&nbsp; &nbsp;&nbsp;{{post.housetype_total_price_a}}</text></view>
      </view>
    </view>
  </view>

  <view class="box housetype" wx:if="{{post.housetype_name_b }}">
    <view class="poster">
      <image bindtap="imageView" data-target="b" src="{{post.housetype_poster_b.url}}"></image>
    </view>
    <view class="meta">
      <view class="name">{{post.housetype_name_b }}</view>
      <view class="kv"><text decode="{{true}}">朝向&nbsp; &nbsp;&nbsp;{{post.housetype_position_b}}</text></view>
      <view class="kv"><text decode="{{true}}">建面&nbsp; &nbsp;&nbsp;{{post.housetype_area_b}}㎡</text></view>
      <view class="kvs">
        <view class="kv">单价<text decode="{{true}}">&nbsp; &nbsp;&nbsp;{{post.housetype_price_b}}</text></view>
        <view class="kv">总价    <text decode="{{true}}">&nbsp; &nbsp;&nbsp;{{post.housetype_total_price_b}}</text></view>
      </view>
    </view>
  </view>


  <view class="box html-content" hidden="{{readmore}}" wx:if="{{post.content_simple.length > 0}}">
    <view class="raw">
      <template is="wxParse" data="{{wxParseData:htmlContentSimple.nodes}}"/>
     <view class="readmore" bindtap='readMore'><text>展开全文</text></view>
    </view>
  </view>

  <view class="box html-content"  hidden="{{readmore == false && post.content_simple.length > 0}}">
    <view class="raw">
      <template is="wxParse" data="{{wxParseData:htmlContent.nodes}}"/>
      <view class="readmore" bindtap='readLess'><text>收起</text></view>
    </view>
  </view>  

  <text class="h1" wx:if="{{post.more_url}}" >买房必读</text>
  <view wx:if="{{post.more_url}}" bindtap='openWebview' class="box moreurl">
    <view class="poster">
      <image src="/assets/images/read-more.png"></image>
    </view>
    <view class="meta">
      <view class="t">{{post.more_title}}</view>
      <view class="d">{{post.more_desc}}</view>
    </view>

    <image src="/assets/images/post-list-footer.png" class="footer"></image>
  </view>

  <text class="h1" wx:if="{{posts.length > 0}}">好房推荐</text>
  <template is="miniposts"  data="{{ posts }}"></template>

  <view class="block-title">
    <text class="h1">用户点评</text>
    <navigator url="/pages/comments/index?target_id={{post.id}}&target_type=post&title=全部评价" class="desc" decode='{{true}}'><text wx:if="{{post.comments_count > 5}}" decode="{{true}}">查看全部{{post.comments_count}}条点评&gt;</text></navigator>
  </view>
  <view class="comments">
    <template wx:for-item="comment" wx:for="{{ comments }}" is="comment-item" data="{{ comment, index, showTarget:false }}"  ></template>
  </view>

  <navigator class="add-comment" url="/pages/comments/new?target_id={{post.id}}"><text decode="{{true}}">&gt;&gt;我要评论&lt;&lt;</text></navigator>
  <view style="height:90rpx;"></view>

</view>

<form report-submit bindsubmit='btnsHandle' class="footer-btns">
  <ul>
    <li>
    <button class="share" open-type="share">
      <image src="/assets/icons/share.png"></image>
      分享
    </button>                
    </li>
    <li>
<button form-type='submit' data-action="callme" class="qa" >
咨询提问<image src="/assets/icons/pen.png"></image>
</button>

    </li>
    <li>
<button form-type="submit" data-action="booking" class="call">
预约报名<image src="/assets/icons/call.png"></image>
</button>   
    
    </li>
  </ul>

</form>
