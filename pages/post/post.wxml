<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/detail-meta.wxml" />
<view class="post-cover">
        <view class="image-count">共{{post.full_images_list.length}} 张</view>
       <myfav wx:if="{{post.id}}" showstatus="{{false}}" showcount="{{false}}" pid="{{post.id}}"></myfav>
       <swiper class="swiper" indicator-dots="true" autoplay="{{post.images_list.length > 1}}" interval="5000"
        duration="500" circular="true" indicator-color="rgba(255,255,255,0.7)" autoplay indicator-active-color="#fff" >
         
            <swiper-item bindtap="viewImage">
                    <image src="{{post.cover}}?imageView2/2/w/750"></image>
            </swiper-item>   
            <swiper-item bindtap="viewImage" wx:for="{{post.full_images_list}}">
                    <image src="{{item}}?imageView2/2/w/750"></image>
            </swiper-item>   
            
        </swiper>
</view>

<view class="header-box">
  <view class="header">
          <view class=" post-title h1">{{ post.title_info.text }}</view>
     <mytags wx:if="{{post.tags_list}}" cat="{{post.cat.name}}" items="{{post.tags_list}}"></mytags>

     <view class="typeinfo" wx:if="{{post.group == 'old' }}">
             <view class="item border">
                     <view class="value">{{post.price_info.text}}</view>
                     <view class="key">总价</view>
             </view>
             <view class="item border">
                     <view class="value">{{post.type_info.text}}</view>
                     <view class="key">户型</view>
             </view>
             <view class="item">
                     <view class="value">{{post.area_info.text}}</view>
                     <view class="key">建面</view>
             </view>

     </view>

     <view class="typeinfo" wx:if="{{post.group == 'rental' }}">
             <view class="item border">
                     <view class="value">{{post.rent_price}}</view>
                     <view class="key">租金</view>
             </view>
             <view class="item border">
                     <view class="value">{{post.type_info.text}}</view>
                     <view class="key">户型</view>
             </view>
             <view class="item">
                     <view class="value">{{post.area_info.text}}</view>
                     <view class="key">{{post.area_info.label}}</view>
             </view>
     </view>

     <view bindtap='couponHandle' class="coupon" wx:if="{{ post && post.coupon_enable}}">
     <view class="name line-limit">{{post.coupon_desc}}</view>
     <view class="action">{{ post.user_has_coupon ? '已领券' : '领券' }}</view>
   </view>     
  </view>
</view>
<mycard title="基本信息" hat>
  <template is="detail-meta" data="{{post: post }}" /> 
</mycard>

<mycard title="房源介绍"> {{ post.desc }} </mycard>
<mycard title="核心卖点" hat></mycard>
<mycard title="业主心态" hat></mycard>
<mycard title="{{ post.group == 'new' ? '周边' : '小区' }}配套" hat></mycard>
<mycard title="服务介绍" hat></mycard>

<mycard title="好房评测" wx:if="{{post.group == 'new' }}">
   <view class="html-content {{ minicontent == true ? 'mini' : 'full' }}">
      <view class="raw">
        <template is="wxParse" data="{{wxParseData:htmlContent.nodes}}"/>
      </view>
      <view class="html-content-footer">
      </view>
  </view>  
  <view class="view-more-container">
  <button class="btn mini plain round view-more " bindtap="contentHandle" wx:if="{{minicontent}}">
    加载全文 <image class="{{ minicontent == true ? 'down' : 'up' }}" src="/assets/icons/down-arrow.png"></image>
  </button>
  </view>
</mycard>

<mycard title="户型信息" wx:if="{{post.group == 'new' }}">
    <view class="housetype" wx:for="{{post.types}}">
      <view class="poster">
          <image bindtap="imageView" data-target="a" src="{{item.image.url}}?imageView2/2/w/300"></image>
      </view>
      <view class="meta">
        <view class="name h1">{{item.name}}</view>
        <view class="kv"><text decode="{{true}}">朝向&nbsp; &nbsp;&nbsp;{{item.position}}</text></view>
        <view class="kvs">
           <view class="kv"><text decode="{{true}}">建面&nbsp; &nbsp;&nbsp;{{item.area}} ㎡</text></view>
          <view class="kv">总价<text decode="{{true}}" class="i">&nbsp; &nbsp;&nbsp;{{item.total_price}} 万</text></view>
        </view>
      </view>
    </view>
</mycard>

<mycard title="地理位置" hat>
  <mapimage url="{{post.map_image_url}}"></mapimage>
</mycard>

<mycard wx:if="{{post.group == 'new' && post.more_url}}" title="{{post.more_title}}" opentype="webview" url="{{post.more_url}}">
  <view>{{ post.more_desc }}</view>
</mycard>

<mycard wx:if="{{post.comment_enable}}" number="{{post.comments_count}}" title="用户评价" url="{{ post.comments_count > 1 ?  '/pages/comments/index?target_id=' +postId : null}}" >
  <comments mini="true" items="{{comments}}"></comments>

  <view class="comments-empty" wx:if="{{post.comments_count == 0}}">暂无评论</view>

  <view class="comments-add">
    <navigator hover-class='none' url="/pages/comments/new?target_id={{post.id}}">
      <button class="plain btn round mini">我要点评</button>
    </navigator> 
  </view>

</mycard>

<mycard wx:if="{{post.qa_enable}}" title="大家都在问" number="{{post.questions_count}}" url="{{ post.questions_count > 5 ? '/pages/qa/index?post_id='+postId : null }}">
  
  <view class="qa"  wx:for="{{qas}}">
      <qa answer="{{false}}" item="{{item}}" mini></qa>
  </view>

  <view class="comments-empty" wx:if="{{questions.length ==0}}">暂无提问</view>
    <view class="comments-add">
    
      <navigator hover-class='none' url="/pages/qa/new?post_id={{postId}}">
        <button class="btn plain round mini">我要提问</button>
        </navigator> 
  </view>
</mycard>


<recoms pid="{{postId}}" count="3"></recoms>


<form report-submit bindsubmit='btnsHandle' class="fixed-footer footer-btns">
  <ul>
    <li class="staff">
            <view class="staff-avatar"><image src="{{post.staff_user.avatar.url}}?imageView2/2/w/100"></image></view>
       <view class="staff-info">
               <view class="staff-name line-limit">{{post.staff_user.name}}</view>
               <view class="staff-desc line-limit">{{post.staff_user.desc}}</view>
       </view>
    </li>
    <li bindtap="bookingHandle" class="booking">
      <button class="btn info" >       
          <image src="/assets/icons/btn-booking.png"></image>
          {{ post.user_has_booking ? '已预约' : '预约看房'}}
      </button>
    </li>
    <li class="call" bindtap="callMe">
        <button class="btn primary">
            <image src="/assets/icons/btn-call.png"></image>电话
        </button>
    </li>

  </ul>
</form>
