<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/detail-meta.wxml" />
<import src="/tpls/posts/new-detail.wxml" />
<import src="/tpls/posts/old-detail.wxml" />
<import src="/tpls/posts/rental-detail.wxml" />

<block wx:if="{{post}}">
<view class="post-cover">
       <view wx:if="{{post && post.vr_url}}" open-type="navigateTo" bindtap='gotoVr' class="vr-btn">
        <image src="/assets/icons/qjkf.png"></image>
       </view>
       <myfav wx:if="{{post.id}}" showstatus="{{false}}" showcount="{{false}}" pid="{{post.id}}"></myfav>
       <swiper class="swiper" 
               indicator-dots="true" 
               autoplay="{{post.images_list.length > 1}}" 
               interval="5000"
               duration="500" 
               circular="true" 
               indicator-color="rgba(255,255,255,0.7)" 
               indicator-active-color="#fff" >
         
            <swiper-item bindtap="viewImage">
                    <image src="{{post.cover}}?imageView2/2/w/750"></image>
            </swiper-item>   
            <swiper-item bindtap="viewImage" wx:for="{{post.full_images_list}}">
                    <image src="{{item}}?imageView2/2/w/750"></image>
            </swiper-item>   
            
        </swiper>
</view>

<view class="header-box">
  <view class="header"> 
     <image bindtap="showShareBoxHandle" src="/assets/icons/share.png" class="share-btn"></image>
     <view class=" post-title h1 line-limit">{{ post.title_info.text }}</view>
     <mytags wx:if="{{post.tags_list}}" items="{{post.tags_list}}"></mytags>
     <view class="typeinfo">
         <view class="item border">
                 <view class="value">{{post.price_info.text}}</view>
                 <view class="key">{{post.price_info.label}}</view>
         </view>
         <view class="item border">
                 <view class="value">{{post.type_info.text}}</view>
                 <view class="key">户型</view>
         </view>
         <view class="item">
                 <view class="value">{{post.area_info.text}}</view>
                 <view class="key">{{post.area_info.label}}</view>
         </view>
     </view>
     <view bindtap='couponHandle' class="coupon" wx:if="{{ post.coupon_desc && post.coupon_enable}}">
       <view class="name line-limit">{{post.coupon_desc}}</view>
     <view class="action">{{ post.user_has_coupon ? '已领券' : '领券' }}</view>
   </view>     
  </view>
</view>



<template wx:if="{{post}}" is="{{post.group}}-detail" data="{{post: post, htmlContent: htmlContent, minicontent:minicontent}}"/>
<mycard 
        wx:if="{{post.comment_enable}}" 
        number="{{post.comments_count}}" 
        title="用户评价" 
        url="{{ post.comments_count > 1 ?  '/pages/comments/index?target_id=' +postId : null}}" >
  <comments mini="true" items="{{comments}}"></comments>

  <view class="comments-empty" wx:if="{{post.comments_count == 0}}">暂无评论</view>
  <view class="comments-add">
    <navigator hover-class='none' url="/pages/comments/new?target_id={{post.id}}">
      <button class="plain btn round mini">我要点评</button>
    </navigator> 
  </view>

</mycard>

<mycard wx:if="{{post.qa_enable}}" title="大家都在问" number="{{post.questions_count}}" url="{{ post.questions_count > 5 ? '/pages/qa/index?post_id='+postId : null }}">
  
  <view class="qa"  wx:for="{{qas}}">
      <qa answer="{{false}}" item="{{item}}" mini></qa>
  </view>

  <view class="comments-empty" wx:if="{{questions.length ==0}}">暂无提问</view>
    <view class="comments-add">
      <navigator hover-class='none' url="/pages/qa/new?post_id={{postId}}">
        <button class="btn plain round mini">我要提问</button>
        </navigator> 
  </view>
</mycard>

<safe-tips/>

<recoms wx:if="{{post.group}}" group="{{post.group}}" count="10"></recoms>
<broker wx:if="{{post.broker_info}}" broker="{{post.broker_info}}" pid="{{post.id}}" booking="{{post.user_has_booking}}"></broker>


<van-popup show="{{showPoster}}" bind:close="closePoster" > 
  <view class="poster-preview">
    <image src="{{posterUrl}}"></image>
    <view class="poster-actions">
      <view class="poster-actions-btn poster-cancle-btn" bind:tap="closePoster" >取消</view>
      <view class="poster-actions-btn poster-save-btn"  bindtap="onSavePoster">保存到相册</view>
    </view>

  </view>
</van-popup>

<van-popup show="{{showShareBox }}" bind:close="closeShareBox" position="bottom">
  <view class="share-box">
    <view class="share-box-title">分享房源</view>
    <view class="share-box-items">
      <button plain bindtap="closeShareBox"  open-type='share' class="share-box-item">
        <image class="share-box-item-icon" src="/assets/icons/weixin.png"></image>
        <view class="share-box-item-name">微信</view>
      </button>

      <view bindtap="onCreatePoster" class="share-box-item" wx:if="{{post.qr}}">
        <image class="share-box-item-icon" src="/assets/icons/pengyouquan.png"></image>
        <view class="share-box-item-name">朋友圈</view>
      </view>      
    </view>
  </view>
</van-popup>

        
<poster wx:if="{{posterConfig}}" id="poster" config="{{posterConfig}}" bind:success="onPosterSuccess" bind:fail="onPosterFail"></poster> 

<view class="float-btn gen-poster" bindtap="onCreatePoster">
  <image src="/assets/icons/gen-poster-icon.png"></image>
  <text>海报</text>
</view>

</block>
