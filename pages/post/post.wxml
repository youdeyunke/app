<import src="/utils/wxParse/wxParse.wxml"/>

<view bindtap="maskClickHandle" class="mask {{showMask ? '' : 'hide'}}">
showMask: {{ showMask }}
  <image src="/assets/images/share_tip.png"></image>

</view>

<view class="container {{showMask ? 'overflow-hidden' : ''}}">
  <view class="myvideo">
          <video  autoplay controls poster="{{ post.cover}}" src="{{post.video}}" danmu-list="{{danmuList}}" enable-danmu danmu-btn controls></video>
   </view>

  <view class="box main">
    <view class="header">
      <view class="like item">
        <image src="/assets/icons/hart.png" ></image>
        <text>1999</text>
      </view>

      <text class="title">{{ post.title }}{{ post.tags }}</text>
      <mytags items="['地铁','学区房', '地体', '学区房']" ></mytags>
      <view class="meta">
        <text class="label">开发商报价</text>
        <text> 45000元/平米</text>
      </view>
      <view class="meta">
        <text class="label">参考总价</text>
        <text> 360万 - 470万</text>
      </view>
      <view class="meta">
        <text class="label">主推户型</text>
        <text> 3室2厅2卫 100平</text>
      </view>
      <view class="meta">
        <text class="label">地址</text>
        <text> 松江-新桥-明兴路18弄</text>
      </view>      


      <view class="line"></view>
    </view>

    <view class="raw">
        <template is="wxParse" data="{{wxParseData:htmlContent.nodes}}"/>
    </view>
  </view>

  <navigator bindtap="callMe" class="box coupon">
    <view class="icon">
      <image src="/assets/images/coupon.png"></image>
    </view>
    <view class="name">
      <text class="t">优惠券的名称</text>
      <text class="d">优惠券的描述</text>
    </view>
    <view class="btn">优惠券</view>
  </navigator>
  
  <text class="h1">好房推荐</text>
  <mypostlist></mypostlist>
</view>

<view class="footer-btns  {{ showMask == true ? 'hide' : ''}}">
   <view class="share" bindtap='shareClickHandle'>
    <image src="/assets/icons/share.png"></image>
    分享
   </view>
   <navigator class="qa" url="/pages/qa/qa?postId={{post.id}}">
    我要提问<image src="/assets/icons/pen.png"></image>
   </navigator>
   <view class="call" bindtap="callMe">
    预约看房<image src="/assets/icons/call.png"></image>
   </view>
</view>

