<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/mini_listing.wxml"/>
<import src="/tpls/comment-item.wxml" />
<import src="/tpls/posts/detail-housetype.wxml" />
<import src="/tpls/posts/detail-meta.wxml" />
<import src="/tpls/posts/more-url" />
<view class="post-cover">
        <view class="image-count">{{post.full_images_list.length}} 图</view>
       <myfav wx:if="{{post.id}}" showstatus="{{false}}" showcount="{{false}}" pid="{{post.id}}"></myfav>
       <swiper class="swiper" indicator-dots="true" autoplay="true" interval="5000"
        duration="500" circular="true" indicator-color="rgba(255,255,255,0.7)" autoplay indicator-active-color="#fff" >
         
            <swiper-item bindtap="viewImage">
                <image src="{{post.cover}}"></image>
            </swiper-item>   
            <swiper-item bindtap="viewImage" wx:for="{{post.full_images_list}}">
                <image src="{{item}}"></image>
            </swiper-item>   
            
        </swiper>
</view>


<view class="header">
  <view class="container">
     <view class=" post-title h1">{{ post.group == 'new' ? post.block_name + ' ' + post.desc : post.title }}</view>
     <mytags wx:if="{{post.tags_list}}" cat="{{post.cat.name}}" items="{{post.tags_list}}"></mytags>

     <template is="detail-meta" data="{{post: post }}" /> 

   <view bindtap='couponHandle' class="coupon" wx:if="{{post.group == 'new' && post && post.coupon_enable}}">
    <view class="name line-limit">{{post.coupon_desc}}</view>
    <view class="action">{{ post.user_has_coupon ? '已领券' : '领取优惠券' }}</view>
   </view>     

  </view>
</view>

<view class="container" style="padding-top:0;">
   <view class="box html-content {{ minicontent == true ? 'mini' : 'full' }}">
      <view class="raw">
        <template is="wxParse" data="{{wxParseData:htmlContent.nodes}}"/>
    </view>
  </view>  

  <view class="content-switch" bindtap="contentHandle" wx:if="{{minicontent}}">
    加载全文 <image class="{{ minicontent == true ? 'down' : 'up' }}" src="/assets/icons/right-arrow.png"></image>
  </view>

</view>

<template is="housetype" data="{{post: post}}" />

<mycard wx:if="{{post.group == 'new' && post.more_url}}" title="{{post.more_title}}" opentype="webview" url="{{post.more_url}}">
  <view>{{ post.more_desc }}</view>
</mycard>

<mycard wx:if="{{post.comment_enable}}" number="{{post.comments_count}}" title="用户评价" url="{{ post.comments_count > 5 ?  '/pages/comments/index?target_id=' +postId : null}}" >
  <comments mini="true" items="{{comments}}"></comments>

  <view class="comments-empty" wx:if="{{post.comments_count == 0}}">暂无评论</view>

  <view class="comments-add">
    <image src='/assets/icons/pen.png'></image>
    <navigator url="/pages/comments/new?target_id={{post.id}}">我要点评</navigator>      
  </view>
</mycard>

<mycard wx:if="{{post.qa_enable}}" title="大家都在问" number="{{post.questions_count}}" url="{{ post.questions_count > 5 ? '/pages/qa/index?post_id='+postId : null }}">
  
  <view class="qa"  wx:for="{{qas}}">
  <qa answer="{{false}}" item="{{item}}" mini></qa>
  </view>

  <view class="comments-empty" wx:if="{{questions.length ==0}}">暂无提问</view>
    <view class="comments-add">
    <image src='/assets/icons/m-qa.png'></image>
    <navigator url="/pages/qa/new?post_id={{postId}}">我要提问</navigator>      
  </view>
</mycard>


<form report-submit bindsubmit='btnsHandle' class="footer-btns">
  <ul>
    <li class="staff">
       <view class="staff-avatar"><image src="{{post.staff_user.avatar.url}}?"></image></view>
       <view class="staff-info">
               <view class="staff-name line-limit">{{post.staff_user.name}}</view>
               <view class="staff-desc line-limit">{{post.staff_user.desc}}</view>
       </view>
    </li>
    <li bindtap="bookingHandle" class="booking"><image src="/assets/icons/btn-booking.png"></image>
      {{ post.user_has_booking ? '已预约' : '预约看房'}}
    </li>
    <li class="call" bindtap="callMe">
      <image src="/assets/icons/btn-call.png"></image>电话
    </li>

  </ul>
</form>
