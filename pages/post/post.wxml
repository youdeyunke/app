<import src="/utils/wxParse/wxParse.wxml"/>
<import src="/tpls/posts/new-detail.wxml" />
<import src="/tpls/posts/old-detail.wxml" />
<import src="/tpls/posts/rental-detail.wxml" />

<template name="meta-tab">
  <block>
    <mapimage image="{{post.map_image_url}}" latitude="{{post.latitude}}"  longitude="{{post.longitude}}" name="{{post.area_name}}" ></mapimage>
  </block>
</template>

<template name="comments-tab">
  <block>
    <comments style="width:100%;" targetId="{{post.id}}" targetType="post" ></comments>
    <view class="comments-empty" wx:if="{{post.comments_count == 0}}">暂无评论</view>
    <view class="comments-add">
      <navigator hover-class='none' url="/pages/comments/new?target_id={{post.id}}">
        <button class="plain btn mini">我要点评</button>
      </navigator> 
    </view>
  </block>
</template>

<template name="qas-tab">
  <view class="qa"  wx:for="{{qas}}">
      <qa answer="{{false}}" item="{{item}}" mini></qa>
  </view>
  <view class="comments-empty" wx:if="{{qas.length ==0}}">暂无提问</view>
    <view class="comments-add">
      <navigator hover-class='none' url="/pages/qa/new?post_id={{post.id}}">
        <button class="btn plain round mini">我要提问</button>
        </navigator> 
  </view>
</template>

<template name="more-tab">
  <block>
    <van-cell bindtap="{{pm.bindtap}}" data-value="{{pm.value}}" wx:for="{{post.protected_meta_list}}" wx:for-item="pm" title="{{pm.label}}" value="{{pm.value}}" />
    <van-cell title="俯瞰图" value="{{ post.overlook_image ? '点击查看' : '无' }}" bindtap="viewOverlook"/>
  </block>
</template>

<template name="flows-tab">
  <view bind:longpress="flowEdit" data-index="{{index}}" class="flow-item" wx:for="{{flows}}" wx:for-item="flow">
    <image src="{{flow.user_info.avatar}}"></image>
    <view class="flow-content">
      <view class="user-name">{{flow.user_info.name}}</view>
      <view class="arrow"></view>
      <view class="text">{{flow.content}}</view>
      <view class="time">{{flow.updated_at_pretty }}</view>
    </view>
  </view>
  <view class="new-flow-action">
    <view class="desc">
      <view wx:if="{{flows.length == 0}}">暂无跟进信息</view>
      <view>写入的跟进记录只对平台入驻的经纪人可见</view>
    </view>
    <van-button disabled='{{showFlowForm}}' size="small" type="primary"  plain bindclick="openFlowForm">写跟进</van-button>
  </view>
</template>

<block wx:if="{{post}}">
<navigator wx:if="{{from_share}}" class="home-btn" open-type="switchTab" url="/pages/home/home">
  <image src="/assets/icons/home.1.png"></image>
  <text>首页</text>
</navigator>

<view class="post-cover">
       <swiper class="swiper" 
               indicator-dots="true" 
               autoplay="{{post.images_list.length > 1}}" 
               interval="5000"
               duration="500" 
               bindchange="swiperChange"
               circular="true" 
               indicator-color="rgba(255,255,255,0.7)" 
               indicator-active-color="#fff" >
                    
            <swiper-item bindtap="viewImage" data-index="{{index}}" wx:for="{{post.full_images_list}}">
              <view class="first">
                <image wx:if="{{ index ==0 && post.vr_url}}" catchtap='gotoVr' class="play vr" src="/assets/icons/vr.png"></image>              
                <image wx:if="{{ index == 1 && post.video}}" catchtap='gotoVideo' class="play video" src="/assets/icons/bofang.png"></image>
                <gimage width="750" height="480" wx:if="{{index == 0 && post.vr_url }}" class="item" src="{{item}}?imageView2/2/h/480"></gimage>
                <image  wx:if="{{index == 0 && !post.vr_url }}" class="item" src="{{item}}?imageView2/2/h/480"></image>
                <image  wx:if="{{index > 0 }}" class="item" src="{{item}}?imageView2/2/h/480"></image>
              </view>
            </swiper-item>               
        </swiper>

</view>

<box padding="30">
  <view class="header"> 
     <view class=" post-title h1 ">{{ post.title_info.text }}</view>

     <view class="typeinfo">
         <view class="item border">
                 <view class="key">{{post.price_info.label}}</view>         
                 <view class="value">{{post.price_info.text}}
                 <text class="px">{{post.price_info.px}}</text>
                 </view>
         </view>
         <view class="item border">
                <view class="key">{{post.type_info.label}}</view>         
                <view class="value">{{post.type_info.text}} </view>
         </view>
         <view class="item">
                 <view class="key">{{post.area_info.label}}</view>         
                 <view class="value">{{post.area_info.text}}
                 <text class="px">{{post.area_info.px}} </text>
                 </view>
         </view>
     </view>

     <view class="tagsinfo">
        <mytags mini="{{true}}" wx:if="{{post.tags_list}}" items="{{post.tags_list}}"></mytags>
     </view>

    <view  class="detail-meta">
          <view  class="meta {{ meta.url ? 'link lg' : '' }}" wx:if="{{meta.value}}" wx:for="{{post.meta_list}}" wx:for-item="meta">
            <text class="label">{{meta.label}}</text>
            <text bindtap="gotoSub" class="value"> {{ meta.value}} </text>
        </view>
    </view>    

    <view  bindtap='couponHandle' class="coupon" wx:if="{{ post.coupon_desc && post.coupon_enable}}">
      <view class="name line-limit">{{post.coupon_desc}}</view>
      <view class="action">{{ post.user_has_coupon ? '已领券' : '领券' }}</view>
    </view>        
  </view>
</box>



<box padding="0">
  <van-tabs swipeable="{{true}}"  bind:change="tabChange" animated="{{true}}" color="#00ae66">
      <van-tab custom-class="mytab" title="详细">
        <template is="meta-tab" data="{{post: post}}" />
        <template wx:if="{{post}}" is="{{post.group}}-detail" data="{{post: post, htmlContent: htmlContent, minicontent:minicontent}}"/>
      </van-tab>
      <van-tab custom-class="mytab"  title="评论"><template is="comments-tab" data="{{post: post}}" /></van-tab>
      <van-tab custom-class="mytab"  title="问答"><template is="qas-tab" data="{{post: post, qas:qas, postId:postId}}" /></van-tab>
      <van-tab custom-class="mytab"  title="更多" wx:if="{{user && user.is_broker}}"><template is="more-tab" data="{{post: post, pm:pm}}" /></van-tab>
      <van-tab custom-class="mytab"  title="跟进" wx:if="{{user && user.is_broker}}"><template is="flows-tab" data="{{post: post, flows:flows}}" /></van-tab>    
  </van-tabs>
</box>


<mycard title="户型信息"  wx:if="{{post.group == 'new'}}">
    <view class="housetype" wx:for="{{post.types}}">
      <view class="poster">
              <image bindtap="viewTypeImage" data-index="{{index}}" src="{{item.image.url}}?imageView2/2/w/300"></image>
      </view>
      <view class="meta">
        <view class="name h1">{{item.name}}</view>
        <view class="kv"><text decode="{{true}}">朝向&nbsp; &nbsp;&nbsp;{{item.position}}</text></view>
        <view class="kvs">
           <view class="kv"><text decode="{{true}}">建面&nbsp; &nbsp;&nbsp;{{item.area}} ㎡</text></view>
          <view class="kv">总价<text decode="{{true}}" class="i">&nbsp; &nbsp;&nbsp;{{item.total_price}} 万</text></view>
        </view>
      </view>
    </view>
</mycard>

<mycard wx:if="{{post.group == 'new' && post.more_url}}" title="{{post.more_title}}" opentype="webview" url="{{post.more_url}}" hat>
  <view>{{ post.more_desc }}</view>
</mycard>

<broker-link wx:if="{{post.user.is_broker}}" broker="{{post.broker_info}}" />
<recoms exclude-id="{{post.id}}" wx:if="{{post.group}}" group="{{post.group}}" count="10"></recoms>
<broker wx:if="{{post.broker_info}}" broker="{{post.broker_info}}" pid="{{post.id}}" booking="{{post.user_has_booking}}"></broker>
<safe-tips/>

<van-popup show="{{showFlowForm }}" bind:click-overlay="closeFlowForm" >
  <view class="flow-form">
        <textarea placeholder='请输入跟进内容' value="{{flowContent}}" bindinput="flowInput"></textarea>
        <van-button disabled='{{flowContent.length <= 3}}' type="primary" custom-class="fbutton" size="large" bindclick='flowSubmit'>保存内容</van-button>
        <van-button type="default" custom-class="fbutton" size="large" bindclick='closeFlowForm'>取消</van-button>
</view>

</van-popup>

<van-popup show="{{showPoster}}" bind:close="closePoster" > 
  <view class="poster-preview">
    <image src="{{posterUrl}}" mode="widthFix"></image>
    <view class="poster-actions">
      <view class="poster-actions-btn poster-cancle-btn" bind:tap="closePoster" >关闭</view>
      <view class="poster-actions-btn poster-save-btn"  bindtap="onSavePoster">保存图片</view>
    </view>

  </view>
</van-popup>



<van-popup show="{{showShareBox }}" bind:close="closeShareBox" position="bottom">
  <view class="share-box">
    <view class="share-box-title">分享房源</view>
    <view class="share-box-items">
      <button plain bindtap="closeShareBox"  open-type='share' class="share-box-item">
        <image class="share-box-item-icon" src="/assets/icons/weixin.png"></image>
        <view class="share-box-item-name">微信</view>
      </button>

      <view bindtap="onCreatePoster" class="share-box-item" wx:if="{{post.qr}}">
        <image class="share-box-item-icon" src="/assets/icons/pengyouquan.png"></image>
        <view class="share-box-item-name">朋友圈</view>
      </view>      
    </view>
  </view>
</van-popup>

        
<poster wx:if="{{posterConfig}}" id="poster" config="{{posterConfig}}" bind:success="onPosterSuccess" bind:fail="onPosterFail"></poster> 

<view class="float-btn gen-poster" catchtap="onCreatePoster">
  <image src="/assets/icons/gen-poster-icon.png"></image>
  <text>海报</text>
</view>

</block>

