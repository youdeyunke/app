<page-loading loading="{{loading}}" />
<view style="width:100%;" hidden="{{loading}}" class="content">
    <block wx:for="{{blocks}}" wx:for-item="block" wx:for-key="index" wx:key="name">
        <view class="cover">
            <cover-block wx:if="{{block.name == 'cover'}}" value="{{block.value}}" />
        </view>
            <header-block wx:if="{{block.name == 'header'}}" value="{{block.value}}" />
            <info-block wx:if="{{block.name == 'info'}}" value="{{block.value}}" />
            <map-block wx:if="{{block.name == 'map'}}" value="{{block.value}}" />
            <types-block id="types" wx:if="{{block.name == 'types'}}" value="{{block.value}}" />
            <buildings-block id="buildings" wx:if="{{block.name == 'buildings'}}" value="{{block.value}}" />
            <brokers-block wx:if="{{block.name == 'brokers'}}" value="{{block.value}}" />
            <qas-block wx:if="{{block.name == 'qas' }}" value="{{block.value}}" />
            <comments-block wx:if="{{block.name == 'comments' }}" value="{{block.value}}" />
            <events-block wx:if="{{block.name == 'events' }}" value="{{block.value}}" />
            <tours-block wx:if="{{block.name == 'tours' }}" value="{{block.value}}" />
            <recoms-block wx:if="{{block.name == 'recoms'}}" value="{{block.value}}" />
            <view class="radar" wx:if="{{block.name == 'score'}}">
                <my-card title='楼盘综合得分'>
                    <view class="score-title">
                        测评得分<text>8.0分</text>
                    </view>
                    <view class='radar-container'>
                        <canvas canvas-id="radarCanvas" class="radarCanvas" bindtouchstart="touchHandler"></canvas>
                    </view>
                </my-card>
            </view>
            <btns-block wx:if="{{block.name == 'btns'}}" value="{{block.value}}" />
            <contact-block wx:if="{{block.name == 'contact'}}" value="{{block.value}}" />
            <view class="margin" wx:if="{{block.name != 'cover'}}"></view>
    </block>
    <!-- official-account></official-account -->
    <ad-link />
    <safe-tips cat="{{post.group}}" />
    <cr />
</view>