/* pages/home/home.wxss */
page {
    padding-bottom: 130rpx;
}

.location {
    padding: 0 0 20rpx 30rpx;
}

.top-margin {
    height: 20rpx;
    display: block;
}

mycard {
    width: 750rpx;
}

.divider {
    height: 20rpx;
    display: block;
}





.html-content {
    line-height: 1.5;
    letter-spacing: 2rpx;
}

.html-content.mini {
    height: 480rpx;
    overflow: hidden;
    position: relative;
    padding-bottom: 20rpx;
}

.html-content.mini .html-content-footer {
    width: 100%;
    height: 150rpx;
    background: #fff;
    position: absolute;
    bottom: 0rpx;
    left: 0rpx;
    background: linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 1));
}

.html-content.full .html-content-footer {
    height: 0rpx;
    width: 0rpx;
    display: none;
}

.view-more-container {
    display: flex;
    justify-content: center;
    align-items: center;
}


.main {
    margin: 18rpx 0 35rpx 0;
}

.coupon {
    background: red;
    height: 80rpx;
    background: url('http://qiniucdn.udeve.cn/coupon-bg-2.png');
    background-size: 100% 80rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    letter-spacing: 5rpx;
    margin-top: 30rpx;
    width: 100%;
}

.coupon .name {
    height: 100%;
    width: 350rpx;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    color: #333;
    padding-left: 60rpx;

}

.coupon .action {
    width: 206rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
}


myfav .myfav {
    display: flex;
    justify-content: center;
    align-items: center;
    position: absolute;
    right: 100rpx;
    top: 100rpx;
}

.mask {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    background: #000;
    opacity: 0.9;
    z-index: 90;
    height: 100%;
    overflow: hidden;
}

.mask image {
    position: absolute;
    width: 515rpx;
    height: 226rpx;
    top: 10rpx;
    right: 0rpx;
}

.hide {
    display: none;
    height: 0rpx;
    width: 0rpx;
}

.overflow-hidden {
    position: fixed;
    top: 10rpx;
    left: 30rpx;
}


#audio {
    width: 100%;
    margin-bottom: 20rpx;
}


.housetype {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    padding-bottom: 20rpx;
    font-size: var(--font-s);
    border-bottom: 1rpx solid #f4f4f4;
}

.housetype .poster,
.housetype .poster image {
    width: 300rpx;
    height: 200rpx;
    overflow: hidden;
    background: #cecece;
}

.housetype .meta {
    width: 320rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
}

.housetype .name {
    width: 100%;
    font-size: 32rpx;
    font-weight: bolder;
    color: #333;
    margin-bottom: 10rpx;
}

.housetype .kv {
    font-size: 28rpx;
    margin: 5rpx 0;
}


.comments-empty {
    text-align: center;
    padding: 20rpx 0;
}

.comments-add {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
}

.comments-add image {
    width: 30rpx;
    height: 30rpx;
    margin-right: 10rpx;
    vertical-align: middle;
}


.content-switch .up {
    transform: rotate(-90deg);
    -ms-transform: rotate(-90deg);
    /* Internet Explorer */
    -moz-transform: rotate(-90deg);
    /* Firefox */
    -webkit-transform: rotate(-90deg);
    /* Safari 和 Chrome */
    -o-transform: rotate(-90deg);
    /* Opera */
}

.qa {
    margin: 10rpx 0 20rpx 0 !important;
    height: 40rpx !important;
}


.recom-post .post {
    padding: 20rpx 0;
}


.poster-preview {
    height: 942rpx;
    width: 595rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
}

.poster-preview image {
    width: 100%;
}


.poster-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100rpx;
    width: 100%;
}

.poster-actions-btn {
    color: #fff;
    font-size: var(--font-l);
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100rpx;
}

.poster-cancle-btn {
    width: 50%;
    background: var(--color-b);
}

.poster-save-btn {
    background: var(--color-a);
    width: 50%;
}

.share-btn {
    width: 32rpx;
    height: 32rpx;
    position: absolute;
    right: 30rpx;
    top: 65rpx;
}

.share-box {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: center;
    padding: 30rpx auto;
    width: 100%;
    height: 300rpx;
    font-size: var(--font-s);
}

.share-box button {
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    font-size: var(--font-s);
}

.share-box-items {
    display: flex;
    justify-content: space-around;
    align-items: center;
    width: 260rpx;
}

.share-box .share-box-items .share-box-item {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    margin-top: 0rpx;
    height: 100rpx;
    line-height: 1.5;
}

.share-box-item-icon {
    width: 32rpx;
    height: 32rpx;
}

.share-box-item-name {
    margin-top: 10rpx;
}

.float-btn {
    width: 88rpx;
    height: 88rpx;
    border-radius: 88rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: fixed;
    right: 30rpx;
    box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
    font-size: var(--font-xs);
    color: #fff;
    opacity: 0.9;
}

.float-btn.gen-poster {
    bottom: 250rpx;
    background: var(--color-b);
    box-shadow: 2rpx 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.float-btn.gen-poster image {
    width: 32rpx;
    height: 32rpx;
}


.mapimage {
    width: 750rpx;
}

.textinfo {
    width: 750rpx;
    padding: 50rpx 50rpx;
    background: #fff;
    margin-bottom: 20rpx;
    box-sizing: border-box;
    font-size: 28rpx;
}

.textinfo .name {
    color: #000;
    font-size: 34rpx;
    font-weight: bold;
}

.info_title {
    margin: 0 0 15rpx 0;
    font-weight: bolder;
    color: #cecece;
}

.info_text {
    margin: 30rpx 0;
    line-height: 1.8;

}

.recoms {
    width: 100%;
    background: #fff;
    margin-bottom: 20rpx;
    padding: 0rpx 0 20rpx 0;
}

.recoms .title {
    font-size: 34rpx;
    color: #000;
    font-weight: bolder;
    padding: 0 40rpx;
    margin-bottom: 40rpx;
}

.recoms .items {
    display: flex;
    justify-content: flex-start;
}

.more-btn,
.more-btn::after {
    border: none;
}


.fac-items {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
}

.fac-item {
    width: 25%;
    margin-bottom: 20rpx;
    height: 100rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}

.fac-item-name {}

.fac-item-icon {
    width: 50rpx;
    height: 80rpx;

}



.mypop {
    position: fixed;
    z-index: 99;
    padding: 0 30rpx;
    box-sizing: border-box;
    width: 690rpx;
    height: 80rpx;
    left: 30rpx;
    right: 30rpx;
    top: 10rpx;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    background: #07c160;
    border-radius: 10rpx;
    letter-space: 1.5;
    font-size: 28rpx;
    opacity: 0.9;
    color: #fff;
}

.mypop .count {
    color: #F7B500;
    font-weight: 800;
    font-size: 40rpx;
    margin: 0 6rpx;
}

.more-brokers-btn {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    margin-bottom: 20rpx;
    background: #fff;
}