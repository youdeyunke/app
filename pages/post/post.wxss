/* pages/home/home.wxss */

page{
  padding:0 0 120rpx 0 !important;
}

mycard{
  width: 750rpx;
}


 .info_title{
  margin:0 0 15rpx 0;
  font-weight:bolder;
  color:#000;
}

.info_text{
  margin-bottom:20rpx;
}

.post-cover{
  width:750rpx;
  height: 480rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 0rpx 0;
  padding:0rpx;
  position:relative;
}


.post-cover myfav{
  color:#fff;
  position:absolute;
  right:50rpx;
  top:50rpx;
  z-index:999;
}

.post-cover .vr-btn{
  color:#fff;
  background: rgba(0,0,0, 0.15);
  position:absolute;
  left:calc(750rpx * 0.5 - 70rpx);
  bottom:calc(50% - 70rpx);

  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 140rpx;
  width: 140rpx;
  border-radius: 100%;
  border:0rpx solid #fff;
  font-size:var(--font-xs);
  z-index:999;
}
.post-cover .vr-btn image{
  width: 80rpx;
  height: 80rpx;
}

.post-cover .image-count{
  color:#fff;
  background:rgba(0,0,0, 0.1);
  position:absolute;
  bottom:80rpx;
  padding:5rpx 18rpx;
  left:calc(50% - 50rpx);
  border-radius:40rpx;
  font-size:var(--font-xs);
  z-index:999;
  display:flex;
  letter-spacing:1rpx;
  justify-content:center;
  align-items:center;
}

.post-cover swiper{
  width:100%;
  height:100%;
}

.post-cover image{
  width:100%;
  height:100%;
}

.detail-meta{
  font-size:var(--font-s);
  display:flex;
  justify-content:flex-start;
  flex-wrap:wrap;
}


.detail-meta .meta{
}

.detail-meta .meta{
   display:flex;
   height: 50rpx;
   width:50%;
   justify-content: flex-start;
   align-items: center;
}

.detail-meta .meta.lg{
  width:100%;
}

.detail-meta  .meta text.label{
  color:#666;
  width:80rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.detail-meta .meta text.label::after{
  content: ':'
}

 .post-title{
  color:#000;
  margin: 20rpx 0 20rpx 0 ;
  font-weight:bold;
  width:550rpx;
}

.header-box{
  width:100%;
  padding-bottom:20rpx;
  position: relative;
}


.header{
  padding:35rpx;
  box-sizing:border-box;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:flex-start;
  background:#fff;
}


.header .typeinfo{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20rpx 0;
  margin:30rpx 0 0 0;
  box-sizing:border-box;
  width:100%;
  border-top:1px solid #f1f1f1;
}

.header .typeinfo .item{
  width:33.333%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
}


.header .typeinfo .item .value{
  font-size:var(--font-xl);
  color:var(--color-b);
  margin-bottom:10rpx;
}

.header .typeinfo .item .key{
  font-size:var(--font-s);
}

.header .typeinfo .item.border{
  border-right:1px solid #f1f1f1;
}

.raw image.wxParse-img{
  margin:20rpx auto;
  width:300rpx;
}

.raw .wxParse-inline {
  line-height: 1.9;
  letter-spacing: 2rpx;  
}

.html-content{
  line-height: 1.5;
  letter-spacing: 2rpx;  
}

.html-content.mini{
  height: 480rpx;
  overflow: hidden;
  position: relative;
  padding-bottom:20rpx;
}

.html-content.mini .html-content-footer{
 width:100%;
 height:150rpx;
 background:#fff;
 position: absolute;
 bottom:0rpx;
 left:0rpx;
 background: linear-gradient(rgba(255, 255, 255, 0.3),rgba(255,255,255,1));
}

.html-content.full .html-content-footer{
  height:0rpx;
  width:0rpx;
  display:none;
}

.view-more-container{
  display:flex;
  justify-content:center;
  align-items:center;
}

.view-more.btn{
  width:210rpx;
}

.main{
  margin:18rpx 0 35rpx 0;
}

.coupon{
  background: red;
  height: 90rpx;
  background: url('http://oc4tj4k6j.bkt.clouddn.com/coupon-bg-2.png');
  background-size: 100% 100rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  letter-spacing: 5rpx;
  margin-top:20rpx;
  width:100%;
}
.coupon .name{
  height: 80rpx;
  width: 350rpx;
  display: flex;
  justify-content: flex-start;
  align-items:  center;
  color: #333;
  padding-left:60rpx;
 
}

.coupon .action{
  width: 206rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
}



myfav .myfav {
  display: flex;
  justify-content: center;
  align-items: center;
  position:absolute;
  right:100rpx;
  top:100rpx;
}

.mask{
  position: absolute;
  top:0;
  left:0;
  width: 100%;
  background: #000;
  opacity: 0.9;
  z-index:90;
  height: 100%;
  overflow: hidden;
}

.mask image{
  position: absolute;
  width:515rpx;
  height: 226rpx;
  top:10rpx;
  right:0rpx;
}

.hide{
  display: none;
  height: 0rpx;
  width:0rpx;
}

.overflow-hidden{
  position: fixed;
  top:10rpx;
  left:30rpx;
}


#audio{
  width:100%;
  margin-bottom:20rpx;
}

.housetype{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:20rpx;
  padding-bottom:20rpx;
  font-size:var(--font-s);
  border-bottom:1rpx solid #f4f4f4;
}

.housetype .poster, .housetype .poster image{
  width: 250rpx;
  height: 150rpx;
  overflow: hidden;
}

.housetype .meta{
  width: 380rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.housetype .name{
  width:100%;
  padding:10rpx 0;
  height:50rpx;
  margin-bottom:15rpx;
}
.housetype .kvs text{
  color: 000;
}

.housetype .kvs{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 90%;
}


.moreurl .container-body .h2{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap
}


.comments-empty{
  text-align: center;
  padding:20rpx 0;
}

.comments-add{
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.comments-add image{
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  vertical-align: middle;
}



.block-title{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.block-title .desc{
  color: #999;
}




.content-switch .up{
  transform:rotate(-90deg);
  -ms-transform:rotate(-90deg); /* Internet Explorer */
  -moz-transform:rotate(-90deg); /* Firefox */
  -webkit-transform:rotate(-90deg); /* Safari 和 Chrome */
  -o-transform:rotate(-90deg); /* Opera */
}

.qa{
  margin:10rpx 0 20rpx 0 !important;
  height: 40rpx !important;
}


.recom-post .post{
   padding:20rpx 0;
}


.poster-preview{
  height: 1100rpx;
  width: 600rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.poster-preview image{
  width: 600rpx;
  height: 960rpx;
}


.poster-actions{
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
  width: 100%;
}

.poster-actions-btn{
  color: #fff;
  font-size:var(--font-l);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
}

.poster-cancle-btn{
  width: 50%;
  background:var(--color-b);
}

.poster-save-btn{
  background: var(--color-a);
  width: 50%;
}

.share-btn{
  width: 32rpx;
  height: 32rpx;
  position: absolute;
  right:30rpx;
  top:65rpx;
}

.share-box{
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  padding:30rpx  auto;
  width: 100%;
  height: 300rpx;
  font-size:var(--font-s);
}

.share-box button{
  border:none;
  padding:0;
  margin: 0;
  background: none;
  font-size:var(--font-s);
}

.share-box-title{
}

.share-box-items{
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: 260rpx;
}

.share-box .share-box-items .share-box-item{
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  margin-top:0rpx;
  height: 100rpx;
  line-height: 1.5;
}

.share-box-item-icon{
  width: 32rpx;
  height: 32rpx;
}

.share-box-item-name{
  margin-top:10rpx;
}

.float-btn{
  width: 88rpx;
  height: 88rpx;
  border-radius: 88rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: fixed;
  right:30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0, 0.2); 
  font-size:var(--font-xs);
  color: #fff;
  opacity: 0.9;
}

.float-btn.gen-poster{
  bottom:200rpx;
  background: rgba(0,0,0, 0.2);
}

.float-btn.gen-poster image{
  width: 32rpx;
  height: 32rpx;
}

.tabs {
  display:flex;
  justify-content:space-between;
  align-items:center;
  height:100rpx;
  font-size:var(--font-l);
  width:100%;
  background:#fff;
  border-bottom:2rpx solid #f4f4f4;
}

.tabs .tab-item{
  display:flex;
  height:100%;
  justify-content:center;
  align-items:center;
  width:30%;
}

.tabs .tab-item.active{
  color:var(--color-a);
}

.tabs .tab-blank{
 width:2rpx;
 height:70%;
 background:#f4f4f4;
}

