/* pages/home/home.wxss */

page{
  padding:0 0 120rpx 0 !important;
}

mycard{
  width: 750rpx;
}



.post-cover{
  width:750rpx;
  height: 420rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 10rpx 0;
  padding:0rpx;
  position:relative;
}

.post-cover .image-count{
  color:#fff;
  background:rgba(0,0,0, 0.1);
  position:absolute;
  bottom:80rpx;
  padding:5rpx 18rpx;
  left:calc(50% - 50rpx);
  border-radius:40rpx;
  font-size:var(--font-xs);
  z-index:999;
  display:flex;
  letter-spacing:1rpx;
  justify-content:center;
  align-items:center;
}

.post-cover swiper{
  width:100%;
  height:100%;
}

.post-cover swiper-item{
  display: flex;
  justify-content: center;
  align-items: center;
  background: #000;
}

.post-cover .first{
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative; 
  height: 100%;
  width: 100%;
}


.post-cover .first image.play{
  background: rgba(0,0,0, 0.2);
  z-index:10;
  border-radius: 100rpx;
  width: 100rpx;
  height: 100rpx;
  padding: 30rpx;
  left:calc(50% - 80rpx);
  top: calc(50% - 80rpx);
  position: absolute;  
}

.post-cover .first image.item{
  left:0rpx;
  right:0rpx;
  top:0rpx; 
}

.post-cover .first video{
  width: 100%;
  height: 100%;
}

.post-cover image.item{
  height:100%;
  width: 100%;
  margin:0 auto;
}

.detail-meta{
  font-size:28rpx;
  display:flex;
  justify-content:flex-start;
  flex-wrap:wrap;
  margin-bottom:0rpx;
  margin-top:20rpx;
  width: 100%;
}

.detail-meta .meta{
   display:flex;
   height: 55rpx;
   width:50%;
   justify-content: flex-start;
   align-items: center;
}

.detail-meta .meta.lg{
  width:100%;
}

.detail-meta  .meta text.label{
  color:#999;
  width:150rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.detail-meta .meta.link .value{
  color: rgb(121, 121, 172);
}

.more-meta{
    width: 660rpx;
    height: 100rpx;
    font-size:30rpx;
    text-align: center;
    margin:20rpx auto;
    display: flex;
    justify-content: center;
    align-items: center;
    vertical-align: middle;
    background: #F8F8F8;
    color: #000;
    letter-spacing: 1.6rpx;
    font-weight: bolder;
    border-radius: 6rpx;
}

 .post-title{
  color:#000;
  font-weight: bold;
  margin: 10rpx 0 20rpx 0 ;

  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size:42rpx;
}

.tagsinfo{
  display: flex;
  width: 100%;
  margin-bottom:10rpx;
  align-items: center;

}

.tagsinfo .num{
  font-size:20rpx;
  color: #999;
}


.header{
  box-sizing:border-box;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:flex-start;
  background:#fff;
}


.raw image.wxParse-img{
  margin:20rpx auto;
  width:300rpx;
}

.raw .wxParse-inline {
  line-height: 1.9;
  letter-spacing: 2rpx;  
}

.html-content{
  line-height: 1.5;
  letter-spacing: 2rpx;  
}

.html-content.mini{
  height: 480rpx;
  overflow: hidden;
  position: relative;
  padding-bottom:20rpx;
}

.html-content.mini .html-content-footer{
 width:100%;
 height:150rpx;
 background:#fff;
 position: absolute;
 bottom:0rpx;
 left:0rpx;
 background: linear-gradient(rgba(255, 255, 255, 0.3),rgba(255,255,255,1));
}

.html-content.full .html-content-footer{
  height:0rpx;
  width:0rpx;
  display:none;
}

.view-more-container{
  display:flex;
  justify-content:center;
  align-items:center;
}

.view-more.btn{
  width:210rpx;
}

.main{
  margin:18rpx 0 35rpx 0;
}

.coupon{
  background: red;
  height: 80rpx;
  background: url('http://qiniucdn.udeve.cn/coupon-bg-2.png');
  background-size: 100% 80rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  letter-spacing: 5rpx;
  margin-top:30rpx;
  width:100%;
}
.coupon .name{
  height: 100%;
  width: 350rpx;
  display: flex;
  justify-content: flex-start;
  align-items:  center;
  color: #333;
  padding-left:60rpx;
 
}

.coupon .action{
  width: 206rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
}


myfav .myfav {
  display: flex;
  justify-content: center;
  align-items: center;
  position:absolute;
  right:100rpx;
  top:100rpx;
}

.mask{
  position: absolute;
  top:0;
  left:0;
  width: 100%;
  background: #000;
  opacity: 0.9;
  z-index:90;
  height: 100%;
  overflow: hidden;
}

.mask image{
  position: absolute;
  width:515rpx;
  height: 226rpx;
  top:10rpx;
  right:0rpx;
}

.hide{
  display: none;
  height: 0rpx;
  width:0rpx;
}

.overflow-hidden{
  position: fixed;
  top:10rpx;
  left:30rpx;
}


#audio{
  width:100%;
  margin-bottom:20rpx;
}


.typeinfo .item .value{
    font-weight: bolder;
}

.housetype{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:20rpx;
  padding-bottom:20rpx;
  font-size:var(--font-s);
  border-bottom:1rpx solid #f4f4f4;
}

.housetype .poster, .housetype .poster image{
  width: 250rpx;
  height: 150rpx;
  overflow: hidden;
}

.housetype .meta{
  width: 390rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.housetype .name{
  width:100%;
  padding:10rpx 0;
  height:50rpx;
  margin-bottom:15rpx;
}
.housetype .kvs text{
  color: 000;
}

.housetype .kvs{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 90%;
}


.moreurl .container-body .h2{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap
}


.comments-empty{
  text-align: center;
  padding:20rpx 0;
}

.comments-add{
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.comments-add image{
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  vertical-align: middle;
}


.content-switch .up{
  transform:rotate(-90deg);
  -ms-transform:rotate(-90deg); /* Internet Explorer */
  -moz-transform:rotate(-90deg); /* Firefox */
  -webkit-transform:rotate(-90deg); /* Safari 和 Chrome */
  -o-transform:rotate(-90deg); /* Opera */
}

.qa{
  margin:10rpx 0 20rpx 0 !important;
  height: 40rpx !important;
}


.recom-post .post{
   padding:20rpx 0;
}


.poster-preview{
  height: 710rpx;
  width: 710rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.poster-preview image{
  width: 100%;
}


.poster-actions{
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
  width: 100%;
}

.poster-actions-btn{
  color: #fff;
  font-size:var(--font-l);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100rpx;
}

.poster-cancle-btn{
  width: 50%;
  background:var(--color-b);
}

.poster-save-btn{
  background: var(--color-a);
  width: 50%;
}

.share-btn{
  width: 32rpx;
  height: 32rpx;
  position: absolute;
  right:30rpx;
  top:65rpx;
}

.share-box{
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  padding:30rpx  auto;
  width: 100%;
  height: 300rpx;
  font-size:var(--font-s);
}

.share-box button{
  border:none;
  padding:0;
  margin: 0;
  background: none;
  font-size:var(--font-s);
}

.share-box-items{
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: 260rpx;
}

.share-box .share-box-items .share-box-item{
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  margin-top:0rpx;
  height: 100rpx;
  line-height: 1.5;
}

.share-box-item-icon{
  width: 32rpx;
  height: 32rpx;
}

.share-box-item-name{
  margin-top:10rpx;
}

.float-btn{
  width: 88rpx;
  height: 88rpx;
  border-radius: 88rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: fixed;
  right:30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0, 0.2); 
  font-size:var(--font-xs);
  color: #fff;
  opacity: 0.9;
}

.float-btn.gen-poster{
  bottom:250rpx;
  background:var(--color-b);
  box-shadow: 2rpx 2rpx 10rpx rgba(0,0,0, 0.2);
}

.float-btn.gen-poster image{
  width: 32rpx;
  height: 32rpx;
}


.mapinfo{
    background: #fff;
    padding:40rpx 40rpx 0 40rpx ;
    font-size:28rpx;
    width:750rpx;
    box-sizing: border-box;
    margin-bottom:0rpx;
    letter-spacing: 0.5;
}

.mapinfo .name{
    color: #000;
    font-size:34rpx;
    font-weight: bold;
}

.mapinfo .location .label{
    color: #999;
}

.mapinfo .location .value{
    color: #000;
}

.mapinfo .location{
    margin:20rpx 0;
}


.mapimage{
    width: 750rpx;
}

.textinfo{
    width: 750rpx;
    padding:50rpx 50rpx;
    background: #fff;
    margin-bottom:20rpx;
    box-sizing: border-box;
    font-size: 28rpx;
}

.textinfo .name{
    color: #000;
    font-size:34rpx;
    font-weight: bold;
}

 .info_title{
  margin:0 0 15rpx 0;
  font-weight:bolder;
  color:#000;
}

.info_text{
  margin:30rpx 0;
  line-height:1.4;

}