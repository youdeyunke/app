/* pages/home/home.wxss */

page{

  background-repeat: no-repeat;
  background-image: url("http://jiayaosu-10013564.image.myqcloud.com/63405b8d-6738-4b16-8052-1a5efb692768");
  background-size: 750rpx 301rpx;
  background-color: #f0f0f0;
}


page .container{
  width:690rpx;
  margin:0 auto 100rpx auto;
}

.myvideo video{
  width:690rpx;
  height: 390rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.box{
  border-radius: 20rpx;
  background:#fff;
  padding:25rpx 20rpx;
  box-shadow: 6rpx 6rpx 18rpx rgba(0,0,0, 0.1);
}

.box .header{
  position: relative;
  width:680rpx;
}

.box .header .line{
  border-bottom:1rpx dashed #d8d8d8;
  height: 1rpx;
  margin:20rpx 0 20rpx 0;
}

.box .header .title{
  font-size:28rpx;
  color:#333;
  margin-bottom:30rpx;
  display: inline-block;
}

.box .tags{
  margin-bottom:10rpx;
}

.box .header .meta text{
  font-size:22rpx;
  color:#000;
}

.box .header .meta text.label{
  color:#666;
  width:150rpx;
  display: inline-block;
}

.box .raw{
  color: #808080;
  font-size:20rpx;
  line-height: 32rpx;
  letter-spacing: 2rpx;
}

.box .raw image.wxParse-img{
  margin:20rpx auto;
  width:300rpx;
}

.box.html-content{
  margin-bottom:40rpx;
}

.box.html-content.small, box.box.html-content.small .raw{
  height: 400rpx;
  overflow: hidden;
  position: relative;
  padding-bottom:20rpx;
}

.box.html-content.small .readmore{
  position: absolute;
  bottom:10rpx;
  left:10rpx;
  font-size:24rpx;
  width: 100%;
  background: #fff;
}

.main{
  margin:18rpx 0 35rpx 0;
}

.coupon{
  margin: 0 0 23rpx 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  flex-wrap: nowrap;
  align-items: center;
  box-shadow: 6rpx 6rpx 18rpx rgba(0,0,0, 0.1);
}

.coupon .name{
  display: flex;
  flex-direction: column;
  width:367rpx;
}

.coupon .name .t{
  color:#333;
  font-size:26rpx;
}

.coupon .name .d{
  color:#666;
  font-size: 20rpx;
}

.coupon .icon {
  margin-right:36rpx;
  margin-left:15rpx;
  background:#ffd900;
  width:82rpx;
  height: 82rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 82rpx;
}

.coupon .icon image{
  width:56rpx;
  height: 60rpx;
}

.coupon .btn{
  width:162rpx;
  height: 52rpx;
  font-size: 26rpx;
  background:#ffd900;
  text-align: center;
  line-height: 52rpx;
  border-radius: 10rpx;
}

.h1{
  font-size:30rpx;
  color:#000;
  padding: 0 20rpx;
  margin: 0 0 20rpx 0;
}


.footer-btns{
  display: flex;
  flex-wrap: nowrap;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  width:690rpx;
  padding:0rpx 30rpx;
  position: fixed;
  bottom:0rpx;
  border-top:1px solid ＃efefef;
  height: 100rpx;
  z-index:20;
}

.footer-btns .share{
  font-size:22rpx;
  color:#666;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;

  width:120rpx;
  background-color:#fff;
  outline:none;
  border:1rpx solid #fff;
  padding-top:10rpx;
}

.footer-btns button.share::after{
        border:0px solid #fff;
        margin:0;
}



.footer-btns .share image{
  width:30rpx;
  height: 30rpx;
}

.footer-btns .qa {

  width:366rpx;
  font-size:26rpx;
  color:#000;
  background:#ffd900;
  margin-right:30rpx;
}

.footer-btns .qa image{
  height: 30rpx;
  width: 30rpx;
  margin-left:20rpx;
}

.footer-btns .call{

  background: #4a68e2;
  width:222rpx;
  font-size:26rpx;
  color:#fff;
}

.footer-btns .call image{
  width:30rpx;
  height: 30rpx;
   margin-left:20rpx;
}

.footer-btns .qa, .footer-btns .call{
  display: flex;
  justify-content: center;
  align-items: center;
  height: 66rpx;
  border-radius: 10rpx;
}



.like image{
  width:28rpx;
  height: 28rpx;
}
 .like{
  padding-left:10rpx;
  padding-right:5rpx;
  width:84rpx;
  height: 34rpx;
  font-size:20rpx;
  color:#fff;
  background: rgba(0,0, 0, 0.5);
  border-top-left-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
  position: absolute;
  right:10rpx;
  top:0rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: nowrap;
  justify-content: space-between;
}

.mask{
  position: absolute;
  top:0;
  left:0;
  width: 100%;
  background: #000;
  opacity: 0.9;
  z-index:90;
  height: 100%;
  overflow: hidden;
}

.mask image{
  position: absolute;
  width:515rpx;
  height: 226rpx;
  top:10rpx;
  right:0rpx;
}

.hide{
  display: none;
  height: 0rpx;
  width:0rpx;
}

.overflow-hidden{
  position: fixed;
  top:10rpx;
  left:30rpx;
}

@import "/tpls/posts/mini_listing.wxss";

#audio{
  width:100%;
  margin-bottom:20rpx;
}

.housetype{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:20rpx;
}

.housetype .poster, .housetype .poster image{
  width: 280rpx;
  height: 200rpx;
}
.housetype .meta{
  font-size: 24rpx;
  width: calc(100% - 280rpx);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.housetype .name{
  font-size:30rpx;
  border-bottom:2rpx solid #f4f4f4;
  width:100%;
  padding:10rpx 0;
  height:50rpx;
  margin-bottom:15rpx;
}
.housetype .kvs text{
  color: red;
}

.housetype .kvs{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 90%;
}
