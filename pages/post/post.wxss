/* pages/home/home.wxss */

page{
  padding:0 0 120rpx 0;
}

.post-cover{
  width:750rpx;
  height: 410rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 20rpx 0;
  padding:0rpx;
}

.detail-meta{
  padding:20rpx 0 0 20rpx;
  border-radius:10rpx;
}

.detail-meta .meta{
 display:flex;
 height: 50rpx;
 justify-content: flex-start;
 align-items: center;
}

.detail-meta  .meta text.label{
  color:#666;
  width:110rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

 .post-title{
  color:#000;
  margin: 20rpx auto 20rpx auto !important;
  font-weight:bold;

}

.header{
  background:#fff;
  position:relative;
  width:100%;
  height:440rpx;
  display:flex;
  justify-content:center;
  align-items:center;
}

.header .container{
  width:710rpx;
  position:absolute;
  top:-60rpx;
  border-radius: 10rpx;
}


.raw image.wxParse-img{
  margin:20rpx auto;
  width:300rpx;
}
.html-content{

  line-height: 64rpx;
  letter-spacing: 2rpx;  
  font-weight: lighter;
}

.html-content.small, box.box.html-content.small .raw{
  height: 400rpx;
  overflow: hidden;
  position: relative;
  padding-bottom:20rpx;
}


.html-content.small .readmore{
  position: absolute;
  bottom:10rpx;
  left:10rpx;
  width: 100%;
  background: #fff;
}

.readmore{
  display: flex;
  justify-content: center;
  align-items: center;
}

.readmore text{
  text-decoration: underline;
    font-weight: 800;
}

.main{
  margin:18rpx 0 35rpx 0;
}

.coupon{
  margin: 0 0 23rpx 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  flex-wrap: nowrap;
  align-items: center;
  box-shadow: 6rpx 6rpx 18rpx rgba(0,0,0, 0.1);
}

.coupon .name{
  display: flex;
  flex-direction: column;
  width:367rpx;
}

.coupon .name .t{
  color:#333;
}

.coupon .name .d{
  color:#666;

}

.coupon .icon {
  margin-right:36rpx;
  margin-left:15rpx;
  background:#ffd900;
  width:82rpx;
  height: 82rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 82rpx;
}

.coupon .icon image{
  width:56rpx;
  height: 60rpx;
}

.coupon .btn{
  width:162rpx;
  height: 52rpx;

  background:#ffd900;
  text-align: center;
  line-height: 52rpx;
  border-radius: 10rpx;
}


.footer-btns{
  background: #fff;
  width:100%;
  padding:0rpx 0rpx;
  position: fixed;
  bottom:0rpx;
  border-top:none;
  height: 100rpx;
  z-index:20;
}

.footer-btns ul{
  display: flex;
  flex-wrap: nowrap;
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  height: 100%;
}

.footer-btns li{
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  color:#fff;
  opacity: 0.93;
}

.footer-btns li image{
  height: 40rpx;
  width: 40rpx;

}

.footer-btns li.call{
  background:green;

  color: #fff;
  font-weight: bold;
  width: 40%;
}
.footer-btns li.call image{
  margin-right:20rpx;
}

.footer-btns li.booking{
  background:#7c0875;
  width:40%;
}

.footer-btns li.booking image{
    margin-right:20rpx;
}

.footer-btns li.fav{
  width: 20%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #333;
  text-align: center;
}

myfav .myfav {
  display: flex;
  justify-content: center;
  align-items: center;
}


.mask{
  position: absolute;
  top:0;
  left:0;
  width: 100%;
  background: #000;
  opacity: 0.9;
  z-index:90;
  height: 100%;
  overflow: hidden;
}

.mask image{
  position: absolute;
  width:515rpx;
  height: 226rpx;
  top:10rpx;
  right:0rpx;
}

.hide{
  display: none;
  height: 0rpx;
  width:0rpx;
}

.overflow-hidden{
  position: fixed;
  top:10rpx;
  left:30rpx;
}

@import "/tpls/posts/mini_listing.wxss";

#audio{
  width:100%;
  margin-bottom:20rpx;
}

.housetype{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.housetype .poster, .housetype .poster image{
  width: 250rpx;
  height: 200rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.housetype .meta{
  width: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.housetype .name{
  width:100%;
  padding:10rpx 0;
  height:50rpx;
  margin-bottom:15rpx;
}
.housetype .kvs text{
  color: 000;
}

.housetype .kvs{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 90%;
}


.moreurl .container-body .h2{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap
}


.comments-empty{
  text-align: center;
  padding:20rpx 0;
}

.comments-add{
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.comments-add image{
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  vertical-align: middle;
}

.block-title{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.block-title .desc{
  color: #999;
}
@import "/tpls/posts/mini_listing.wxss";
