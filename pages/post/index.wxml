<view class="header">

  <van-search 
    name="kw" 
    value="{{kw}}" 
    placeholder-style="font-size:24rpx;color:#cecece;" 
    placeholder="输入小区、街道关键词" 
    background="#none" 
    field-class="search-box-field"
    custom-class="search-box"
    bind:change="inputChange"
    bind:clear="inputClear"
    focus="{{false}}" 
  />
  <view class="f">
    <base-filter initValue="{{filter}}"  bind:change="filterChange" />
  </view>
</view>


<view class="res">

  <box wx:if="{{filter.sub_district_id}}" padding="20">
    <sub-district sid="{{filter.sub_district_id}}" />
  </box>
  
  <box padding="20" width="750">
    <items kw="{{kw}}" wx:if="{{filter}}" page="{{page}}" filter="{{filter}}" />
  </box>

</view>
