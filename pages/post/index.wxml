<!--pages/post/index.wxml-->
    <block wx:for="{{posts}}" wx:for-item="postitems">
            <postcard wx:for="{{postitems}}" item="{{item}}"></postcard>
    </block>


<view class="empty" wx:if="{{posts.length == 0}}">
   <image src="/assets/images/cover-none.png"></image>
   <view>{{ emptyText || '没有数据'}}</view>
</view>

  <view class="empty" wx:if="{{isEmpty}}">没有数据</view>
  <view class="empty" wx:if="{{isEnd}}">END</view>
  <view class="empty" wx:if="{{loading}}">加载中...</view>
