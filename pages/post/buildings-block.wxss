.buildings {
    display: flex;
    justify-content: flex-start;
    flex-wrap: nowrap;
}

.building {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    width: 280rpx;
    margin-right: 30rpx;
}

.building .cover image {
    width: 280rpx;
    height: 180rpx;
}

.building .name {
    font-size: 28rpx;
    color: #333;
    font-weight: bolder;
    margin-top: 8rpx;
}

.building .attr {
    font-size: 24rpx;
    display: flex;
    justify-content: flex-start;
    margin-top: 8rpx;
}

.building .attr .label {
    margin-right: 15rpx;
    color: #999;
}

.building .cover {
    position: relative;
}

.building .zoom {
    position: absolute;
    bottom: 0rpx;
    right: 0rpx;
    padding: 4rpx;
    background: rgba(0, 0, 0, 0.15);
    font-size: 28rpx;
    color: #f4f4f4;
    display: flex;
    border-radius: 6rpx;
}

.building .attr .value {
    margin-right: 15rpx;
}

.price {
    color: #ff0000;
}