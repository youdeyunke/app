/* pages/post/meta-block.wxss */

.header {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    background: #fff;
}

.tagsinfo {
    display: flex;
    width: 100%;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 20rpx;
}

.tagsinfo .num {
    font-size: 20rpx;
    color: #999;
}

.title-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0rpx 0 20rpx 0;
    width: 100%;
}

.title-block .post-title {
    font-size: 40rpx;
    font-weight: bolder;
    color: #333;
}

.title-block .report {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.baseinfo {
    margin-bottom: 20rpx;
}

.baseinfo .item .value {
    font-weight: bolder;
}

.baseinfo .item .key {
    margin-top: 10rpx;
}

.baseinfo {
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-sizing: border-box;
    width: 100%;
}

.baseinfo .item {
    width: 33.333%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
}

.baseinfo .item .value {
    font-size: 38rpx;
    color: #ff4444;
    margin-top: 0rpx;
}

.baseinfo .item .value .px {
    font-size: 24rpx;
    color: #666;
}

.baseinfo .item .key {
    font-size: var(--font-xs);
    color: #999;
}

.baseinfo .item.border {
    border-right: 1px solid #f1f1f1;
    margin-right: 30rpx;
}

.detail-meta {
    font-size: 28rpx;
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
    margin-bottom: 20rpx;
    width: 100%;
}

.detail-meta .meta {
    display: flex;
    height: 40rpx;
    margin-bottom: 10rpx;
    width: 50%;
    justify-content: flex-start;
    align-items: center;
}

.detail-meta .meta.lg {
    width: 100%;
}

.detail-meta .meta text.label {
    color: #999;
    width: 130rpx;
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.detail-meta .meta text.value {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.detail-meta .meta navigator.value {
    color: rgb(121, 121, 172);
}

.more-btn {
    width: 660rpx;
    height: 100rpx;
    font-size: 30rpx;
    text-align: center;
    margin: 20rpx auto;
    display: flex;
    justify-content: center;
    align-items: center;
    vertical-align: middle;
    background: #F8F8F8;
    color: #333;
    letter-spacing: 1.6rpx;
    font-weight: bolder;
    border-radius: 6rpx;
}

.dinyue-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
}