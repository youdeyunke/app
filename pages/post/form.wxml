<import src="/tpls/posts/form-rental.wxml" />
<import src="/tpls/posts/form-old.wxml" />

<form bindsubmit="submit">
  <box>
      <van-field bindchange="inputChange" error="{{error.title}}" input-align="left" data-name="title" label="房源标题" value="{{post.title}}" clearable placeholder="如：房东急租小2房" />
  </box>

  <card wx:if="{{step == 1}}" title="房源照片" subtitle="请上传{{imagesMin}}~{{imagesMax}}张真实房源照片" hat>
      <images-uploader overlook-image="{{post.overlook_image}}" bindchange="imagesChanged" max="{{imagesMax}}" min="{{imagesMin}}" enable-video="{{true}}" video="{{post.video}}" cover="{{post.cover_index || 0}}" images="{{post.images}}"></images-uploader>

  </card>

  <card wx:if="{{step == 1}}" title="全景外链" subtitle="选填" hat>
    <van-field bindchange="inputChange" label="链接" value="{{ post.vr_url }}" input-align="left" placeholder="请输入" data-name="vr_url" error="{{error.vr_url}}" />
  </card>

  <template is="form-{{post.group}}" data="{{user:user, is_sublet: is_sublet, error: error, post: post, step: step , minRentMonthItems: minRentMonthItems}}" />

  <card wx:if="{{step == 2}}" hat title="联系人信息" subtitle="必填">
    <van-field bindchange="inputChange" label="姓名" value="{{ post.broker_name || broker_name}}" input-align="left" placeholder="请输入" data-name="broker_name" error="{{error.broker_name}}" />
    <van-field bindchange="inputChange"  label="电话" value="{{ post.broker_mobile || broker_mobile }}" placeholder="请输入" input-align="left" data-name="broker_mobile" error="{{error.broker_mobile}}" />
    <van-field bindchange="inputChange"  label="微信" value="{{post.broker_wechat || broker_wechat }}" placeholder="选填" input-align="left" data-name="broker_wechat" border="{{false}}" />
  </card>


  <flow-tips />

  <view class="buttons">
    <block wx:if="{{step == 1}}">
      <button data-name="step1" form-type="submit" type="primary" class="btn ">下一步 1/2</button>
    </block>

    <block wx:if="{{step == 2}}">
      <button data-name="step2" type="primary" form-type="submit" class="btn ">提交保存</button>
      <button bindtap="previousStep" type="default" class="btn ">返回修改</button>
    </block>
  </view>



</form>
<mypicker bindtap="showMinRentMonthPicker" id="min-rent-month" items="{{minRentMonthItems}}" bindchange="minRentMonthChange" />
<city-picker id="citypicker" bindchange="cityChanged" show="{{cityPickerShow}}" />
<typepicker id="typepicker" bindconfirm="typeChanged" />
<payment id="payment" bindconfirm="paymentChanged" />
<floorpicker id="floorpicker" bindconfirm="floorChanged" />
<fitment-picker id="fitmentpicker" bindconfirm="fitmentChanged" />

