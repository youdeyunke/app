/* pages/post/simple-images-block.wxss */
.wrapper{
  display:flex;
  justify-content:space-between;
  margin:20rpx auto;
}


.wrapper2{
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  align-items:center;

}


.west{
  background:#f4f4f4;
  width:500rpx;
  height:404rpx;
  margin-right:4rpx;
}

.north{
  background:#f4f4f4;
  width:206rpx;
  height:200rpx;

}

.south{
  background:#f4f4f4;
  width:206rpx;
  height:200rpx;
  position:relative;
}

.south .count{
  width:206rpx;
  height:200rpx;
  position:absolute;
  top:0rpx;
  left:0rpx;
  z-index:10;
  background:rgba(0,0,0, 0.5);
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:36rpx;
  color:#ffffff;
  font-weight:bolder;
  letter-space:1.2;

}
