.header{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: white;
  width: 100%;
  padding:10rpx 30rpx;
  box-sizing: border-box;
  position: fixed;
  left:0rpx;
  right:0rpx;
  top:0rpx;
  z-index:99;
  border-bottom:2rpx solid #f4f4f4;
}


.header .f{
  width: 100%;
  margin: 10rpx 0;
}

.search-box{
  width: 740rpx;
}


.res{
  padding-top:200rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}


.subinfo{
    width:100%;
    border-bottom:2rpx solid #f4f4f4;
}

.float-btn{
  width: 88rpx;
  height: 88rpx;
  border-radius: 88rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: fixed;
  right:30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0, 0.2); 
  font-size:var(--font-xs);
  color: #fff;
  opacity: 0.9;
}

.float-btn.ditu{
  bottom:150rpx;
  background:var(--color-b);
  box-shadow: 2rpx 2rpx 10rpx rgba(0,0,0, 0.2);
}

.float-btn.ditu image{
  width: 88rpx;
  height: 88rpx;
}

