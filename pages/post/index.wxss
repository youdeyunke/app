.header{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: white;
  width: 100%;
  padding:10rpx 30rpx;
  box-sizing: border-box;
  position: fixed;
  left:0rpx;
  right:0rpx;
  top:0rpx;
  z-index:99;
  border-bottom:2rpx solid #f4f4f4;
}


.header .f{
  width: 100%;
  margin: 10rpx 0;
}

.search-box{
  width: 740rpx;
}

.search-box .van-cell  {

  background:#F6F7FB ;
  border-radius: 15rpx;
  display: flex;
  justify-content: center;
  align-items:  center;
  height: 80rpx;

}


.res{
  padding-top:200rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}


.subinfo{
    width:100%;
    border-bottom:2rpx solid #f4f4f4;
}