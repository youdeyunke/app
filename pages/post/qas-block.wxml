<mycard title="{{ value.title }}"  hat="{{false}}" title-size="32" sub-title="{{ value.more_title }}" url="{{moreUrl}}" >
  <view class="qas">
    <view class="empty" wx:if="{{value.items.length == 0}}">还没有人提问</view>

    <view class="item" hover-class="none" wx:key="id"   wx:for="{{value.items}}" >
        <view class="icon">问</view>
        <view class="info">
            <navigator hover-class="none" url="/pkgQa/pages/qa/qa?id={{item.id}}"  class="content">{{item.content}}</navigator>
            <view class="footer">
                <view class="count">{{item.answers_count}}条回答</view>
            </view>
        </view>
    </view>

    <navigator class="add-btn"  hover-class="none" url="/pkgQa/pages/qa/new?target_id={{value.post_id}}&target_type=post">
     <van-icon name="edit" /> 去提问
    </navigator>

  </view>

</mycard>
