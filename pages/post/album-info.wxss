/* pages/post/album-info.wxss */

.album {
    width: 750rpx;
    height: 300rpx;
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
    padding: 20rpx;
}

.album .name {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
}

.album .content {
    color: #666;
    line-height: 1.5;
}