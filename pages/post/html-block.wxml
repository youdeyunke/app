<mycard title-size="40" title="{{value.title}}" hat="{{false}}" >
    <view class="html-content {{ minicontent == true ? 'mini' : 'full' }}">
        <view class="raw">
            <rich-text nodes="{{prettyHtml}}" />
        </view>
        <view class="html-content-footer"></view>
    </view>

    <view class="more-btn" bindtap="contentHandle" wx:if="{{minicontent}}" >
        显示全文
    </view>

</mycard>
