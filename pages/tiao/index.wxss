
page{
  background: #ffd900;
}


page .container{
  width:690rpx;
  margin: auto;
}

.item{
  background: #fff;
  padding:30rpx;
  width:calc(100% - 60rpx);
  position: relative;
  margin-bottom:50rpx;
  border-radius: 10rpx;
}

.title-block{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:30rpx;
  margin-top:10rpx;
}

.title-block .l{
  width:80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.title-block .l image{
  border-radius: 100%;
  width:100%;
  height: 100%;
}


.title-block .m{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
  width:calc(100% - 80rpx - 120rpx - 40rpx);
}
.title-block .m .title{
  font-size:28rpx;
  color:#000;
  
}

.title-block .m .address{
  font-size:24rpx;
  color: #cecece;
  width:100%;

}

.title-block .m .address image{
  width:25rpx;
  height: 25rpx;
}

.title-block .r{
  width:120rpx;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
}

.title-block .r image{
  width:31rpx;
  height: 31rpx;
}

.poster-block image{
  width: 100%;
}

.tag-block{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;                  
}

.tag-block view{
  background: #EFEFEF;
  color: #666;
  font-size:20rpx;
  border-radius: 10rpx;
  padding:5rpx 15rpx;
  text-align: center;
  flex-shrink: 0;
  margin-right:10rpx;
}

.tag-block view.tag-yellow{
  background: #ffd900;
}

.item .footer{
position:absolute;
bottom:-29rpx;
left:0rpx;
z-index:10;
height:30rpx;
width:100%;  
}