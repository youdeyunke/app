<view class="container">
  <navigator class="item" open-type='navigateTo' hover-class='none' wx:for="{{posts}}" url="/pages/post/post?id={{item.id}}">
    <view class="poster-block">
      <image src="{{item.cover.url}}"></image>
    </view>
    <view class="title-block">
      <view class="l">
        <image src="/assets/images/logo.jpeg"></image>
      </view>
      <view class="m">
        <view class="title line-limit">{{item.block_info.name}}</view>
        <view class="address line-limit">
        <image src="/assets/icons/location.png"></image>
        {{item.block_info.district.name}}-{{item.block_info.street}}
        </view>
      </view>
      <view class="r">
      <block wx:for="{{[1,2,3,4,5]}}" wx:for-item="score">
        <image wx:if="{{item.score >= score }}" src="/assets/icons/star-yellow.png"></image>
        <image wx:if="{{item.score < score }}" src="/assets/icons/star-dark.png"></image>
      </block>
      </view>
    </view>
    <view class="tag-block">
      <view class="tag {{tagIndex <= 2 ? 'tag-yellow' : '' }}" wx:for="{{item.tags_list}}" wx:for-item="tag" wx:for-index="tagIndex">{{tag}}</view>
    </view>

  <image src="/assets/images/post-list-footer.png" class="footer"></image>
  </navigator>


</view>