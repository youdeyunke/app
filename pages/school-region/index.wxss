/* pages/school-region/index.wxss */
.header{
  height:500rpx;
  width:750rpx;

  padding:0;
  margin:0;
  background-image: url('http://qiniucdn.udeve.cn/fsz-header-bg-2.3x.png');

  background-size: 750rpx 500rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

.header .app-name{
  font-size:28rpx;
  letter-spacing: 0.25;
  color: #fff;
  font-weight: bolder;
  margin-top:90rpx;
  margin-bottom:56rpx;
}

.header .tabs{
  width: 245rpx;
  height: 43rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:60rpx;
}

.header .tab{
  color: #fff; 
  font-size:22rpx;
  height: 100%;
}

.header .tab.tab-active{
  font-size: 28rpx;
  border-bottom:4rpx solid #fff;
  padding-bottom:4rpx;

}

.header .search{
  width: 100%;
}

.notice{
  width: 750rpx;
  position: fixed;
  left:0rpx;
  right: 0rpx;
  bottom: 0rpx;
}

.page-title{
  background-image: url('https://qiniucdn.udeve.cn/fang-fsz-pagetitle.3x-2.png');
  background-size: 710rpx 40rpx;
  height: 40rpx;
  width: 710rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #333;
  margin-bottom:30rpx;
  margin-top:37rpx;
  font-size:28rpx;
}

.district-list{
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  width: 710rpx;
  margin:20rpx 20rpx  20rpx 20rpx;
}

.district{
  width: 710rpx;
  box-sizing: border-box;
  height:170rpx;
  background: #fff;
  border-radius: 10rpx;
  box-shadow:#cecece  2rpx 4rpx 6rpx 0.1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding:0 56rpx;
}

 .district .left{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

 .district .name{
  color: #333;
  font-size: 24rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;  
}

 .district .name image{
  width: 26rpx;
  height: 24rpx;
  margin-right:10rpx;
}

 .district .address{
  color: #999;
  font-size:20rpx;
  margin-top:22rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.district .address image{
  width: 18rpx;
  height: 26rpx;
  margin-right: 20rpx;
}

.district .right{
  color: 999;
  font-size:20rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  height: 40rpx;
}

.district .right .number{
  color: #F5A623;
  font-size:40rpx;
  margin-right: 20rpx;
}