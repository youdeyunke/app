<view style="width:100%">
    <ud-tabs tabs='{{tabs}}' model:active-index='{{tabIndex}}' bind:change='tabChangeHandle' mytabs="newtabs" myborder="newborder"></ud-tabs>
</view>
<search-bar bind:change="kwChange" />
<view hidden="{{ tabIndex != 0}}" style="">
    <view class="res news-list">
        <scroll-view scroll-x class="news-cats-scroll">
            <navigator url="/pkgNews/pages/news/index?cat_id={{cat.id}}" class="news-cat-item" wx:for="{{newsCats}}" wx:for-item="cat" wx:key="id" hover-class="none">
                <image src="{{cat.icon}}" style="width:80rpx;height:80rpx;margin-bottom:10rpx" />
                <text class="">{{cat.name}}</text>
            </navigator>
        </scroll-view>
        <ud-card title='热门推荐' sub-title='查看更多'>
            <scroll-news items="{{topNewsItems}}" />
        </ud-card>
        <ud-card title='楼盘资讯'>
            <news-item wx:for="{{newsItems}}" item="{{item}}"></news-item>
        </ud-card>
    </view>
</view>
<view hidden="{{tabIndex != 1}}">
    <view class="res qa-list">
        <view style="margin-top:20rpx;">
            <qa-item wx:for="{{qaItems}}" item="{{item}}"></qa-item>
        </view>
    </view>
    <navigator url="/pkgQa/pages/qa/new" class="qa-new">我要提问</navigator>
</view>
<view hidden="{{tabIndex != 2}}">
    <view class="res tour-list">
        <tour-item wx:for="{{tourItems}}" item="{{item}}"></tour-item>
    </view>
</view>
<no-result wx:if="{{isEmpty}}" />