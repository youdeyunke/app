<view class="mytabs">
    <van-tabs sticky="{{true}}" active="{{tab}}" color="#1989fa" bind:change="tabChangeHandle">
        <van-tab wx:for-key="id" name="{{tab.id}}" title="{{tab.name}}" wx:for-item="tab" wx:for="{{tabs}}"></van-tab>
    </van-tabs>
</view>
<view hidden="{{ tab != 'news'}}">
    <hot-news limit="5"></hot-news>
    <view class="res news-list">
        <news-cats bind:change="newsCatChange"></news-cats>
        <search-bar bind:change="newsKwChange"></search-bar>
        <view style="height:20rpx;display:block;"></view>
        <news-item wx:for="{{newsItems}}" item="{{item}}"></news-item>
    </view>
</view>
<view hidden="{{tab != 'qa'}}">
    <view class="res qa-list">
        <search-bar bind:change="qaKwChange"></search-bar>
        <qa-item wx:for="{{qaItems}}" item="{{item}}"></qa-item>
    </view>
    <navigator url="/pkgQa/pages/qa/new" class="qa-new">我要提问</navigator>
</view>
<view hidden="{{tab != 'tour'}}">
    <view class="res tour-list">
        <tour-item wx:for="{{tourItems}}" item="{{item}}"></tour-item>
    </view>
</view>
<no-result wx:if="{{isEmpty}}" />