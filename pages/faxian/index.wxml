<view class="top-box">
    <view style="width:100%">
        <ud-tabs data='{{tabs}}' model:active-index='{{tabIndex}}' bind:change='tabChangeHandle' mytabs="newtabs"
            ></ud-tabs>
    </view>
    <search-bar bind:change="kwChange" kw="{{value}}" />
</view>

<block wx:if="{{tabIndex==0}}">
    <news kw="{{kw}}" page="{{page}}"></news>
</block>
<block wx:if="{{tabIndex==1}}">
    <qa kw="{{kw}}" page="{{page}}"></qa>
</block>
<block wx:if="{{tabIndex==2}}">
    <hd kw="{{kw}}" page="{{page}}"></hd>
</block>
<no-result wx:if="{{isEmpty}}" />

<copyright></copyright>