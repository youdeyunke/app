/* pages/faxian/news/index.wxss */

.box{
  background-color: #F2F2F2;
}
.news-cats-scroll {
  width: 750rpx;
  white-space: nowrap;
  margin: 0;
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx 0rpx;
}
.news-cat-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #333333;
  font-size: 24rpx;
  display: inline-flex;
  font-weight: bold;
}
.card{
  position: relative;
  color: #666666;
}
.jiantou{
  width: 14rpx;
  height: 24rpx;
  position: absolute;
  top: 16px;
  right: 7px;
}