/* pages/faxian/scroll-news/index.wxss */
.scroll-cell{
    width: 500rpx;
    height: 312rpx;
    color: #333;
    font-size: 24rpx;
    display: inline-flex;
    position: relative;
    margin-right:20rpx;
    z-index: 2;
}
.scroll{
    width: 100%;
    white-space: nowrap;
    border-radius:20rpx ;

}
.cell-image{
    width: 500rpx;
    height: 312rpx;
    z-index: -1;
    border-radius: 20rpx;
}
.position-image,.image-box{
    width:100rpx ;
    height: 100rpx;
}
.image-box{
    position: absolute;
    top: 116rpx;
    left: 200rpx;
}
.cell-tag{
    border-radius: 0rpx 10rpx 10rpx 0rpx;
    background: #1989FA;
    width: 110rpx;
    height: 40rpx;
    color: #fff;
    font-size: 24rpx;
    position: absolute;
    top: 29rpx; left: 0;
    text-align: center;
    line-height: 40rpx;
}
.footer-text{
    width: 100%;
    color: #fff;
    font-size: 28rpx;
    position: absolute;
    background:linear-gradient(0deg, rgba(0,0,0, 0.5), rgba(0,0,0, 0.1));
    height: 100rpx;
    box-sizing: border-box;
    padding:8rpx 15rpx;
    left:0; 
    bottom:0;
    border-bottom-left-radius: 20rpx;
    border-bottom-right-radius: 20rpx;
    display: flex;
    flex-direction: column;
}

.footer-text .title{
    overflow: hidden;
    text-overflow: ellipsis;
}

.footer-text .summary{
    font-size: 24rpx;
    overflow: hidden;
    text-overflow: ellipsis;
}