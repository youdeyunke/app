/* pages/faxian/index.wxss */

.mytabs {
    width: 100%;
    margin-bottom: 20rpx;
}

.res {
    width: 750rpx;
    box-sizing: border-box;
}

.news-list,
.tour-list {
    background: #fff;
}

.qa-list,
.tour-list {
    padding: 20rpx;
}

.tour-list {
    background-color: #f2f2f2;
}

.qa-new {
    height: 80rpx;
    line-height: 80rpx;
    background: #1989fa;
    color: #fff;
    border-radius: 80rpx;
    font-size: 28rpx;
    text-align: center;
    position: fixed;
    bottom: 20rpx;
    width: 200rpx;
    left: calc(50% - 100rpx);
    z-index: 10;
}

.news-cat-item {
    width: 20%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #333;
    font-size: 24rpx;
    display: inline-flex;
}

.news-cats-scroll {
    width: 750rpx;
    white-space: nowrap;
    margin: 0;
}

.newtabs {
    width: 100%;
    height: 124rpx;
    line-height: 124rpx;
    box-sizing: border-box;
    border-bottom: 1rpx solid #D3D3D3;
    white-space: nowrap;
    background-color: #fff;
    padding: 0 26rpx;
    z-index: -4;
}

.newborder {
    width: 48rpx;
    height: 8rpx;
    border-radius: 10rpx;
    background: #1989FA;
    position: absolute;
    top: 116rpx;
    left: 14rpx;
    z-index: 1;
}