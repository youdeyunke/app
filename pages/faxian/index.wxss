/* pages/faxian/index.wxss */

.mytabs {
    width: 100%;
    margin-bottom: 20rpx;
}

.res {
    width: 750rpx;
    box-sizing: border-box;
}

.newtabs {
    width: 100%;
    height: 124rpx;
    line-height: 124rpx;
    box-sizing: border-box;
    border-bottom: 1rpx solid #D3D3D3;
    white-space: nowrap;
    background-color: #fff;
    padding: 0 26rpx;
    z-index: -4;
}

.newborder {
    width: 48rpx;
    height: 8rpx;
    border-radius: 10rpx;
    background: #1989FA;
    position: absolute;
    top: 116rpx;
    left: 14rpx;
    z-index: 1;
}