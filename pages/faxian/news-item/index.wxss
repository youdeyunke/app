.item {
    width: 710rpx;
    height: 164rpx;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-sizing: border-box;
    position: relative;
    border-bottom: 1rpx solid #F0F0F0;
    margin-top: 20rpx;
    padding-bottom: 20rpx;
    padding-right: 20rpx;
}

.item .badge {
    width: 120rpx;
    height: 110rpx;
    position: absolute;
    top: -30rpx;
    left: -24rpx;
    z-index: 10;
}
.cover {
    width: 214rpx;
    height: 136rpx;
    border-radius: 0rpx;
    overflow: hidden;
    position: relative;
}
.cover image{
    width: 100%;
    height: 100%;
    border-radius: 10rpx;

}
.bofang{
    position: absolute;
    width: 50rpx !important;
    height: 50rpx  !important;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    margin: auto; 
}

.item .title {
    font-size: 26rpx;
    color: #333;
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    width: 448rpx;
    height: 68rpx;
}

.item .item-title-block {
    height: 100%;
    display: flex;
    width: 450rpx;
    flex-direction: column;
    justify-content: space-between;
    padding: 10rpx 20rpx 10rpx 0;
    box-sizing: border-box;
}

.item .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #666;
    font-size: 20rpx;
    width: 100%;

}

.item .date {
    font-size: 22rpx;
    color: #A0A0A0;
}

.item .author {
    font-size: 22rpx;
    color: #666666;
}
.video-box{
    width: 100%;
    border-bottom: 1rpx solid #F0F0F0;
    padding:30rpx 20rpx 30rpx 0rpx;
}
.video-title{
    font-size: 26rpx;
    color: #333333;
    width: 90%;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    margin-bottom: 14rpx;
}
.video-message{
    font-size: 24rpx;
    color:#A0A0A0 ;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
}
.video-message text:nth-of-type(1){
    color:#666666
}
.video-image,.video-image-box{
    width: 710rpx;
    height: 380rpx;
    border-radius: 10rpx;
}
.video-image-box{
    position: relative;
}
.video-position-image{
    position: absolute;
    top: 150rpx;
    left: 315rpx;
    width: 80rpx;
    height: 80rpx;
}