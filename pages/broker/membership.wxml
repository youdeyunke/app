
<mycard width="710" title="请选择套餐" hat="{{false}}" padding="20">
  <van-radio-group value="{{ radio }}" bind:change="onChange">
    <van-cell-group  border="{{false}}">
      <van-cell size="large" border="{{index < items.length-1}}" wx:key="{{item.id}}" wx:for="{{items}}" label="{{item.desc}}" bind:click="onClick" title="{{item.name}}" clickable data-index="{{index}}" >
        <van-radio checked-color="#07c160" name="{{item.id}}" />
      </van-cell>
    </van-cell-group>
  </van-radio-group>
</mycard>


<mycard width="710" wx:if="{{currentItem.id}}" title="{{currentItem.name}}" hat="{{false}}" padding="20">
 
  <van-cell icon="gold-coin-o" title="价格" value="{{currentItem.price}}" />
  <van-cell icon="clock-o" title="有效期" value="{{currentItem.months}} 个月" />  
  <van-cell icon="bar-chart-o" title="每天可发布房源数"  value="{{currentItem.per_day_limit}}套" />
  <van-cell icon="chart-trending-o" border="{{false}}" title="总共可发布房源数"  value="{{currentItem.total_limit}}套" />  
</mycard>

<van-submit-bar
  wx:if="{{currentItem.id}}"
  price="{{ currentItem.total_fee }}"
  disabled="{{!radio}}"
  button-text="立即支付"
  button-type="primary"
  loading="{{loading}}"
  tip="请在10分钟内完成支付，支付成功后，自动开通经纪人权限"
  bind:submit="requestPay"
/>
