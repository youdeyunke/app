page {
    height: 100% !important;
    width: 100%;
    padding: 0;
}

.auth {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    position: relative;
}

.header {
    padding-top: 300rpx;
    text-align: center;
}

.header .title {
    font-size: 60rpx;
    color: #fff;
}

.header .subtitle {
    font-size: 28rpx;
    color: #fff;
    margin-top: 10rpx;
}

.body {
    padding-top: 300rpx;
    width: 590rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    color: #fff;
}

.body .tips {
    color: #fff;
    font-size: 24rpx;
    margin-top: 10rpx;
}

.footer {
    display: flex;
    justify-content: center;
    align-items: center;
    color: #f4f4f4;
    font-size: 24prx;
    padding-bottom: 60rpx;
}

.auth .mask {
    width: 100%;
    height: 100%;
    position: absolute;
    z-index: -1;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.1);
}

.auth .bg {
    width: 100%;
    height: 100%;
    position: absolute;
    z-index: -10;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    filter: blur(2px);
}