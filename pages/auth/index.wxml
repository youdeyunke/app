<view class="auth" wx:if="{{!userInfo}}">
    <view class="header">
        <view class="title">登陆账号</view>
        <view class="subtitle">可体验更多服务</view>
    </view>
    <view class="body">
        <van-button style="width:100%;" block wx:if="{{loginMethod == 'v2'}}" loading="{{loading}}" disabled="{{loading}}" type="info" open-type='getPhoneNumber' bindgetphonenumber='loginHandle'>
            {{ loading == true ? '正在登录...'  : '手机号授权登录'}}
        </van-button>
        <button wx:else loading="{{loading}}" disabled="{{loading}}" type="primary" class="btn" open-type='getUserInfo' bindgetuserinfo='loginHandle'>
            {{ loading == true ? '正在登录...'  : '微信授权登录' }}
        </button>
        <navigator url="/pages/home/home" open-type="switchTab" class="tips">不登录，先逛逛</navigator>
    </view>
    <navigator class="footer" url="/pages/static/terms" hover-class="none">
        <view class="terms">《用户协议》</view>
    </navigator>
    <image class="bg" src="/assets/images/login-bg.png" />
    <view class="mask"></view>
</view>