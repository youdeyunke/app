
.post-cover{
  width:750rpx;
  height: 420rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 0rpx 0;
  padding:0rpx;
  position:relative;
}


.post-cover swiper{
  width:100%;
  height:100%;
}

.post-cover swiper-item{
  display: flex;
  justify-content: center;
  align-items: center;
  background: #000;
}

.post-cover image.item{
  height:100%;
  width: 100%;
  margin:0 auto;
}


.name{
  font-size:var(--font-l);
  padding:0 20rpx;
  color: #333;
}
.address{
  padding:0 20rpx;
  margin-top:20rpx;
  color: #333;
  font-size: var(--font-s)
}

 .typeinfo{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20rpx 0;
  margin:30rpx 0 0 0;
  box-sizing:border-box;
  width:100%;
  border-top:1px solid #f1f1f1;
}

 .typeinfo .item{
  width:33.333%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
}


 .typeinfo .item .value{
  font-size:var(--font-l);
  color:var(--color-b);
  margin-bottom:10rpx;
}
.typeinfo .item .value .px{
  font-size:20rpx;
  color: #666;
}

 .typeinfo .item .key{
  font-size:var(--font-s);
}

 .typeinfo .item.border{
  border-right:1px solid #f1f1f1;
}
