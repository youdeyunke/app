
.post-cover{
  width:750rpx;
  height: 420rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 0rpx 0;
  padding:0rpx;
  position:relative;
}


.post-cover text.none:after{
  content: "照片拍摄中";
  position:absolute;
  display:flex;
  justify-content:center;
  align-items:center;
  width:750rpx;
  height:420rpx;
  left:0rpx;
  right:0rpx;
  top:0rpx;
  font-size:60rpx;
  color:#fff;
  font-weight:bolder;
  background:#f4f4f4;
  z-index:1000;
}


.post-cover swiper{
  width:100%;
  height:100%;
}

.post-cover swiper-item{
  display: flex;
  justify-content: center;
  align-items: center;
  background: #000;
}

.post-cover image.item{
  height:100%;
  width: 100%;
  margin:0 auto;
}


.name{
  font-size:32rpx;
  color: #333;
  font-weight: bolder;
  line-height: 1.4;
}

.address{
  margin-top:20rpx;
  color: #333;
  font-size: 28rpx;
  line-height: 1.4;

}

 .typeinfo{
  border-top:1px solid #f1f1f1;
  margin-top:20rpx;
  padding-top:20rpx;
}
