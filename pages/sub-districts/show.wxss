
.post-cover{
  width:750rpx;
  height: 420rpx;
  border-radius: 0rpx;
  overflow: hidden;
  margin:0 0 0rpx 0;
  padding:0rpx;
  position:relative;
}


.post-cover swiper{
  width:100%;
  height:100%;
}

.post-cover swiper-item{
  display: flex;
  justify-content: center;
  align-items: center;
  background: #000;
}

.post-cover image.item{
  height:100%;
  width: 100%;
  margin:0 auto;
}


.name{
  font-size:var(--font-l);
  padding:0 20rpx;
  color: #333;
}
.address{
  padding:0 20rpx;
  margin-top:20rpx;
  color: #333;
  font-size: var(--font-s)
}

 .typeinfo{
  border-top:1px solid #f1f1f1;
  margin-top:20rpx;
  padding-top:20rpx;
}
