
.shadow{
    box-shadow: 2px 2px 6px #cecece;
}

.loading{
  background: #fff;
  width:200rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: fixed;
  top:50rpx;
  left:calc(50% - 100rpx);
  border-radius: 60rpx;
  opacity: 0.78;

}


.groups{
  height:80rpx;
  display:flex;
  justify-content:space-between;
  background:#fff;
  border-radius:80rpx;
  width:480rpx;
  box-sizing:border-box;
  padding:10rpx;
  position:fixed;
  top:50rpx;
  left:calc(50% - 240rpx);
}

.group-item{
  width:33.33%;
  height:60rpx;
  color:#333;
  border-radius:60rpx;
  display:flex;
  justify-content:center;
  line-height:60rpx;
  text-align:center;
  align-items:center;
}

.group-item.active{
  background:#00ae66;
  color: #fff;
}


.dingwei{
  width: 80rpx;
  height: 80rpx;
  border-radius: 80rpx;
  position: fixed;
  bottom:50rpx;
  right:40rpx;
  background: #fff;
}

.center-point{
  width: 50rpx;
  height: 50rpx;
  position: fixed;
  left:calc(50% - 25rpx);
  bottom:calc(50% - 25rpx);
}

.map-view{
    transition: height .25s;
}


.result-view{
  background: #fff;
  width:100%;
  height:550rpx;
  padding:20rpx 20rpx 10rpx 10rpx;
  box-sizing:border-box;
}


.result-view .body{
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
}

.result-view .header{
  padding:0 20rpx;
  height:80rpx;
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-size:28rpx;
  font-weight: bolder;
  letter-spacing: 1.2px;

}

.result-view .items{
  display:flex;
  justify-content:flex-start;
}


