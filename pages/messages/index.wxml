<block wx:if="{{userInfo.id}}">
<ud-box padding="30" >
  <navigator wx:key="{{item.id}}" hover-class='none' open-type='navigate' url="/pages/messages/show?target_user_id={{item.sender_id}}" wx:for="{{items}}" class="item">
  <view class="tip" wx:if="{{item.unread == true}}"> </view>
  <image class="avatar" src="{{item.sender_info.avatar}}"></image>
  <view class="info">
    <view class="name">
      <text class="nickname">{{item.sender_info.name}}</text>
      <howlong wx:if="{{item}}" date="{{item.updated_at}}" />
    </view>
    <view class="line-limit">{{item.last_content}}</view>
  </view>
  </navigator>
</ud-box>
<view wx:if="{{items.length == 0}}" class="empty">没有收到任何消息</view>

</block>

  <login-window bind:success="loginSuccess" class="loginwindow"></login-window>
