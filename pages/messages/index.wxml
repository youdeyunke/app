<view wx:if="{{showDingyue}}" class="message-top" bindtap="dingyueHandle">
  <text style="color: #333333;">订阅消息推送，第一时间回复通知</text>
  <view style="background-color: {{primaryColor || '#F49946'}};">
    <text style="color: #ffffff;background-color: {{primaryColor}};">订阅</text>
  </view>
</view>
<view style="display: flex;justify-content: space-between;flex-direction: column;min-height: calc(100vh - 100rpx);">
  <van-tabs active="{{ active }}" bind:click="onChange" color="{{primaryColor}}">
  <van-tab info="{{chat_message_count == 0 ?  null : chat_message_count}}" title="聊天">
    <block wx:if="{{userInfo.id}}">
  <view class="tools">
    <view class=""></view>
    <view wx:if="{{chat_message_count > 0}}" bindtap="readAll" class="read-all">全部已读</view>
  </view>

  <view bindtap="dingyue" class="outer" padding="30">
    <navigator data-index="{{index}}" bindlongpress="deleteHandle" wx:key="{{item.id}}" hover-class='none' open-type='navigate'
      url="/pages/messages/show?target_user_id={{item.sender_info.user_id}}" wx:for="{{items}}" class="item">
      <!-- view class="tip" wx:if="{{item.unread == true}}"> </view -->
      <image mode="aspectFill" class="avatar" src="{{item.sender_info.avatar}}?imageView2/5/w/200/h/200"></image>
      <view class="info">
        <view class="name">
          <text class="nickname">{{item.sender_info.name}}</text>
          <text class="date">{{item.time}}</text>
        </view>
        <view class="line-limit">{{item.last_content}}</view>
      </view>
      <view wx:if="{{item.unread > 0}}" class="count">{{item.unread}}</view>
    </navigator>
  </view>
  <view wx:if="{{items.length == 0}}" class="empty">没有收到任何消息</view>
  <van-divider wx:else  contentPosition="center">没有更多了</van-divider>

</block>
  </van-tab>

  <van-tab info="{{sys_message_count == 0 ? null : sys_message_count }}" title="系统消息">
    <view class="tools">
      <view class=""></view>
      <view wx:if="{{sys_message_count > 0}}" bindtap="readAllSys" class="read-all">全部已读</view>
    </view>

    <view class="outer" padding="30">
      <view bindtap="sysItemClickHandle" data-index="{{index}}" wx:for="{{systemItems}}">
        <view class="xtxxbox">
          <view style="display: flex;flex-direction: column;justify-content: space-between;width: 700rpx;">
            <view style="display: flex;justify-content: space-between;align-items: center">
              <view style="font-weight: bold;font-size: 32rpx;">
                {{item.title}}
              </view>
              <view class="biaoqian" wx:if="{{item.unread==true}}">未读</view>
            </view>
            <view style="color: #333333;font-size: 32rpx;word-wrap: break-word;">
              {{item.content}}
            </view>
            <view style="color: #666666;font-size: 26rpx;">
              {{item.updated_at}}
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{systemItems.length == 0}}" class="empty">没有收到任何消息</view>
    <van-divider wx:else contentPosition="center">没有更多了</van-divider>
  </van-tab>

</van-tabs>



<copyright></copyright>
</view>


<login-window bind:success="loginSuccess" class="loginwindow"></login-window>