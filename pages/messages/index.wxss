page{
  background: #fff !important;
  height: 100vh;
}

.item{
  display: flex;
  justify-content: space-between;
  align-items:  center;
  height: 160rpx;
  border-bottom: 1rpx solid #E1E1E1;
  position: relative;
}

.item .tip::after{
  content: ' ';
  height: 12rpx;
  width: 12rpx;
  display: flex;
  border-radius: 8rpx;
  background: red;
  position: absolute;
  left: 92rpx;
  top: 30rpx;
}

.item .avatar{
  height:100rpx;
  width: 100rpx;
  border-radius: 50%;
  margin-right:35rpx ;
}

.item .info{
  height: 100rpx;
  width: calc(750rpx - 60rpx - 92rpx - 20rpx);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.line-limit{
  width: 427rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #777777;
  font-size: 24rpx;
}

.item .name{
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item  .nickname{
  color: #000;
  font-size: 36rpx;
}

.item .info .text{
  color: #cecece;
}



.empty{
  height:100%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
}


.unlogin .title{
  font-size:30rpx;
}
.unlogin .desc{
  font-size:28rpx;
  margin-top:20rpx;
  margin-bottom:40rpx;
}


