/* components/message/namecard.wxss */

.card {
    border-radius: 8rpx;
    padding: 22rpx 18rpx;
    max-width: 400rpx;
    color: #333;
    display: flex;
    flex-direction: column;
    background: #fff;
    font-size: 24rpx;
}

.card .body {}

.card .line {
    height: 2rpx;
    border-top: 1px solid #f4f4f4;
    margin: 20rpx 0;
}

.card .footer {
    color: #1989fa;
    text-align: center;
    margin-bottom: 10rpx;
}