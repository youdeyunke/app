.input-wrapper {
    height: 100rpx;
    background: #fff;
    width: 750rpx;
    box-sizing: border-box;
    padding: 0 rpx;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    z-index: 50;
}

.input-wrapper input {
    border-bottom: 1rpx solid #f4f4f4;
    width: 550rpx;
    height: 100rpx;
}

.btn-sent {
    font-size: 24rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 20rpx;
    height: 60rpx;
    width: 100rpx;
    border-radius: 10rpx;
}

.btn-sent.default {
    background: #1989fa;
    color: #fff;
}

.btn-sent.pending {
    background: #fff;
    color: #cecece;
    border: 1rpx solid #cecece;
}

.input-wrapper .icon {
    height: 100rpx;
    width: 100rpx;
    padding: 20rpx;
    box-sizing: border-box;
}

.input-wrapper .icon image {
    width: 100%;
    height: 100%;
}

.outer {
    z-index:99;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    flex-direction: column;
    position: fixed;
    bottom: 0rpx;
    left: 0rpx;
    right: 0rpx;
}

.tool-box.open {
    border-top: 1px solid #cecece;
    background: #ebebeb;
    padding: 20rpx;
    width: 710rpx;
    height: 216rpx;
    padding: 20rpx 0;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    transition: height 0.5s;
}

.tool-box.close {
    height: 0;
    overflow: hidden;
    opacity: 0;
    padding: 0;
    margin: 0;
}

.tool-box .tool-item {
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: center;
    width: 175rpx;
    height: 175rpx;
}

.tool-box .tool-item .name {
    color: #333;
    font-size: 22rpx;
    margin-top: 20rpx;
}

.tool-box .tool-item .icon-wrapper {
    background: #fff;
    border-radius: 10rpx;
    width: 100rpx;
    height: 100rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.tool-box .tool-item .icon-wrapper image {
    width: 60rpx;
    height: 60rpx;
}

.audio-res {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.audio-res .btn-sent {
    width: 480rpx;
    margin-right: 20rpx;
}

.audio-record-btn {
    height: 60rpx;
    width: 500rpx;
    background: #ffffff;
    border-radius: 10rpx;
    text-align: center;
    font-size: 24rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.cyy {
    position: fixed;
    left: 20rpx;
    bottom: 120rpx;
    display: flex;
    justify-content: center;
    color: #1989fa;
    font-size: 20rpx;
    width: 100rpx;
    height: 40rpx;
    align-items: center;
    border-radius: 60rpx;
    border: 1rpx solid #cecece;
    padding: 0 15rpx;
}

.cyy image {
    width: 25rpx;
    height: 25rpx;
    vertical-align: middle;
    margin-right: 8rpx;
}