<!--pages/poster/index.wxml-->
<image style="width:750rpx;height:1060rpx;" bindtap='onSavePoster' src="{{posterUrl}}" ></image>
<poster wx:if="{{posterConfig}}" id="poster" config="{{posterConfig}}" bind:success="onPosterSuccess" bind:fail="onPosterFail"></poster> 

<view class="tips" bindtap="showTips">
 <van-icon name="question-o" />
 <text>  房源海报有什么用途？</text>
</view>

<view class="bar">
  <view class="left" bindtap="editHandle" style="display:flex;justify-content:flex-start;">
    <van-icon name="edit" /> 修改海报
  </view>
  <view class="right">
    <van-button bindtap="onSavePoster" type="primary"  round>下载打印海报</van-button>
  </view>
</view>
