<block wx:if="{{userInfo}}">

  <view class="card-wrapper">
    <image src="{{userInfo.avatar}}" class="card-wrapper-bg" />
    <view class="card"><namecard user-info="{{userInfo}}" /> </view>

  </view>



  <view class="body">
    <van-tabs animated swipeable  type="line" color="#00ae66" bind:change="tabChange">
      <van-tab wx:for="{{tabs}}" wx:for-item="tab" title="{{tab.label}}">
        <view style="height:30rpx;" class="blank"></view>
        <box padding="0" width="700">
          <items kw="" wx:if="{{filter}}" page="{{page}}" filter="{{filter}}" />
        </box>
      </van-tab>
    </van-tabs>  


  </view>
</block>


<view class="fixed-footer btns">
  <button bindtap="callMe" class="btn btn-call" open-type="">电话咨询</button>
  <button open-type="share" class="btn btn-share" >分享名片</button>
</view>
