<view class="empty" wx:if="{{!loading && items[0].length == 0 }}" style="text-align:center;color:#cecece;margin-top:100rpx;">没有访问记录</view>
<box padding="20" wx:else>   
  <block wx:for="{{items}}" wx:for-item="visitors">

    <van-cell title="{{ item.target_info.title }}" wx:for="{{visitors}}"  wx:for-key="item.id"  size="large" hover-class="none" 
    label="{{item.user.mobile || '未知手机号' }} / {{ item.updated_at }}  / 第{{ item.view_count}}次 "   >
        <image style="width:80rpx;height:80rpx;border-radius:80rpx;" slot="right-icon" src="{{item.user.avatar}}" />
    </van-cell>


  </block>
  <view style="display:flex;justify-content:center;align-items:center;">
    <van-loading wx:if="{{loading}}" />
  </view>
</box>
