page{
 
}

.box{
  background: #fff;
  border-radius: 10rpx;
  width:689rpx;
  margin:0  auto 45rpx auto;
  position: relative;

}

.box.q .box-header{
  display: flex;
  flex-wrap: nowrap;
  justify-content: flex-start;
  align-items: flex-start;
  padding-top:17rpx;
  padding-right:30rpx;
  margin-bottom:30rpx;

}

.box.q .box-header .icon{
  width:49rpx;
  height:32rpx;
  background-color:#ffdb2d;
  border-top-right-radius:30rpx;
  border-bottom-right-radius:30rpx;
  text-align:center;
  font-size:22rpx;
  color:#000; 
}

.box.q .box-header .content{
  font-size:26rpx;
  color:#333;
  padding-left:17rpx;
  padding-bottom:17rpx;
}

.box.q .box-body{
  display: flex;
  justify-content: space-between;
    padding-left:60rpx;
    padding-right:30rpx;
    margin-bottom:15rpx;
}

.box.q .box-body .author{
  font-size:20rpx;
  color: #000;


}

.box.q .box-body .time{
  font-size:20rpx;
  color: #666;
}



.box-footer{
  width:689rpx;
  height: 35rpx;
  position: absolute;
  bottom:-34rpx;
}

.box.a{
  margin-top:15rpx;
}

.box.a .box-header {
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  padding-top:20rpx;
  padding-right:30rpx;
}

.box.a .box-header .icon{
  width:49rpx;
  height:32rpx;
  background-color:#ffdb2d;
  border-top-right-radius:30rpx;
  border-bottom-right-radius:30rpx;
  text-align:center;
  font-size:22rpx;
  color:#000; 
}

.box.a .box-header .author{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width:100%;
  height:42rpx;
  padding-bottom:24rpx;
  padding-left:17rpx; 
}

.box.a .box-header .author .name{
  display: flex;
  justify-content: flex-start;
  height:42rpx;
  align-items:center;

}

.box.a .box-header .author .nickname{
  font-size:22rpx;
  color:#000;
  padding-left:10rpx;

}

.box.a .box-header .author image{
  width:42rpx;
  height: 42rpx;
  border-radius: 42rpx;
}
.box.a .box-header .author .instr{
    font-size:22rpx;
    color:#666;
    padding-left:10rpx;
}

.box.a .box-header .author .btn-add-q{

  background:#ffdb2d;
  color:#000;
  width:164rpx;
  height:44rpx;
  line-height:44rpx;
  font-size:26rpx;
  text-align:center;
  border-radius: 10rpx;

}

.box.a .box-body{
  padding:0 40rpx 25rpx 60rpx;
}

.box.a .box-body .about{
  display: flex;
  justify-content: flex-start;
}

.box.a .box-body .about .item{
  display: flex;
  width: 180rpx;
}

.box.a .box-body .about .label{
  font-size:20rpx;
  color:#666;
}
.box.a .box-body .about .value{
  color:#ff0505;
  font-size:20rpx;
  margin-left:10rpx;
}
.box.a .box-body .answer{
  font-size:26rpx;
  color:#666;
  margin:30rpx 0 50rpx 0;
}

.box.a .box-body .answer text{
}

.box.a .box-body .info{
  display: flex;
  justify-content: space-between;
}

.box.a .box-body .info .time{
  font-size:20rpx;
  color: #666;
}

.box.a .box-body .info .like{
  font-size:20rpx;
  color:#666;
  display:flex;
  align-items:center;

}

.box.a .box-body .info .like image{
    width:36rpx;
    height:36rpx;
    margin-right:15rpx;
}

.blank-block{
  height: 72rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding:0 30rpx;
  background: #fff;
  margin:18rpx 0 24rpx;
}

.blank-block .name{
  font-size:26rpx;
  color: #333;
}
.blank-block .more{
  font-size:22rpx;
  color:#afafaf;
}

.more-qas .box{
  margin-bottom:24rpx;
}
.more-qas .box .box-header{
  min-height: 99rpx;
}
