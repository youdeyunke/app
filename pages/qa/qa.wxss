page{
  padding-top:0rpx !important;
}

.box{
    padding:30rpx;
    width:690rpx;
    background: #fff;
    margin-bottom:20rpx;
}

.float-btn{
    width: 100%;
    padding:30rpx;
    position: fixed;
    left:0rpx;
    bottom:0rpx;
    right: 0rpx;
    background: #fff;
    border-top:1px solid #f4f4f4;
    box-sizing: border-box;
    z-index:999;
}

.answer-form{
    width:690rpx;
}

.answer-form .header{
    display: flex;
    width:100%;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    box-sizing: border-box;
    border-bottom: 2rpx solid #f4f4f4;
    margin-bottom:30rpx;
    font-size:28rpx;
}

.answer-form .content{
    font-size: 28rpx;
    width:100%;
    padding:0rpx 30rpx;
    box-sizing: border-box;
}

.answer-form .header .cancle{
    color: #999;
}

.answer-form .header .submit{
    color: #1989FA;
}

.question{
    margin-bottom:30rpx;
    padding-bottom:30rpx;
    border-bottom:2rpx solid #f4f4f4;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
}

.question .icon{
    background: #ff4444;
    color: #fff;
    font-weight: bolder;
    font-size:20rpx;
    width:32rpx;
    height: 32rpx;
    line-height: 32rpx;
    text-align: center;
    margin-right:30rpx;
}

.question .content .target{
    color:#1989FA;
    margin-right:5rpx;
}

.question .body{
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
}

.question .content {
    font-size:28rpx;
    color:#000000;
    line-height:1.4;
    letter-spacing: 2.2rpx;
    border-radius: 8rpx;
    margin-bottom:20rpx;
}

.question .actions{
  width:100%;
  display:flex;
  justify-content:space-between;
  font-size: 24rpx;
}

.question .count{
  color: #999999;
}

.question .add{
  color:#1989fa;
}

.answer{
    border-bottom:2rpx solid #f4f4f4;
    margin-bottom:30rpx;
    padding-bottom:30rpx;
}

.answer .meta{
    display: flex;
    justify-content:space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.answer .avatar, .answer .name, .answer .tag{
    margin-right:20rpx;
}

.answer .meta .left{
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-size:24rpx;
}

.answer .avatar image{
    width: 60rpx;
    height: 60rpx;
    border-radius: 60rpx;
    border:1rpx solid #f4f4f4;
}

.answer .content{
  letter-spacing: 2.2rpx;
  width:690rpx;
  font-size:28rpx;
  line-height:1.4;
  word-break: break-all;
  padding:0rpx;
  border-radius: 8rpx;
  margin-bottom:20rpx;
}

.answer .actions{
  display:flex;
  justify-content:flex-end;
}


.answer .action-item{
  width:60rpx;
  height:60rpx;
  border-radius:60rpx;
  display:flex;
  justify-content:center;
  align-items:center;
}

.answer .footer{
    display: flex;
    justify-content: flex-end;
    align-items: center;
}