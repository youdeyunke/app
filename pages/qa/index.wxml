
<import src="/tpls/qa.wxml"/>

  <view class="cats" >
    <text data-cid="{{item.id}}" bindtap="catHandle" class="item {{  catId == item.id ? 'active' : '' }}" wx:for="{{cats}}" id="item-{{index}}">{{item.name}}</text>
  </view>

  <form report-submit class="qa-items" bindsubmit='gotoNew'>
      <template is="qa-item" data="{{item}}" wx:for="{{items}}"></template>
  </form>






