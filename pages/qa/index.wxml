  <view class="cats" >
    <text data-cid="{{item.id}}" bindtap="catHandle" class="item {{  catId == item.id ? 'active' : '' }}" wx:for="{{cats}}" id="item-{{index}}">{{item.name}}</text>
  </view>

<box padding="30" margin-bottom="0" wx:for="{{items}}" >
    <qa wx:if="{{item}}"  item="{{item}}"></qa>
</box>

<view  class="weui-loadmore" wx:if="{{hasMore}}">
  <i class="weui-loading"></i>
  <text class="weui-loadmore__tips">正在加载</text>
</view>

<view  class="weui-loadmore weui-loadmore_line" wx:if="{{!hasMore}}">
    	<text class="weui-loadmore__tips weui-loadmore__tips_in-line">END</text>
</view>

<view class="fixed-footer add-new">
  <view>在这里，问关于房子的一切问题</view>
  <button bindtap="gotoNew" class="btn primary mini">去提问</button>
</view>
