/* pages/qa/qa.wxss */


.qa-item{
  background: #fff;
  padding:20rpx;
  border-radius: 0px;
  position: relative;
}

.qa-item .body{
  position: relative;
  margin-top:10rpx;
  padding:10rpx;
}


.qa-item  .author{
  font-size:28rpx;
  color:#666;
  margin-top:10rpx;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.qa-item .author .name{
  display:flex;
  justify-content:flex-start;
  align-items:center;
}

.qa-item .author image{
  width:45rpx;
  height: 45rpx;
  border:2rpx solid #f4f4f4;
  border-radius: 100%;
  margin-right:10rpx;
}

.qa-item  .icon{
  padding:0 20rpx;
  height: 40rpx;
  display:flex;
  justify-content:center;
  align-items:center;
  text-align: center;
  font-size:24rpx;
  color:var(--color-green);
  border:1px solid var(--color-green);

}


.qa-item .line{
      border-top:4rpx dashed #f4f4f4;
}

.qa-item .body .content{
    padding:15rpx 0;
    color:#666;
    display: flex;
    flex-direction: column; 
}

.qa-item .answer-text{
  color:#000;
}
