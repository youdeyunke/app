/* pages/qa/qa.wxss */

.qa-items{
  display: flex;
  flex-direction: column;
  padding:120rpx 20rpx 15rpx 20rpx;   
}

.qa-items .qa-item{
  background: #fff;
  padding:20rpx;
  border-radius: 0px;
   margin-bottom:calc(38rpx + 18rpx);
   position: relative;
}

.qa-items .qa-item .body{
  position: relative;
  margin-top:10rpx;
  padding:10rpx;
}


.qa-items .qa-item  .author{
  font-size:28rpx;
  color:#666;
  margin-top:10rpx;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.qa-items .qa-item .author .name{
  display:flex;
  justify-content:flex-start;
  align-items:center;
}

.qa-item .author image{
  width:35rpx;
  height: 35rpx;
  widows: 35rpx;
  border-radius: 100%;
  margin-right:10rpx;
}

.qa-items .qa-item  .icon{
  padding:0 20rpx;
  height: 40rpx;
  display:flex;
  justify-content:center;
  align-items:center;
  text-align: center;
  font-size:24rpx;
  color:var(--color-green);
  border:1px solid var(--color-green);

}


.qa-items .qa-item .line{
      border-top:4rpx dashed #f4f4f4;
}

.qa-items .qa-item .body .content{
    padding:15rpx 0;
    color:#666;
    display: flex;
    flex-direction: column; 
}

.qa-items .qa-item .body .content text{

  display: -webkit-box ;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp:3; 
 }



