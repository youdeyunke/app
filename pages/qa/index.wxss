/* pages/qa/qa.wxss */

@import './base.wxss';

.qa-items{
  display: flex;
  flex-direction: column;
  padding:120rpx 20rpx 15rpx 20rpx;   
}



.qa-item .body .content text{

  display: -webkit-box ;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp:3; 
 }



