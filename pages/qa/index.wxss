/* pages/qa/qa.wxss */


page{padding-top:0rpx !important; 
}

.add{
    padding:20rpx 30rpx;
    box-sizing: border-box;
    background: none;
    width: 100%;
    position: fixed;
    bottom: 0rpx;
    left: 0rpx;
    right: 0rpx;
}

.items{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
}

.items .item{
    margin-bottom: 40rpx;
    width:100%;
}

.question{
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
}

.question .icon{
    background: #ff4444;
    color: #fff;
    font-weight: bolder;
    font-size:20rpx;
    width:32rpx;
    height: 32rpx;
    line-height: 32rpx;
    text-align: center;
    margin-top:4rpx;
    margin-right:30rpx;
}

.question .content .target{
    color:#1989FA;
    margin-right:5rpx;
}

.question .body{
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
}

.question .content {
    font-size:32rpx;
    color:#000000;
    line-height:1.4;
    letter-spacing: 2.2rpx;
    border-radius: 8rpx;
    margin-bottom:4rpx;
}

.question .count{
    font-size:24rpx;
    color: #999;
}


.answer{
  width:100%;
  box-sizing: border-box;
  padding:20rpx;
  background: #f9f9f9;
  margin-top:20rpx;
  margin-bottom:20rpx;
  border-radius: 8rpx;
}

.answer .header{
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-size:24rpx;
}

.answer .header .avatar image{
    width: 60rpx;
    height: 60rpx;
    border-radius: 60rpx;
    border:1rpx solid #f4f4f4;
    margin-right: 20rpx;
}

.answer .header .name{}

.answer .content{
  letter-spacing: 2.2rpx;
  width:100%;
  font-size:32rpx;
  line-height:1.4;
  word-break: break-all;
  padding:0rpx;
  border-radius: 8rpx;
  margin-bottom:0rpx;

}

.answer .footer{
  display:flex;
  justify-content:flex-end;
}
