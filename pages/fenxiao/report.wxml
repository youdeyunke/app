
<form bindsubmit="submit">
    <mycard width="750" title="客户信息"   hat="{{false}}">
        <van-field    size="large"  name="name" v input-align="left" 
            placeholder="客户姓名" bind:change="inputChange" />

        <van-field size="large"  name="mobile" v input-align="left" 
            placeholder="客户手机号" bind:change="inputChange" />

        <van-field border="{{false}}"   size="large"  name="mobile_confirm" v input-align="left" border="{{false}}"
            placeholder="再次输入手机号" bind:change="inputChange" />
    </mycard>

    <mycard width="750" title="客户意向房源"   hat="{{false}}">
        <van-field size="large"  name="post_name" v input-align="left" border="{{false}}"
            placeholder="请填写客户的意向房源" bind:change="inputChange" autosize />
    </mycard>    

    <view class="actions">
      <button  data-name="step1" form-type="submit" type="primary" class="btn ">提交报备</button>
    </view>
</form>


<flow-tips steps="{{setpsText}}" />
