  <block wx:for="{{items}}" wx:for-item="balances">
    <van-cell wx:for="{{balances}}"  wx:for-key="item.id" label="" label="{{ item.created_at_pretty  }}"   size="large" hover-class="none" title="{{item.name}}"  value="￥{{item.amount}}" />
  </block>
  <van-loading wx:if="{{loading}}" />
</box>
