<view class="empty" wx:if="{{!loading && items[0].length == 0 }}" style="text-align:center;color:#cecece;margin-top:100rpx;">没有记录</view>
<box padding="20" wx:else>  
  <block wx:for="{{items}}" wx:for-item="customers">
    <van-cell wx:for="{{customers}}"  wx:for-key="item.id" label="{{ item.user_remark  }}"   size="large" hover-class="none" title="{{item.name}}"  value="{{item.mobile}}" />
  </block>
  <view style="display:flex;justify-content:center;align-items:center;">
    <van-loading wx:if="{{loading}}" />
  </view>
</box>

