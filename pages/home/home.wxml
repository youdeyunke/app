<view class="container">
<view class="top-bar">
  <picker bindchange="cityChangeHandle" value="0" mode="selector" range="{{cityList}}">
    {{cityList[selectedCity]}} <image src="/assets/icons/home-arrow.png" ></image>
  </picker>

  <view class="search-bar">
    <image class="btn" src="/assets/icons/search.png" ></image>
    <input placeholder='买房 租房 评测' />
  </view>
</view>


<myslider></myslider>
<view class="tab-icons">
  
  <navigator hover-class="none"  wx:for-index="index" url="{{item.url}}" wx:for="{{tabIcons}}">
    <image src="/assets/icons/{{index}}.png"></image>
    <text>{{ item.name }}</text>
  </navigator>
</view>

<view class="posts">
        <navigator hover-class="none" wx:for="{{posts}}" hover-class="none" url="/pages/post/post?id={{item.id}}" class="item">
    <view class="header">
            <image class="cover" src="{{item.cover}}"></image>

      <image src="/assets/images/play-btn.png" class="play-btn"></image>
      <view class="like">
        <image src="/assets/icons/hart.png" ></image>
        <text>{{item.like_nums_base}}</text>
      </view>
    </view>

    <view class="meta">
      <view class="price">
              <text class="title">{{item.title}}</text>
        <text class="price">450万-620万</text>
      </view>
      <view class="desc" wx:if="{{item.desc}}"> {{ item.desc }} </view>

      <mytags right items="{{item.tags_list}}"></mytags>

    </view>
  </navigator>

</view>

</view>
