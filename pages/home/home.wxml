<van-transition show="{{showInstallTips == 1}}" duration="500" name="fade-down" custom-class="install-tips" bindtap="closeInstallTips">
    <image src="/assets/images/install-tips-{{system.systemName}}.png" />
</van-transition>


<page-loading loading="{{loading}}" />

<block wx:for="{{homeData}}" wx:for-item="block" wx:for-key="index" hidden="{{loading}}">
      <myslider wx:if="{{block.name == 'banners' }}" items="{{block.items}}"></myslider>
      <view wx:if="{{block.name == 'navs' }}"  class="header"> <navs items="{{block.items}}" /> </view>
      <view wx:if="{{block.name== 'news'  }}" class="my-news-swiper"> <news-swiper items="{{block.items}}" /> </view>
      <view class="block-navs"   wx:if="{{block.name == 'dingzhi' }}">
          <view class="left">
            <view class="block-nav-item" bindtap="gotoZhaofang">
              <view class="block-nav-item-name">定制找房</view>
              <view class="block-nav-item-desc">只需要填写简单要求，平台经纪人即可为您找到理想居所</view>
              <view class="block-nav-item-action">
                <van-button type="info" size="small">点击开始找房</van-button>
              </view>
            </view>
          </view>

          <view class="right">
            <view class="block-nav-item" bindtap="gotoSubs">
              <view class="block-nav-item-name">热门小区</view>
              <view class="block-nav-item-desc">浏览热门小区</view>
            </view>
            <view class="block-nav-item" bindtap="gotoMap">
              <view class="block-nav-item-name">地图找房</view>
              <view class="block-nav-item-desc">点击开始找房</view>
            </view>
          </view>
      </view>

      <block wx:if="{{block.name == 'brokers' }}">
            <view class="home-title" style="margin-top:20rpx;"> <view class="name">{{block.label}}</view> </view>
            <scroll-view  scroll-with-animation="{{true}}" scroll-x style="width:100%;margin-bottom:20rpx;">
              <brokers brokers="{{block.items}}"  max="10" />
            </scroll-view>
      </block>

      <block wx:if="{{block.name == 'posts' }}">
        <posts-block block="{{block}}" />
      </block>
        
      <new-version wx:if="{{block.name == 'version' }}" />
      <cr wx:if="{{ block.name == 'copyright' }}" text="{{block.text}}"  />

</block>


