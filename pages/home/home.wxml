<myslider id="slider"></myslider>
<view class="header">
  <view class="tab-icons">
    <navigator url="{{item.url}}"  open-type="{{item.opentype}}" hover-class="none"  wx:for-index="index" wx:for="{{tabIcons}}">
           <view style="background:#{{tabColors[index]}}" class="icon-cover">
              <image src="/assets/icons/tab-{{item.id}}.png"></image>
           </view>
      <text>{{ item.name }}</text>
    </navigator>
  </view>
</view>

    <view class="home-title">
        <view class="h1">猜你喜欢</view>
        <view class="home-actions">
                <view bindtap="action1Click" class="item {{ currentAction == 1 ? 'active' : ''}}">二手房</view>
                <view bindtap="action2Click" class="item {{ currentAction == 2 ? 'active' : ''}}">租房</view>
        </view>
    </view>
    <box padding="30">
    <block wx:for="{{posts}}" wx:for-item="postitems">
       <post wx:for="{{postitems}}" item="{{item}}"></post>
    </block>
    </box>

<van-action-sheet
  show="{{ publishSheetShow }}"
  actions="{{ publishActions }}"
  bind:close="publishClose"
  bind:select="publishClick"
/>
