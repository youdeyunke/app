
<view class="container main">
  <mytopbar bindcitychanged="cityHandle"></mytopbar>
  <myslider></myslider>
  <view class="tab-icons">
          <navigator url="/pages/post/index?group={{item.id}}"  open-type="{{item.opentype}}" hover-class="none"  wx:for-index="index" wx:for="{{tabIcons}}">
          <image src="/assets/icons/tab-{{item.id}}.png"></image>
      <text>{{ item.name }}</text>
    </navigator>

  </view>
</view>


  <view class="posts-list">
    <block wx:for="{{posts}}" wx:for-item="postitems">
            <mypost border="{{false}}" shadow="{{false}}" wx:for="{{postitems}}" item="{{item}}"></mypost>
    </block>
  </view>
