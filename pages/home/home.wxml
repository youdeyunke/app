<myslider wx:if="{{configs.plugin_home_slider != false }}"  id="slider"></myslider>

<view class="header">
  <navs id="navs" />
</view>

<view wx:if="{{configs.plugin_home_toutiao != false}}" class="my-news-swiper">
    <news-swiper />
</view>


<block wx:if="{{configs.plugin_home_dingzhi != false }}">
<view class="home-title">
  <view class="name">定制找房</view>
</view>

<form report-submit bindsubmit='formidHandle' class="zhao">
  <button class="fake-btn" form-type="submit" bindtap="gotoZhaofang">
    <view class="desc">只需要填写简单要求，平台经纪人即可为您找到理想居所</view>
    <view class="link">开始找房<van-icon name="arrow" color="#000000" /></view>
  </button>
</form>
</block>


<block wx:if="{{configs.plugin_home_xinfang != false }}">
<view class="home-title">
  <view class="name">猜你喜欢的新房</view>
</view>
<box width="750" padding="30">
  <items id="new-posts" kw="" page="1" filter="{{newFilter}}" />
  <navigator url="/pages/post/index?group_v2=new" hover-class="none" class="more-btn">查看更多新房</navigator>
</box>
</block>


<block wx:if="{{ configs.plugin_home_ershoufang != false }}">
<view class="home-title">
  <view class="name">猜你喜欢的二手房</view>
</view>
<box width="750" padding="30">
  <items id="old-posts" kw="" page="1" filter="{{oldFilter}}" />
  <navigator url="/pages/post/index?group_v2=old" hover-class="none" class="more-btn">查看更多二手房</navigator>  
</box>
</block>


<block wx:if="{{ configs.plugin_home_zufang != false }}">
<view class="home-title">
  <view class="name">猜你喜欢的租房</view>
</view>
<box width="750" padding="30">
  <items id="rent-posts" kw="" page="1" filter="{{rentFilter}}" />
 <navigator url="/pages/post/index?group_v2=rental" hover-class="none" class="more-btn">查看更多租房</navigator>  
</box>
</block>

<cr />

<van-popup show="{{showNewVersionWindow}}" duration="500" custom-style="background:none;"   >
  <view class="new-version-window">
    <view class="close" bindtap="markNewVersion"></view>
    <image src="https://qiniucdn.udeve.cn/wefang-sass/new-version-popup.png" class="bg" /> 
    <view class="confirm" bindtap="markNewVersion"></view>
    <view class="title">发现新版本</view>
    <view class="sub-title">最新版本号：{{ ext.version }}</view>
    <view class="desc">{{ ext.version_desc }}</view>
  </view>

</van-popup>
