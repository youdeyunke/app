<import src="/tpls/posts/mini_listing.wxml"/>

<view class="container main">
  <mytopbar bindcitychanged="cityHandle"></mytopbar>
  <myslider></myslider>
  <view class="tab-icons">
        <navigator open-type='navigateTo' url="/pages/post/index" hover-class='none'>
          <image src="/assets/icons/tab-all.png"></image>
          <text>全部</text>
        </navigator>

          <navigator url="/pages/post/index?cat_id={{item.id}}"  open-type="navigateTo" hover-class="none"  wx:for-index="index" wx:for="{{cats}}">
      <image src="{{item.icon}}"></image>
      <text>{{ item.name }}</text>
    </navigator>

  </view>
</view>

  <view class="post-mini container" wx:for="{{posts}}" wx:for-item="postitems">
    <template is="miniposts"  data="{{ posts: postitems}}"></template>
  </view>
