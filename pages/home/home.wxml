<import src="/tpls/posts/mini_listing.wxml"/>

<view class="container">
  <mytopbar bindcitychanged="cityHandle"></mytopbar>
  <myslider></myslider>
  <view class="tab-icons">
    <navigator open-type="{{item.opentype}}" hover-class="none"  wx:for-index="index" url="{{item.url}}?cat={{item.id}}" wx:for="{{tabIcons}}">
      <image src="/assets/icons/tab-{{item.id}}.png"></image>
      <text>{{ item.name }}</text>
    </navigator>

  </view>
</view>

  <view class="post-mini container" wx:for="{{posts}}" wx:for-item="postitems">
    <template is="miniposts"  data="{{ posts: postitems}}"></template>
  </view>
