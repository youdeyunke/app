page {
    padding-top: 0rpx !important;
}

.install-tips {
    position: fixed;
    top: 0rpx;
    right: 20rpx;
    width: 595rpx;
    height: 95rpx;
    z-index: 999999;
}

.install-tips image {
    width: 100%;
    height: 100%;
}
.topLeftBtn{
    font-size: 24rpx;
    color:#cecece;
    height: 32px;
    background-color: rgb(0, 0, 0, 0.16);
    border-radius: 16px;
    display: flex;
    max-width: 220rpx;
    align-items: center;
}
.topLeftBtn-address{
    margin-left:16px;
    max-width: 165rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 50rpx;
    /* padding-right: 6px; */
}