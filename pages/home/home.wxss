page{
  padding-top:0rpx;
  background: #fff !important;
}

.header{
background:#fff;
width:710rpx;
padding:0 0rpx 20rpx 0rpx;

box-sizing: border-box;
border-radius:15rpx;

}

.home-title{
  display:flex;
  justify-content:space-between;
  align-items: center;
  width:100%;
  box-sizing:border-box;
  padding:0rpx 30rpx;
  background: #fff;
  margin-top:20rpx;
}

.my-news-swiper{
  margin:20rpx 20rpx;
  width:670rpx;
  border-radius: 10rpx;
  padding:20rpx;
  border :2rpx solid #f4f4f4;

}

.home-title .name{
  font-size:40rpx;
  color:#000;
  font-weight: bolder;
  width:50%;
}

.home-title .home-actions{
        width:50%;
        display:flex;
        justify-content:flex-end;
}
.home-title .home-actions view{
  margin-left:15rpx;
}

.home-title .home-actions view.active{
  color:var(--color-a);
}

.zhao{
  width:100%;
}

.zhao button{
  background: #FFFFFF;
  box-shadow: 2rpx 2rpx 6rpx 0 #CECECE;
  border-radius: 10rpx;
  padding:30rpx;
  width:690rpx;
  margin:20rpx auto;
}


.zhao .desc{
  color:#666;
  width:430rpx;
}

.zhao .link{
  margin-top:20rpx;
  color:#000000;
  font-weight:bolder;
  display:flex;
  justify-content:flex-start;
  align-items:center;
}


.zhao button.fake-btn, .zhao button.fake-btn::after{
  background:none;
  font-size:28rpx;
  font-weight:normal;
  text-align:left;
  line-height:1.4;
}
