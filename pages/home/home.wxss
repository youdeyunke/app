/* pages/home/home.wxss */

page{
  display:flex;
  flex-direction: row;
  flex-wrap: nowrap;
  background-repeat: no-repeat;
  justify-content: space-between;
  background-image: url("http://jiayaosu-10013564.image.myqcloud.com/39d0ccd7-721a-471e-a853-54ec69f564f5");
  background-size: 750rpx 850rpx;
}

page .container{
  width:690rpx;
  margin:0 auto;
}

.top-bar{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: nowrap;
  height: 110rpx;
}

.top-bar picker{
  width:138rpx;
  font-size:28rpx;
  color:#000;
  padding-left:10rpx;
}

.top-bar picker image{
  width:18rpx;
  height: 18rpx;
}

.top-bar .search-bar{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  width:552rpx;
  position: relative;
}

.top-bar .search-bar .btn{
  width:40rpx;
  height: 40rpx;
  border:none;
  position: absolute;
  left:30rpx;
  top:7rpx;
  z-index: 10;
  
}

.top-bar .search-bar input{
  height: 46rpx; 
  background: #fff;
  opacity: 0.6;
  border-radius: 40rpx;
  width:100%;
  padding-left:100rpx;
  font-size:22rpx;
  line-height: 46rpx;

  }

.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;

  margin-top:40rpx;
  margin-bottom:40rpx;
}

.tab-icons navigator{
  width:25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icons navigator image{
  width:120rpx;
  height: 120rpx;
}

.tab-icons navigator text{
  color: #666;
  font-size:24rpx;
  margin-top:20rpx;
}
@import "/pages/post/index.wxss";