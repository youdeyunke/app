page{
  padding-top:0rpx;
}

.header{
  background:white;
  width:100%;
  padding:0 0rpx 20rpx 0rpx;
  box-shadow: 2rpx 4rpx 10rpx rgba(0,0,0, 0.05);
  margin-bottom:20rpx;
  box-size:border-box;
}



.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-around;
  box-sizing: border-box;
  margin-top:30rpx;
  font-size:var(--font-xs);
}

.tab-icons navigator{
  width:20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}


.tab-icons .icon-cover{
  width:84rpx;
  height:84rpx;
  margin-bottom:8rpx;
  border-radius:100%;
  box-shadow: 1px 1px 2px rgba(0,0,0, 0.1);
  display:flex;
  justify-content:center;
  align-items:center;
}

.tab-icons navigator image{
  width:47rpx;
  height: 47rpx;
}

.tab-icons navigator text{
  color: #000;
  font-weight: normal;
  margin-top:8rpx;
  margin-bottom:8rpx;
}

myfav{
  position: absolute;
  top:30rpx;
  right:0rpx;
}


.section{
 width:720rpx;
 padding:15rpx 15rpx;
}

.home-title{
  display:flex;
  justify-content:space-between;
  width:100%;
  box-sizing:border-box;
  padding:20rpx 30rpx;
}

.home-title .h1{
  width:50%;
}

.home-title .home-actions{
        width:50%;
        display:flex;
        justify-content:flex-end;
}
.home-title .home-actions view{
  margin-left:15rpx;
}

.home-title .home-actions view.active{
  color:var(--color-a);
}
