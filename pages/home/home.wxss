page{
  padding-top:0rpx;
}

.header{
  background:linear-gradient(to bottom, var(--color-a), white 50%);
  width:100%;
  padding:0 0rpx 20rpx 0rpx;
  box-shadow: 2rpx 4rpx 10rpx rgba(0,0,0, 0.05);
  margin-bottom:20rpx;
  box-size:border-box;
}



.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-around;
  box-sizing: border-box;
  margin-top:30rpx;
  font-size:var(--font-xs);
}

.tab-icons navigator{
  width:25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}


.tab-icons .icon-cover{
  width:84rpx;
  height:84rpx;
  margin-bottom:8rpx;
  border-radius:100%;
  box-shadow: 1px 1px 2px rgba(0,0,0, 0.1);
  display:flex;
  justify-content:center;
  align-items:center;
}

.tab-icons navigator image{
  width:47rpx;
  height: 47rpx;
}

.tab-icons navigator text{
  color: #000;
  font-weight: normal;
  margin-top:15rpx;
}

myfav{
  position: absolute;
  top:30rpx;
  right:0rpx;
}


.header myslider swiper, .header myslider image{
  width:710rpx;
  height:320rpx;
  border-radius:20rpx;
}


.section{
 width:720rpx;
 padding:15rpx 15rpx;
}
