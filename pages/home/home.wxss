@import "/tpls/posts/mini_listing.wxss";

page, page .container.main{
  padding-top:0rpx;
}

.post-list{
  margin-top:20rpx;
}

.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-around;
  box-sizing: border-box;
  margin-top:30rpx;
}

.tab-icons navigator{
  width:25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icons navigator image{
  width:35rpx;
  height: 35rpx;
  margin-bottom:10rpx;

  border:1rpx solid #f4f4f4;
  padding:18rpx;
  border-radius:100%;
  box-shadow: 1rpx 1rpx 1rpx rgba(0,0,0, 0.1);
  
}

.tab-icons navigator text{
  font-size:24rpx;
  color: #000;
  font-weight: normal;
}

myfav{
  position: absolute;
  top:30rpx;
  right:0rpx;
}


.posts-list{
  width: 100%;
}