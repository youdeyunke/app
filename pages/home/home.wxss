/* pages/home/home.wxss */

page{
  display:flex;
  flex-direction: row;
  flex-wrap: nowrap;
  background-repeat: no-repeat;
  justify-content: space-between;
  background-image: url("http://jiayaosu-10013564.image.myqcloud.com/39d0ccd7-721a-471e-a853-54ec69f564f5");
  background-size: 750rpx 850rpx;
}

page .container{
  width:690rpx;
  margin:0 auto;
}

.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;

  margin-top:40rpx;
  margin-bottom:40rpx;
}

.tab-icons navigator{
  width:25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icons navigator image{
  width:120rpx;
  height: 120rpx;
}

.tab-icons navigator text{
  color: #666;
  font-size:24rpx;
  margin-top:20rpx;
}
@import "/tpls/posts/listing.wxss";
