page{
  padding-top:0rpx;
}

.header{
  background:white;
  width:100%;
  padding:0 0rpx 20rpx 0rpx;
  box-shadow: 2rpx 4rpx 10rpx rgba(0,0,0, 0.05);
  margin-bottom:20rpx;
  box-size:border-box;
}




.home-title{
  display:flex;
  justify-content:space-between;
  width:100%;
  box-sizing:border-box;
  padding:20rpx 30rpx;
}

.home-title .h1{
  width:50%;
}

.home-title .home-actions{
        width:50%;
        display:flex;
        justify-content:flex-end;
}
.home-title .home-actions view{
  margin-left:15rpx;
}

.home-title .home-actions view.active{
  color:var(--color-a);
}
