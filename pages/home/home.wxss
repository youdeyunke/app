@import "/tpls/posts/mini_listing.wxss";

page{
  padding-top:0rpx;
}

.post-list{
  margin-top:20rpx;
}

.tab-icons{
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: flex-start;
  box-sizing: border-box;
  margin-top:30rpx;
}

.tab-icons navigator{
  width:25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icons navigator image{
  width:40rpx;
  height: 40rpx;
  margin-bottom:10rpx;
}

.tab-icons navigator text{
  font-size:24rpx;
  color: #000;
  font-weight: normal;
}

myfav{
  position: absolute;
  top:30rpx;
  right:0rpx;
}