page{
  padding-top:0rpx;
  background: #fff !important;
}

.header{
background:#fff;
width:710rpx;
padding:0 0rpx 20rpx 0rpx;
box-shadow:2rpx 6rpx 6rpx rgba(0,0,0, 0.08);
margin-bottom:20rpx;
border:2rpx solid #f4f4f4;
box-sizing: border-box;
border-radius:15rpx;

}

.home-title{
  display:flex;
  justify-content:space-between;
  align-items: center;
  width:100%;
  box-sizing:border-box;
  padding:0rpx 30rpx;
  margin-top:30rpx;
  background: #fff;
  margin-top:20rpx;
}

.my-news-swiper{
  margin:20rpx 20rpx;
  width:670rpx;
  background:#f9f9f9;
  border-radius: 10rpx;
  padding:20rpx;

}

.home-title .h1{
  width:50%;
}

.home-title .home-actions{
        width:50%;
        display:flex;
        justify-content:flex-end;
}
.home-title .home-actions view{
  margin-left:15rpx;
}

.home-title .home-actions view.active{
  color:var(--color-a);
}
