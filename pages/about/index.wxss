/* pages/about/index.wxss */
page{
  background: #ffd900;
  height: 100%;
}

.container{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  height: 100%;
}

.logo{
  height: 40%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo image{
  height: 200rpx;
  width:200rpx;
}

.meta{
  height: 60%;
  display: flex;
  flex-direction: column;
  align-items: center;
  width:100%;
}

.meta .item{
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  font-size:28rpx;
  color:#333;
  border-bottom:1px solid #f4f4f4;
  padding-left:50rpx;
  padding-right:50rpx;
  width:calc(100% - 100rpx);
  padding-top:30rpx;
  padding-bottom:30rpx;

}
