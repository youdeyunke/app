<view class="container">
    <view class="desc">{{info.company_desc}}</view>
    <view class="meta">
        <view class="item">
          <view class="label">咨询电话</view>
          <view class="value">
            <text selectable="{{true}}">{{info.service_mobile}}</text>
            </view>
        </view>           
         
        <view class="meta">
              <view class="item contact">
                <view class="label">客服微信</view>
                <view class="value" bindtap='copyWechat'>
                  <text selectable="{{true}}">{{info.service_wechat}}</text>
                  <image src="/assets/icons/weixin.png"></image>
                </view>

              </view>   
        </view>                                
    </view>

</view>
