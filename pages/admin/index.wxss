.notice{
  width:100%;
  position: absolute;
  left:0;
  bottom:0;
  right:0;
}

.user{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width:100%;
}

.user .uinfo{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  width:370rpx;
}

.user .user-actions{
  display:flex;
  justify-content:flex-end;
}

.user .uinfo .avatar{
  margin-right:20rpx;
}

.avatar, .avatar image{
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom:10rpx;
}

.user button.fake, .user button.fake::after{
  background: none;
  border:none;
  font-size:28rpx;
}


.menu-item-name{
  color: #333;
  font-size:24rpx;
  margin-top:15rpx;
}

.menu-item{
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  flex-wrap:wrap;
}
