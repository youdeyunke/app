<box padding="40" >
<view class="user">
  <view class="uinfo">
    <view class="avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="nickname">{{userInfo.name || '' }} {{ userInfo.company || '' }} </view>
  </view>

  <view class="user-actions">
      <!-- button bindtap="subMessageHandle"  style="font-size:24rpx; color:#333;" type="default" plain >激活微信推送</button -->
  </view>
</view>
</box>

<box padding="30">
  <van-grid>
    <van-grid-item url="{{item.url}}"  use-slot wx:for="{{menuItems}}" wx:key="{{index}}"   hover-class="none"  >
      <view class="menu-item">
        <van-icon color="{{item.color}}" size="58rpx" name="{{item.icon}}"  />
        <view class="menu-item-name">{{item.name}} </view>
      </view>
    </van-grid-item>
  </van-grid>
</box>
