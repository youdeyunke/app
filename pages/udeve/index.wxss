.cover{
  width:750rpx;
  height: 660rpx;
  position: relative;
}

.cover .title{
  width: 750rpx;
  font-size: 52rpx;
  color: #fff;
  text-align: center;
  position: absolute;
  top:60rpx;
  left: 0rpx;
  right: 0rpx;
  z-index:99;
}

.cover image{
  position: absolute;
  left:0rpx;
  top: 0rpx;
  right: 0rpx;
  width: 750rpx;
  height: 660rpx;
  z-index: 1 ;
}

button::after{
  border:none;
}


.form{
  background: #fff;
  width: 100%;
  padding:20rpx 95rpx;
  box-sizing: border-box;
  font-size:28rpx;
}

.form .title{
  text-align:center;
  margin-bottom:40rpx;
}

.form .submit{
  margin-top:80rpx;
  margin-bottom:80rpx;
  background-image: linear-gradient(90deg, #F2DC71 0%, #F6AC47 100%);
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: bolder;
  color: #FFFFFF;
  letter-spacing: 0;
  text-align: center;
  width: 500rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.res{
  margin:0 auto;
}
