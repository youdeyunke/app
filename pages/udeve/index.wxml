<view class="cover">
  <view class="title">做个小程序     </view>
  <image src="https://qiniucdn.udeve.cn/wefang-sass/zgxcx.png"></image>
</view>

<form wx:if="{{!isDone}}" class="form" bindsubmit="submitHandle" report-submit  >
  <view class="title">填写联系信息，技术顾问将在48小时内联系您</view>

  <van-field size="large" required bindchange="inputChange"input-align="left" name="name" label="称呼"  placeholder="如何称呼您" />
  <van-field size="large" required bindchange="inputChange"input-align="left" name="mobile" type="number" label="电话"  placeholder="11位手机号" />
  <van-field size="large" bindchange="inputChange"input-align="left" name="wechat" label="微信"  placeholder="微信号，可不填" />
  <van-field size="large" bindchange="inputChange"input-align="left" name="remark" label="留言"  clearable placeholder="具体想做个怎样的小程序" />

  <button form-type="submit" class="submit">填好了，马上提交</button>
</form>

<form  class="form" bindsubmit='formidHandle' report-submit  wx:if="{{isDone}}">
  <view class="res">
    <view class="title">提交成功</view>
    <view class="desc">我们已经收到您提交的信息，技术顾问将在48小时后联系您，请保持电话畅通</view>
    <view class="btns">
      <button class="submit" type="default" form-type="submit" bindtap="gotoHome">返回首页</button>
    </view>
  </view>
</form>


<view class="tips">
  <flow-tips title="小程序制作流程" steps="{{steps}}" />
</view>
