.ecats {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.cat-item {
    height: 60rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24rpx;
    border-radius: 4rpx;
    color: #333333;
    border: 2rpx solid rgba(200, 201, 204, 1);
    padding: 0 15rpx;
    margin-right: 10rpx;
}

.cat-item.active {
    color: #ffffff;
    background: rgba(25, 137, 250, 1);
    border: none;
}

.event {}

.event .title {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.event .title .circle {
    width: 22rpx;
    height: 22rpx;
    border: 6rpx solid rgba(25, 137, 250, 1);
    border-radius: 22rpx;
    margin-right: 30rpx;
}

.event .title .time {
    font-size: 28rpx;
    color: #333;
}

.event .content {
    font-size: 28rpx;
    color: #666;
    padding: 14rpx 0 30rpx 42rpx;
    border-left: 2px solid #cecece;
    margin-left: 15rpx;
}

.tips{
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-size:22rpx;
    margin-bottom:30rpx;
}

.tips text{
    color:#cecece;
}

