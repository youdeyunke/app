<!-- pkgXiangce/pages/xiangce/index.wxml -->
<viwe class="header" >
    <van-tabs animated type="line" color="#1989FA" bind:change="tabChange" sticky>
        <van-tab wx:key="id" wx:for="{{cats}}" wx:for-item="cat" title="{{cat.name}}">
            <view class="tab-outer"><media-items items="{{cat.media_items}}" /></view>
        </van-tab>
    </van-tabs>
</viwe>


<view class="footer">
    <van-button bindtap="bookingHandle" icon="chat-o" type="primary" block>预约看房</van-button>
    <van-button bindtap="callHandle" icon="phone-o" type="info" block>电话咨询</van-button>
</view>
<booking bind:change="bookingChange" booked="{{bookingStatus}}" post-id="{{postId}}" id="booking" />