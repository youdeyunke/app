<view class="tm">
  <timer date="{{item.ends_at}}"></timer>
</view>

<cover item="{{item}}"></cover>

<view class="body">

  <steps></steps>

  <mycard width="710" radius="15" title="活动介绍" title-size="32">
    <raw-html html="{{item.content}}"></raw-html>
  </mycard>

  <mycard width="710" radius="15" title="使用规则" title-size="32">
    {{ item.rule }}
  </mycard>


</view>

<view class="footer">
  <view class="btn share">
    <button class="fake" open-type="share"></button>
    转发告诉好友
  </view>

  <view bindtap="joinHandle" class="btn join">
    我要发起助力
  </view>
</view>