.outer{
  width: 100%; 
  height: 26rpx; 
  background: #E6E6E6; 
  border: 2rpx solid #DCDCDC;
  border-radius: 13rpx;
  overflow: hidden;
  margin: 30rpx 0;
}

.main{
  height: 100%; 
  background: #FFAD0E; 
  transition: width 1s ease-out;
  
}