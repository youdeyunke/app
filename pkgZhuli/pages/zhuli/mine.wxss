/* pkgZhuli/pages/zhuli/mine.wxss */

.tips{
  color:#333333;
  font-size: 24rpx; 
}

.tips .red{
  color:#923737; 
  font-weight: 600;
  font-size: 26rpx;
}


.help{
  height: 90rpx; 
  width: 100%; 
  color:#fff; 
  line-height: 90rpx;
  text-align: center;
  font-size: 28rpx; 
  font-weight: bolder;
  border-radius: 45rpx; 
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
}

.help.done{
  color:#999; 
  background:#f2f2f2;
}


.footer {
  height: 90rpx;
  position: fixed;
  bottom: 20rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.footer .btn {
  line-height: 90rpx;
  text-align: center;
  width: 317rpx;
  height: 90rpx;
  font-size: 28rpx;
  color: #fff;
 
  border-radius: 45rpx;
}
.footer .btn.share{
  position:relative;
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
 
}

.footer .btn.share .fake {
  width: 100%; 
  height: 100%; 
  position: absolute; 
  top:0; 
  left:0;
  opacity: 0;
}

.footer .btn.join{
  background: linear-gradient(180deg, #FF7373 0%, #F97373 49.27%, #D84848 100%);

}