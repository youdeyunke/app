/* pkgZhuli/pages/zhuli/mine.wxss */
page{
  padding-bottom:120rpx;
  padding-top:200rpx;
  height: 100%;
  background-image: url('https://qiniucdn.udeve.net/fang/zhuli-bg.png?t=2');
  background-size: 100% 100%;

}

.tips{
  color:#333333;
  font-size: 24rpx; 
}

.tips .red{
  color:#923737; 
  font-weight: 600;
  font-size: 26rpx;
}


.help{
  height: 90rpx; 
  width: 100%; 
  color:#fff; 
  line-height: 90rpx;
  text-align: center;
  font-size: 28rpx; 
  font-weight: bolder;
  border-radius: 45rpx; 
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
}

.help.done{
  color:#999; 
  background:#f2f2f2;
}


.footer {
  height: 90rpx;
  position: fixed;
  bottom: 20rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.footer .btn {
  line-height: 90rpx;
  text-align: center;
  width: 317rpx;
  height: 90rpx;
  font-size: 28rpx;
  color: #fff;
 
  border-radius: 45rpx;
}
.footer .btn.share{
  position:relative;
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
 
}

.footer .btn.share .fake {
  width: 100%; 
  height: 100%; 
  position: absolute; 
  top:0; 
  left:0;
  opacity: 0;
}

.footer .btn.join{
  background: linear-gradient(180deg, #FF7373 0%, #F97373 49.27%, #D84848 100%);

}

.haoyou-list{
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  width: 100%; 
}

.haoyou-item{
  display: flex;
  width: 100%;
  box-sizing: border-box;
  padding:10rpx 10rpx;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f2f2f2;
  font-size: 24rpx;
}

.haoyou-item .name{
  color:#333;
}

.haoyou-item .time{
  color:#999;
}

.haoyou-item .fqr{
  width: 98rpx; 
  height: 28rpx;
  vertical-align: middle;
}
.haoyou-item:last-child{
  border:none;
}

.success .btn {
  line-height: 90rpx;
  text-align: center;
  width: 100%;
  height: 90rpx;
  font-size: 28rpx;
  color: #fff; 
  border-radius: 45rpx;

  position:relative;
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
 
}

.success {
  padding:20rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

.success .title{
  font-size:38rpx; 
  color: #A68900;
  line-height: 38rpx;
  text-align: center;
  margin-bottom:40rpx;
  margin-top:30rpx;

}

.success .desc{
  font-size: 24rpx; 
  color: #666;
  margin-bottom:30rpx;
  margin-top:20rpx;
}