/* pkgSearch/page/search/index.wxss */
page{
  box-sizing: border-box;
  background-color: #fff !important;
  padding: 40rpx 25rpx 0 20rpx;
}
.search-top{
  height:70rpx ;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.search-top-left{
  width:625rpx ;
  height:70rpx ;
  background-color: #F0F0F0;
  border-radius: 50rpx;
  font-size:24rpx ;
  color: #A0A0A0;
  display: inline-block;
  display: flex;
  align-items: center;
  padding-left: 45rpx;
}
.image1{
  width:26rpx ;
  height: 26rpx;
  margin-right: 15rpx;
}
.search-top-right{
  font-size:26rpx ;
  color:#1989FA ;
}
.search-history{
  font-size: 34rpx;
  color: #333333;
  height: 45rpx;
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 37rpx;
}
.image2{
  width: 31rpx;
  height: 34rpx;
}
.search-record text{
  height: 53rpx;
  background-color: #F0F0F0;
  font-size:24rpx ;
  color: #A0A0A0;
  display: inline-block;
  line-height: 53rpx;
  padding:0 33rpx;
  border-radius:50rpx ;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}
.image3{
  width: 700rpx;
  height: 120rpx;
  margin-top: 20rpx;
  margin-bottom: 50rpx;
}