<template name="form-old">
  <block>
    <card title="地址" wx:if="{{step==1}}" subtitle="门牌号保密，仅管理员可见" hat wx:if="{{step==1}}">
      <van-field error="{{error.district_id}}" input-align="left" disabled bindtap="showCityPicker" is-link label="城市" value="{{post.city.name || '请选择'}} {{post.district.name}}" arrow-direction="down" />
      <van-field value="{{ post.area_name}}" data-name="area_name" error="{{error.area_name}}" label="小区" input-align="left" placeholder="请输入小区名称" bind:change="inputChange" />
      <van-field value="{{ post.area_year }}" type="number" data-name="area_year" error="{{error.area_year}}" label="年代" input-align="left" placeholder="请输入小区年代" bind:change="inputChange" />
      <van-field data-name="street" value="{{ post.street }}" input-align="left" error="{{error.street}}" label="街道" placeholder="如：巨峰路1028弄55号" bind:change="inputChange" />
      <van-field data-name="house_number" value="{{ post.house_number }}" input-align="left" label="门牌号" placeholder="如：55号楼 1002室" bind:change="inputChange" />
    </card>

    <card title="户型信息" hat wx:if="{{step==1}}">
          <van-field
            value="{{ post.construction_area }}"
            error="{{error.construction_area}}"
            label="建筑面积"
            type="number"
            placeholder="平米"
            data-name="construction_area"
            input-align="left"
            bind:change="inputChange"
          />
          <van-field
            data-name="total_price"
            error="{{error.total_price}}"
            value="{{ post.total_price }}"
            label="售价(万)"
            input-align="left"
            type="digit"
            placeholder="万元"
            bind:change="inputChange"
          />

      <van-field bindtap="showTypePicker" is-link error="{{error.type}}" input-align="left" label="户型" value="{{post.s}}室-{{post.t}}厅-{{post.w}}卫 {{ post.position}}" arrow-direction="down" disabled />
      <van-field bindtap="showFitmentPicker" error="{{error.fitment_id}}" is-link input-align="left" label="装修" value="{{post.fitment.name || '请选择'}}" arrow-direction="down" disabled />

      <van-field bindtap="showFloorPicker" is-link input-align="left" error="{{error.floor}}" label="楼层" value="第{{post.current_floor || '几'}}层-共{{post.total_floor || '几'}}层 {{post.has_lift == true ? '有' : '无'}}电梯" arrow-direction="down" disabled />
      <van-switch-cell title="服务费" data-name="service_charge_enable" checked="{{post.service_charge_enable}}" bindchange="serviceChargeEnableChange" />
      <van-field 
              wx:if="{{post.service_charge_enable}}" 
              error="{{error.service_charge}}"
              data-name="service_charge" 
              value="{{ post.service_charge }}" 
              input-align="left" 
              label="收费标准" 
              placeholder="请输入" 
              bind:change="inputChange" />
    </card>


<card title="房源详情" hat  wx:if="{{step==2}}">
        <van-field value="{{post.desc}}" label="房源介绍" placeholder="选填" bind:change="inputChange"  data-name="desc" autosize />
        <van-field value="{{post.selling_points}}" label="核心卖点" placeholder="选填" bind:change="inputChange"  data-name="selling_points" autosize />
        <van-field value="{{post.surrounding}}" label="周边配套" placeholder="选填" bind:change="inputChange"  data-name="surrounding" autosize />
        <van-field value="{{post.owner_mindset}}" wx:if="{{user.is_broker}}" label="业主心态" placeholder="选填" bind:change="inputChange"  data-name="owner_mindset" autosize />
</card>

</block>
</template>
