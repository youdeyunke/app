<template name="form-old">
    <block>

        <card title="业主信息" hat="true" wx:if="{{step==1 && user.broker_profile.enable  }}">
            <van-field size="large"  data-name="owner_name" value="{{ post.owner_name }}" input-align="left"
                error="{{error.owner_name}}" label="姓名" placeholder="" bind:change="inputChange" />
            <van-field size="large"  data-name="owner_mobile" value="{{ post.owner_mobile }}" input-align="left"
                error="{{error.owner_mobile}}" label="电话" placeholder="" bind:change="inputChange" />
        </card>

        <card title="户型信息" hat wx:if="{{step==1}}">
            <van-field size="large"  value="{{ post.area }}" error="{{error.area}}" label="建筑面积"
                type="number" placeholder="平米" data-name="area" input-align="left"
                bind:change="inputChange" />
            <van-field size="large"  data-name="total_price" error="{{error.total_price}}" value="{{ post.total_price }}"
                label="售价(万)" input-align="left" type="digit" placeholder="万元" bind:change="inputChange" />

            <van-field size="large"  bindtap="showTypePicker" is-link error="{{error.type}}" input-align="left" label="户型"
                value="{{post.s}}室-{{post.t}}厅-{{post.w}}卫 {{ post.position}}" arrow-direction="down" disabled />
            <van-field size="large"  bindtap="showFitmentPicker" error="{{error.fitment_id}}" is-link input-align="left" label="装修"
                value="{{post.fitment.name || '请选择'}}" arrow-direction="down" disabled />

            <van-field size="large"  bindtap="showFloorPicker" is-link input-align="left" error="{{error.floor}}" label="楼层"
                value="第{{post.current_floor || '几'}}层-共{{post.total_floor || '几'}}层 {{post.has_lift == true ? '有' : '无'}}电梯"
                arrow-direction="down" disabled />
            <van-cell  title="服务费" >
                <van-switch slot="right-icon" data-name="service_charge_enable" checked="{{ post.service_charge_enable }}" bind:change="serviceChargeEnableChange" />
            </van-cell>

            <van-field size="large"  wx:if="{{post.service_charge_enable}}" error="{{error.service_charge}}"
                data-name="service_charge" value="{{ post.service_charge }}" input-align="left" label="收费标准"
                placeholder="请输入" bind:change="inputChange" />
        </card>


        <card title="房源详情" hat wx:if="{{step==2}}">
            <van-field size="large"  value="{{post.verify_code}}" label="核验码" placeholder="选填" bind:change="inputChange" data-name="verify_code"
                />

            <van-field size="large"  value="{{post.desc}}" label="房源介绍" placeholder="选填" bind:change="inputChange" data-name="desc"
                autosize />
            <van-field size="large"  value="{{post.owner_mindset}}" wx:if="{{user.is_broker}}" label="业主心态" placeholder="选填"
                bind:change="inputChange" data-name="owner_mindset" autosize />
            <van-field size="large"  value="{{post.remark }}" label="备注" placeholder="选填" bind:change="inputChange" data-name="remark"
                autosize />
        </card>

        <card title="标签" hat wx:if="{{step==1}}" subtitle="请选择标签" wx:if="{{step==2}}">
            <view class="post-tags">
                <view bindtap="tagHandle" data-index="{{index}}"
                    class="post-tag-item {{ tag.selected ? 'active' : '' }}" wx:for="{{allTags}}" wx:for-item="tag">
                    {{tag.name}}</view>
            </view>

        </card>

    </block>
</template>
