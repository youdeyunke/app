<template name="posts">
  <view class="posts">
  <navigator hover-class="none" wx:for="{{posts}}" hover-class="none" url="/pages/post/post?id={{item.id}}" class="item">
    <view class="header">
            <image class="cover" src="{{item.cover.url}}"></image>

      <image src="/assets/images/play-btn.png" class="play-btn"></image>
      <myfav post="{{item}}"></myfav>
    </view>

    <view class="meta">
      <view class="price" wx:if="{{item.cate == 'item'}}">
          <text class="title"> <text>[好房评测]</text> {{item.title}} </text>
          <text class="price">{{item.block_info.item_total_price_max}}万-{{item.block_info.item_total_price_min}}万</text>
      </view>
      <block wx:else>
        <view class="price">
          <text class="title"> <text>[板块评测]</text> {{item.title}} </text>
          <text class="price">均价{{item.block_info.block_average_price}}万</text>
        </view>

      </block >

      <view class="desc" wx:if="{{item.desc}}"> {{ item.desc }} </view>

      <mytags right max="4" items="{{item.tags_list}}"></mytags>

    </view>
  </navigator>
  </view>

</template>
