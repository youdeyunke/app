<template name="detail-meta">
  <block>
      <view  class="detail-meta {{post.group}}">

        <block wx:if="{{post.group == 'new'}}">
                <view class="meta">
                  <text class="label">类型</text>
                  <text class="price">{{ post.cat.name}}</text>
                 </view>

                <view class="meta" wx:if="{{post.open_at_unknow == false }}">
                    <text class="label">开盘</text>
                    <text> {{ post.open_at }}</text>
                </view>
                <view class="meta lg">
                  <text class="label">地址</text>
                  <text>{{ post.address }} {{post.street}}</text>
                </view> 

        </block>

        <block wx:if="{{post.group == 'old' }}">
        </block>

        <block wx:if="{{post.group == 'rental' }}">
                <view class="meta">
                  <text class="label">类型</text>
                  <text class="price">{{ post.cat.name}}</text>
                 </view>

                <view class="meta">
                  <text class="label">朝向</text>
                  <text class="price">{{ post.position }}</text>
                 </view>

                <view class="meta">
                  <text class="label">楼层</text>
                  <text>第{{ post.current_floor }}层/ 共{{ post.total_floor }}层</text>
                </view> 

                <view class="meta" wx:if="{{post.has_lift != null }}">
                  <text class="label">电梯</text>
                  <text>{{ post.has_lift == true ? '有' : '无' }}</text>
                </view> 

                <view class="meta">
                  <text class="label">小区</text>
                  <text>{{ post.area_name }}</text>
                </view> 

                <view class="meta" wx:if="{{post.min_rent_month > 0}}">
                  <text class="label">起租</text>
                  <text>{{ post.min_rent_month }}个月起租</text>
                </view> 
        </block>

      </view>
  </block>
</template>
