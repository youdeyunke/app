<template name="form-rental">
  <block>
    <card title="地址" wx:if="{{step==1}}" subtitle="门牌号保密，仅管理员可见" hat>
      <van-field placeholder="请选择" error="{{error.district_id}}" input-align="right" disabled bindtap="showCityPicker" is-link label="城市" value="{{post.city.name || '请选择'}} {{post.district.name}}" arrow-direction="down" />
      <van-field value="{{ value }}" name="area_name" error="{{error.area_name}}" label="小区" input-align="right" placeholder="请输入小区名称" bind:change="inputChange" />
      <van-field name="street" value="{{ value }}" input-align="right" error="{{error.street}}" label="街道" placeholder="如：巨峰路1028弄55号" bind:change="inputChange" />
      <van-field name="house_number" value="{{ value }}" input-align="right" label="门牌号" placeholder="如：55号楼 1002室" bind:change="inputChange" />
    </card>

    <card title="户型信息" hat wx:if="{{step==1}}">
      <van-field value="{{ value }}" label="面积" input-align="right" error="{{error.area}}" type="number" placeholder="平米" name="area" bind:change="inputChang" />

      <van-field name="rent_price" error="{{error.rent_price}}" value="{{ value }}" input-align="right" label="租金" type="number" placeholder="元" bind:change="inputChange" />

      <picker bindchange="minRentMonthChange" range-key="label" range="{{minRentMonthItems}}" value="0">
        <van-cell title="起租" is-link value="{{post.min_rent_month >0 ? post.min_rent_month + '个月' : '' }}" input-align="right">
        </van-cell>
      </picker>

      <van-field bindtap="showTypePicker" is-link error="{{error.type}}" input-align="right" label="户型" value="{{post.w}}室-{{post.t}}厅-{{post.w}}卫 {{ post.position}}" arrow-direction="down" disabled />
      <van-field bindtap="showFitmentPicker" error="{{error.fitment_id}}" is-link input-align="right" label="装修" value="{{post.fitment.name || '请选择'}}" arrow-direction="down" disabled />

      <van-field bindtap="showFloorPicker" is-link input-align="right" error="{{error.floor}}" label="楼层" value="第{{post.current_floor || '几'}}层-共{{post.total_floor || '几'}}层 {{post.has_lift == true ? '有' : '无'}}电梯" arrow-direction="down" disabled />
      <van-field bindtap="showPayment" error="{{error.payment_cycle}}" is-link input-align="right" label="付款类型" value="{{post.payment_cycle || '请选择'}}" arrow-direction="down" disabled />
      <van-switch-cell title="服务费" name="service_charge_enable" checked="{{post.service_charge_enable}}" bindchange="serviceChargeEnableChange" />
      <van-field wx:if="{{post.service_charge_enable}}" name="service_charge" value="{{ post.service_charge }}" input-align="right" label="收费标准" placeholder="请输入" />
    </card>

    <card title="房源详情" hat wx:if="{{step == 2}}">
      <van-field label="房源介绍" value="{{post.desc}}" placeholder="选填" name="desc" autosize />
      <van-field label="出租要求" value="{{post.rent_limit}}" placeholder="选填" name="rent_limit" autosize />
      <van-field label="周边配套" value="{{post.surrounding}}" placeholder="选填" name="surrounding" autosize />
    </card>




  </block>
</template>
