<template name="form-rental">
  <block>
    <card title="出租类型" hat wx:if="{{step==1 }}">
      <van-radio-group value="{{post.rent_type}}">
      <van-cell title="整租" bind:click="rentTypeClick" clickable data-name="zhengzu"  >
        <van-radio name="zhengzu" />
      </van-cell>
      <van-cell title="合租" bind:click="rentTypeClick" clickable data-name="hezu"  >
        <van-radio name="hezu" />
      </van-cell>   
      </van-radio-group>   
    </card>

    <card title="地址" wx:if="{{step==1}}" subtitle="门牌号保密，仅管理员可见" hat>
      <van-field  error="{{error.district_id}}" input-align="right" disabled bindtap="showCityPicker" is-link label="城市" value="{{post.city.name || '请选择'}} {{post.district.name}}" arrow-direction="down" />
      <van-field value="{{ post.area_name }}" data-name="area_name" error="{{error.area_name}}" label="小区" input-align="right" placeholder="请输入小区名称" bind:change="inputChange" />
      <van-field data-name="street" value="{{ post.street }}" input-align="right" error="{{error.street}}" label="街道" placeholder="如：巨峰路1028弄55号" bind:change="inputChange" />
      <van-field data-name="house_number" value="{{ post.house_number }}" input-align="right" label="门牌号" placeholder="如：55号楼 1002室" bind:change="inputChange" />
    </card>

    <card title="户型信息" hat wx:if="{{step==1}}">
      <van-field value="{{ post.area }}" label="面积" input-align="right" error="{{error.area}}" type="number" placeholder="平米" data-name="area" bind:change="inputChange" />

      <van-field data-name="rent_price" error="{{error.rent_price}}" value="{{ post.rent_price}}" input-align="right" label="租金" type="number" placeholder="元" bind:change="inputChange" />

      <picker bindchange="minRentMonthChange" range-key="label" range="{{minRentMonthItems}}" value="{{post.min_rent_month || 0 }}">
        <van-cell title="起租" is-link value="{{post.min_rent_month >0 ? post.min_rent_month + '个月' : '' }}" input-align="right">
        </van-cell>
      </picker>

      <van-field bindtap="showTypePicker" is-link error="{{error.type}}" input-align="right" label="户型" value="{{post.w}}室-{{post.t}}厅-{{post.w}}卫 {{ post.position}}" arrow-direction="down" disabled />
      <van-field bindtap="showFitmentPicker" error="{{error.fitment_id}}" is-link input-align="right" label="装修" value="{{post.fitment.name || '请选择'}}" arrow-direction="down" disabled />

      <van-field bindtap="showFloorPicker" is-link input-align="right" error="{{error.floor}}" label="楼层" value="第{{post.current_floor || '几'}}层-共{{post.total_floor || '几'}}层 {{post.has_lift == true ? '有' : '无'}}电梯" arrow-direction="down" disabled />
      <van-field bindtap="showPayment" error="{{error.payment_cycle}}" is-link input-align="right" label="付款类型" value="{{post.payment_cycle || '请选择'}}" arrow-direction="down" disabled />
      <van-switch-cell title="服务费" data-name="service_charge_enable" checked="{{post.service_charge_enable}}" bindchange="serviceChargeEnableChange" />
      <van-field 
              wx:if="{{post.service_charge_enable}}" 
              error="{{error.service_charge}}"
              data-name="service_charge" 
              value="{{ post.service_charge }}" 
              input-align="right" 
              label="收费标准" 
              placeholder="请输入" 
              bind:change="inputChange" />
    </card>

    <card title="房源详情" hat wx:if="{{step == 2}}">
      <van-field label="房源介绍" bind:change="inputChange" value="{{post.desc}}" placeholder="选填" data-name="desc" autosize />
      <van-field label="出租要求" bind:change="inputChange" value="{{post.rent_limit}}" placeholder="选填" data-name="rent_limit" autosize />
      <van-field label="周边配套" bind:change="inputChange" value="{{post.surrounding}}" placeholder="选填" data-name="surrounding" autosize />
    </card>

  </block>
</template>
