<template name="miniposts">

        <navigator wx:for="{{posts}}" class="post" open-type="navigate" url="/pages/post/post?id={{item.id}}" >
      <view class="cover">
              <image class="i" src="{{ item.cover.url }}?imageView2/2/w/250"></image>
        <image wx:if="{{false}}" class="play-btn" src="/assets/images/play-btn.png"></image>
      </view>
      <view class="meta">
              <text class="item-title">{{ item.title }}</text>
        <view class="mini-tags">
        <text wx:for="{{item.tags_list}}" wx:for-item="tag">{{tag}}</text>
        </view>

        <view class="location">
          {{item.block_info.district.name}} {{item.block_info.name}}
        </view>
        
        <view class="area-price">
           <text class="area" wx-if="{{item.block_info.item_layout}}">{{ item.block_info.item_layout }}</text>
           <text class="price" wx-if="{{item.block_info.item_price}}">{{ item.block_info.item_price }} 元/㎡</text>
        </view>
      </view>
    </navigator>

</template>
