.post-mini .tags {
  font-size:20rpx;
  color: 333;
}


.post-mini .post{
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom:20rpx;
  padding-bottom:20rpx;
  border-bottom:1px solid #f4f4f4;
}

.post-mini .post .cover{
  position: relative;
  width:266rpx;
  height: 184rpx;  
}

.post-mini .post .badge{
    position: absolute;
    color: #fff;
    background-color: #FA5741;  
    left:-10rpx;
    bottom:20rpx;
    padding:10rpx 15rpx;
    line-height: 100%;
    box-sizing: border-box;
    max-width: 266rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;    
}

.post-mini .post .badge-arrow{
  width: 10rpx;
  height: 10rpx;
  position: absolute;
  left: -9rpx;
  bottom: 10rpx;
}


.post-mini .post .cover .i{
  width:100%;
  height: 100%;
}

.post-mini .post .play-btn{
  position: absolute;
  width:36rpx;
  height: 36rpx;
  left:calc(266rpx * 0.5 - 36rpx * 0.5);
  top:calc(184rpx * 0.5 - 36rpx * 0.5);

}

.post-mini .post .meta{
  width:390rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.post-mini .post .meta .item-title{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width:320rpx;
  font-size:24rpx;
  color: #000;
  font-weight: bold;

}


.post-mini .post .meta .area-price{
  font-size:24rpx;
  display: flex;
  justify-content: space-between; 
}

.post-mini .post .meta .location{
  font-size:24rpx;
}

.post-mini .post .meta .area-price .area{
  color:#000;
}

.post-mini .post .meta .area-price .price{
    color: orangered;
    font-weight: bold;
}
.post-mini mytags .tag{
}


@import "/components/tags.wxss";
