<template name="qa-item">

    <view class="qa-item container">
      <view class="body">
        <view class="content h1 question" bindtap="itemHandle" data-qid="{{item.id}}">

          <text class="main"> 
          
          {{item.content}}</text>
        </view>    

        <view class="author">
          <view class="name">
           
                <text class="line-limit nickname">{{item.user.nickname}}</text>            
                <text>在{{item.created_at_pretty }}咨询：</text>          
          </view>        
        <view>
                               
          </view>           
        </view>      
          
      </view>

      <view class="line" wx:if="{{item.answer}}"></view>
      <view class="body" wx:if="{{item.answer}}">

          <view class="content h1 answer" bindtap="itemHandle" data-qid="{{item.id}}">
            <text class="main answer-text">  {{item.answer}}</text>
          </view>


          <view class="author">
            <view class="name">                 
              <text>{{item.admin_user.name}}</text>
              <text>回复：</text>
            </view>
            <view>
 
            </view>          
          </view>
      </view>
    
    </view>
</template>