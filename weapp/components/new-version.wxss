.new-version-window{
  width:600rpx;
  height:929rpx;
  background:none;
  position:relative;
}

.new-version-window image.bg{
  width:100%;
  height:100%;
  position:absolute;
  left:0;
  right:0;
  top:0;
  bottom:0;
}

.new-version-window .close{
  display:block;
  z-index:999;
  position:absolute;
  width:60rpx;
  height:60rpx;
  border-radius:60rpx;
  right:39rpx;
  top:36rpx;
}

.new-version-window .close-text{
  display:block;
  z-index:999;
  position:absolute;
  width:120rpx;
  height:40rpx;
  line-height:40rpx;
  border-radius:0rpx;
  right:39rpx;
  padding:4rpx;
  text-align: center;
  top:36rpx;
  color:#fff;
  background:rgba(0,0,0, 0.5);

}

.new-version-window .confirm{
  display:block;
  z-index:999;
  position:absolute;
  width:60rpx;
  height:60rpx;
  border-radius:60rpx;
  left:130rpx;
  right:130rpx;
  bottom:40rpx;
  width:340rpx;
  height:80rpx;
  border-radius:40rpx;
  z-index:999;
}

.new-version-window .title{
  display:block;
  z-index:999;
  position:absolute;
  width:100%;
  height:70rpx;

  left:0rpx;
  right:0rpx;
  top:98rpx;
  z-index:999;
  color:#fff;
  font-size:50rpx;
  text-align:center;
}


.new-version-window .sub-title{
  display:block;
  z-index:999;
  position:absolute;
  width:100%;
  height:70rpx;

  left:0rpx;
  right:0rpx;
  top:172rpx;
  z-index:999;
  color:#fff;
  font-size:28rpx;
  text-align:center;
}

.new-version-window .desc{
  display:block;
  z-index:999;
  position:absolute;
  width:480rpx;
  left:60rpx;
  right:60rpx;
  top:237rpx;
  z-index:999;
  color:#fff;
  font-size:28rpx;
  line-height:1.4;
}
