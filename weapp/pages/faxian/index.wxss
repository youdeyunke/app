/* pages/faxian/index.wxss */
.top-box {
  /* position: sticky; */
  top: 0;
  left: 0;
  z-index: 5;
  width: 100%;
}
.top-box .van-tabs__scroll{
  background: rgba(0, 0, 0, 0);
}
.search{
  background: rgba(0, 0, 0, 0) !important;
}
.tab-box{
  margin-top: 10rpx;padding-top: 5rpx;border-radius: 30rpx 30rpx 0 0 ;background: #fff;min-height: 300rpx;
}
.header {
  background-size: 750rpx 410rpx;
  background-repeat: no-repeat;
  width: 750rpx;
  height: 410rpx;
  
  position: absolute;
  top: 0;
  z-index: -1;
}

.res {
  width: 750rpx;
  box-sizing: border-box;
}

.qa-new {
  position: fixed;
  bottom: 20rpx;
  width: 200rpx;
  left: calc(50% - 100rpx);
  z-index: 10;
}