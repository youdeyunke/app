/* pkgZhuli/pages/zhuli/index.wxss */

page {
  background-color: linear-gradient(180deg, #A84343 0%, #8C3434 100%);

  padding-bottom:120rpx;
  padding-top:300rpx;
  height: 100%;
  background-image: url('https://qiniucdn.udeve.net/fang/zhuli-bg.png?t=2');
  background-size: 100% 100%;
}

.tm{
  position:fixed; 
  top:0; 
  left:0;
  z-index:100;
  width:750rpx;
}

.body {
  width: 750rpx;
  height: auto;
  padding-top: 20rpx;
  margin-bottom:120rpx;
}

.rule{
  font-size: 24rpx; 
  color:#666;
}

.rule-item{
  padding:4rpx 6rpx;
}

.footer {
  height: 90rpx;
  position: fixed;
  bottom: 20rpx;
  left: 0;
  width: 750rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.footer .btn {
  line-height: 90rpx;
  text-align: center;
  width: 317rpx;
  height: 90rpx;
  font-size: 28rpx;
  color: #fff;
 
  border-radius: 45rpx;
}
.footer .btn.share{
  position:relative;
  background: linear-gradient(180deg, #FFAC70 0%, #FEA05B 49.27%, #FE9243 100%);
 
}

.footer .btn.share .fake {
  width: 100%; 
  height: 100%; 
  position: absolute; 
  top:0; 
  left:0;
  opacity: 0;
}

.footer .btn.join{
  background: linear-gradient(180deg, #FF7373 0%, #F97373 49.27%, #D84848 100%);

}