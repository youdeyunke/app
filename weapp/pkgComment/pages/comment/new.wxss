page {
    padding-top: 0rpx;
}

textarea {
    padding: 20rpx;
    font-size: 32rpx;
    box-sizing: border-box;
    background: #f8f8f8;
    width: 100%;
    border-radius: 6rpx;
}

.actions {
    width: 100%;
    margin: 30rpx auto 0 auto;
}

.counter {
    position: absolute;
    right: 10rpx;
    bottom: 10rpx;
    font-size: 28rpx;
    color: #cecece;
}

.tags {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
}

.tag-item {
    height: 52rpx;
    background: #f4f4f4;
    border-radius: 52rpx;
    padding: 0 20rpx;
    text-align: center;
    line-height: 52rpx;
    margin-right: 20rpx;
    font-size: 24rpx;
    color: #333333;
    margin-bottom: 20rpx;
}

.tag-item.active {
    color: #528af4;
    background: #e6f4ff;
}

.score {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 20rpx;
}

.title {
    font-size: 28rpx;
    color: #333;
    margin-bottom: 20rpx;
}

.title.center {
    text-align: center;
}