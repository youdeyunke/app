<image wx:if="{{item.cover }}"  
class="cover" src="{{item.cover }}?imageView2/2/w/750"></image>
<box padding="10" margin-bottom="2" >
  <view class="header">
    <view class="h1">{{item.title}}</view>
    <van-cell icon="clock-o" label="集合时间" size="mini" value-class="mycell-value" value="{{item.starts_at_pretty}}" />
    <van-cell icon="flag-o" label="集合地点" value="{{item.address  }}" value-class="mycell-value"  />
    <van-cell icon="sign" label="报名截止" value="{{item.ends_at_pretty   }}" value-class="mycell-value"  />
    <van-cell icon="friends-o" label="已报人数" value="{{item.join_nums   }}" value-class="mycell-value"  />
    <van-cell border="{{false}}" is-link icon="contact" label="联系人" value="{{item.server_name }} {{ item.server_mobile}}" bindtap="callHandle" value-class="mycell-value"  />
  </view>
</box>

<mycard title="活动介绍" hat="{{false}}">
  <view class="raw">
      <rich-text  nodes="{{html}}" />
  </view>
</mycard>

<view class="footer" hidden="{{item.status.value != 1 }}">
    <van-button open-type="share" icon="good-job" type="primary" block >转发分享</van-button>
    <van-button  plain="{{joined}}" bindtap="joinHandle" icon="{{ joined == true ? 'passed' : 'add-o' }}" type="info" block >{{ joined == true ? '我已报名' : '我要报名' }}</van-button>
</view>

<view class="footer" hidden="{{item.status.value != 2 }}">
    <van-button open-type="share" icon="good-job" type="primary" block >转发分享</van-button>
    <van-button  plain  icon="close" type="info" block >报名已截止</van-button>
</view>

