
<view class="container">


<view class="box">
  <view class="title">{{ item.title }}</view>
  <view class="main-flex-column-bottom">
    <view class="main-bottom">活动时间: {{item.starts_at_pretty}} ~ {{ item.ends_at_pretty}}</view>
    <view class="main-bottom">活动地点: {{ item.address }} </view>
    <view wx:if="{{item.master}}" class="main-bottom">主办方: {{ item.master || '' }} </view>
  </view>

  <raw-html class="introduce-flex-column-middle" html="{{item.content}}"></raw-html>
</view>

<ud-card title="关联项目" wx:if="{{post}}">
  <post-item post="{{post}}"></post-item>
</ud-card>

<!-- 底部分享 -->



<!-- 报名弹窗 -->
<van-popup closeable bind:close="formClose" position="bottom" round title="活动报名" show="{{showForm}}">
  <view class="form">

    <van-field label="联系人" model:value="{{name}}" placeholder="请输入联系人姓名"></van-field>
    <!-- <van-field label="人数" model:value="{{numbers}}" placeholder="您有几人参加"></van-field> -->
    <van-field disabled="{{mobile_lock}}" label="手机号" placeholder="" model:value="{{mobile}}" use-button-slot>
        <sms-button wx:if="{{!mobile_lock}}"  slot="button" mobile="{{mobile}}" />
        <van-button wx:if="{{mobile_lock}}" slot="button" size="small" type="primary" bindtap="mobileChange" plain>修改号码</van-button>
    </van-field>
    <van-field wx:if="{{!mobile_lock}}" label="验证码" model:value="{{ sms_code }}" placeholder="短信验证码"></van-field>
    <!-- <van-field label="备注" model:value="{{remark}}" placeholder="其它备注信息"></van-field> -->
    <block wx:if="{{brokerId && brokerPhone}}">
      <van-field label="邀约顾问" disabled="true" value="{{brokerName}} {{ brokerPhone}}" ></van-field>
    </block>
    <view class="footer">
      <van-button custom-style="margin-bottom:10rpx;" block bindtap="formClose" color="{{primaryBtnColor}}">取消</van-button>
      <van-button block disabled="{{loading}}" color="{{primaryBtnColor}}" type="primary" bindtap="formSubmit">确定报名</van-button>
    </view>

  </view>
</van-popup>

<!-- 底部分享 -->
<view class="content-bottom" wx:if="{{item.status_value == 'full'}}">
  <view class="bacconttent-bottom">
    <view class="bottom-collection" bindtap="moveHome">
      <van-icon class="font-top" name="wap-home-o" />
      <view class="font-bottom">首页</view>
    </view>
    <view class="bottom-share bottom-collection">
      <van-icon class="font-top" name="share" />
      <view class="font-bottom" open-type="share">分享</view>
      <button class="bottom-share-two" open-type="share"></button>
    </view>
    <view class="bottom-button-right bottom-button-common">
      <view style="background: {{primaryBtnColor}};" wx:if="{{joined}}" bindtap="cancleJoin">已满员(取消报名)</view>
      <view style="background: {{primaryBtnColor}};" wx:else>已满员</view>
    </view>
  </view>
</view>

<!-- 底部分享 -->
<view class="content-bottom" wx:if="{{item.status_value == 'active' || item.status_value == 'comming'}}">
  <view class="bacconttent-bottom">
    <view class="bottom-collection" bindtap="moveHome">
      <van-icon class="font-top" name="wap-home-o" />
      <view class="font-bottom">首页</view>
    </view>
    <view class="bottom-share bottom-collection">
      <van-icon class="font-top" name="share" />
      <view class="font-bottom" open-type="share">分享</view>
      <button class="bottom-share-two" open-type="share"></button>
    </view>
    <view class="bottom-button-right bottom-button-common">
      <view wx:if="{{joined}}" style="background: {{primaryBtnColor}};" bindtap="cancleJoin">取消报名</view>
      <view wx:else bindtap="joinHandle" style="background: {{primaryBtnColor}};">我要报名</view>
    </view>
  </view>
</view>


<!-- 底部分享 -->
<view class="content-bottom" wx:if="{{item.status_value == 'end' }}">
  <view class="bacconttent-bottom">
    <view class="bottom-collection" bindtap="moveHome">
      <van-icon class="font-top" name="wap-home-o" />
      <view class="font-bottom">首页</view>
    </view>
    <view class="bottom-share bottom-collection">
      <van-icon class="font-top" name="share" />
      <view class="font-bottom" open-type="share">分享</view>
      <button class="bottom-share-two" open-type="share"></button>
    </view>
    <view class="bottom-button-right bottom-button-common">
      <view style="background: {{primaryBtnColor}};">报名已截止</view>
    </view>
  </view>
</view>

<view class="container-bottom"></view>
</view>