<van-cell-group title="扫码签到">

  <van-field model:value="{{name}}" placeholder="请填写姓名" label="姓名"/>

  <van-field disabled="{{mobile_lock}}"  model:value="{{mobile}}" placeholder="请填写姓名" label="手机号"/>
</van-cell-group>



<view class="footer">


<van-button bindtap="signHandle" type="primary" block>确认签到</van-button>

</view>

<login-window bind:success="loginSuccess" class="loginwindow"></login-window>