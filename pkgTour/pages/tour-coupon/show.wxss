/* pkgTour/pages/tour-coupon/show.wxss */
page{
    background: linear-gradient(180deg, #FF3900, #FF6300, #F83F4A);
}
.container {
    /* background-color: #EEEEEE; */
    background-size: 750rpx 840rpx;
    background-image: url('https://qiniucdn.udeve.cn/fang2021/f6099ade-e061-4fac-9105-623b88ea7030.png');
    background-repeat: no-repeat;
  }
  
  .box{
    width:750rpx; 
    padding:30rpx;
    /* background:#fff; */
    box-sizing: border-box;
  }
  
  .box .title{
    font-size:32rpx; 
    color:#333; 
    font-weight: bold;
    margin-bottom:20rpx;
  }
  
  .main-flex-column {
    display: flex;
    flex-direction: column;
    padding: 0 0 20rpx 0;
    background-color: #ffffff;
  }
  
  .contentA-flex-column-top image {
    width: 750rpx;
    height: 420rpx;
  }
  
  /* 内容 */
  .main-flex-column-middle {
    margin-top: 31rpx;
    display: flex;
  }
  
  .main-flex-row-left {
    margin-left: 30rpx;
    display: flex;
    flex-direction: column;
  }
  
  .main-title-top {
    font-size: 30rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  .main-title-bottom {
    margin-top: 30rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #B20700;
  }
  
  .main-flex-row-right {
    width: 100rpx;
    height: 52rpx;
    background: #FFFFFF;
    border: 1rpx solid #EE1313;
    border-radius: 4rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #EE1313;
    text-align: center;
    line-height: 52rpx;
  }

  
  /* 活动介绍 */
  .introduce-flex-column {
    margin-top: 24rpx;
    padding: 50rpx 30rpx 55rpx 30rpx;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
  }
  
  .introduce-flex-column-top {
    font-size: 32rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  /* 关联项目 */
  .content-flex-column {
    padding: 24rpx 30rpx 0 30rpx;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
  }
  
  .content-flex-column-top {
    padding-top: 49rpx;
    padding-bottom: 41rpx;
    font-size: 32rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  .content-flex-column-middle {
    display: flex;
    justify-content: space-between;
  }
  
  .content-flex-row-left {
    width: 240rpx;
    height: 190rpx;
    background-color: pink;
    display: flex;
    border-radius: 8rpx;
  }
  
  .content-flex-row-left image {
    margin: 152rpx 12rpx 0 12rpx;
    width: 26rpx;
    height: 26rpx;
  }
  
  .content-flex-row-left view {
    margin-top: 152rpx;
    font-size: 24rpx;
    font-weight: 400;
    color: #FFFFFF;
  }
  
  
  .content-flex-row-right {
    width: 420rpx;
    display: flex;
    flex-direction: column;
  }
  
  .content-flex-top {
    font-size: 32rpx;
    font-weight: bold;
    color: #333333;
  }
  
  .content-flex-middle-top {
    display: flex;
    margin: 16rpx 0 0 0;
    font-size: 26rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #666666;
  }
  
  .content-flex-middle-bottom {
    display: flex;
    margin: 17rpx 0 0 0;
  }
  
  .content-status {
    display: flex;
    margin-right: 10rpx;
    height: 34rpx;
    background: #FFF2E6;
    border-radius: 4rpx;
    align-items: center;
    justify-content: center;
  }
  
  .content-status view {
    margin-left: 10rpx;
    margin-right: 10rpx;
    font-size: 20rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #FF9935;
  }
  
  .content-status:first-child {
    height: 34rpx;
    background: #CCCCCC;
    border-radius: 4rpx;
  }
  
  .content-status:first-child view {
    font-size: 20rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #FFFFFF;
  }
  
  .content-flex-bottom {
    margin-top: 20rpx;
    font-size: 26rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #B20700;
  }
  
  
  
  .content-flex-column-bottom {
    margin: 20rpx 30rpx 0 30rpx;
    height: 30rpx;
    border-bottom: 1px solid #DDDDDD;
  }
  
  .content-flex-middle-bottom .content-status-two {
    background: #FFF2E6;
  }
  
  .content-flex-middle-bottom .content-status-two view {
    color: #FF9935;
  }
  
  .container-bottom {
    height: 100rpx;
  }
  
  /* 底部 */
  .content-bottom {
    position: fixed;
    bottom: 0rpx;
    width: 100%;
    height: 140rpx;
    margin-top: 17rpx;
    background-color: #F83F4A;
  }
  
  .bacconttent-bottom {
    display: flex;
    flex-direction: row;
    margin: 0 30rpx 0 30rpx;
    justify-content: space-between;
    align-items: center;
  }
  
  .bottom-collection {
    margin-top: 11rpx;
  }

  .font-top {
    width: 76rpx;height: 76rpx;margin: 0 auto;display: block;
  }
  
  .font-bottom {
    font-size: 24rpx;color: #FFF;margin-top: 10rpx;
  }
  
  .bottom-button-common {
    width: 420rpx;height: 96rpx;border-radius: 48rpx;background: linear-gradient(0deg, #FF9600, #FFD513);font-size: 36rpx;color: #FFF;font-weight: bold;line-height: 96rpx;text-align: center;
  }
  

  
  .bottom-share-two {
    position: absolute;
    top: 21rpx;
    left: 142rpx;
    width: 50rpx;
    height: 71rpx;
    z-index: 3;
    background-color: transparent;
    border: none;
  }
  
  .bottom-share-two::after {
    border: none;
  }
  
  .form{
    width:750rpx;
    box-sizing: border-box;
    padding:50rpx 30rpx 30rpx 30rpx;
  }
  
  .form .footer{
    margin-top:20rpx;
  }
  .huodong-card{
    width: 690rpx;border-radius: 20rpx;margin-bottom: 30rpx;background-color: #FFF;padding: 35rpx;
  }
  .huodong-card-title{
    width: 286rpx;height: 56rpx;background-image: url('https://qiniucdn.udeve.cn/fang2021/3c505d6f-5e49-420b-9aa5-f82aa7b8006d.png');background-size: 286rpx 56rpx;text-align: center;font-size: 40rpx;font-weight: bold;margin: 0 auto;margin-bottom: 30rpx;
  }