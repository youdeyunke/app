/* pkgTour/pages/tour-coupon/show.wxss */
.container {
    background-color: #EEEEEE;
  }
  
  .box{
    width:750rpx; 
    padding:20rpx;
    background:#fff;
    box-sizing: border-box;
  }
  
  .box .title{
    font-size:32rpx; 
    color:#333; 
    font-weight: bold;
    margin-bottom:20rpx;
  }
  
  .main-flex-column {
    display: flex;
    flex-direction: column;
    padding: 0 0 20rpx 0;
    background-color: #ffffff;
  }
  
  .contentA-flex-column-top image {
    width: 750rpx;
    height: 420rpx;
  }
  
  /* 内容 */
  .main-flex-column-middle {
    margin-top: 31rpx;
    display: flex;
  }
  
  .main-flex-row-left {
    margin-left: 30rpx;
    display: flex;
    flex-direction: column;
  }
  
  .main-title-top {
    font-size: 30rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  .main-title-bottom {
    margin-top: 30rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #B20700;
  }
  
  .main-flex-row-right {
    width: 100rpx;
    height: 52rpx;
    background: #FFFFFF;
    border: 1rpx solid #EE1313;
    border-radius: 4rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #EE1313;
    text-align: center;
    line-height: 52rpx;
  }
  
  .main-flex-column-bottom {
    display: flex;
    margin-bottom:30rpx;
    flex-direction: column;
  }
  
  .main-bottom {
    margin-top: 8rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #666666;
  }
  
  /* 活动介绍 */
  .introduce-flex-column {
    margin-top: 24rpx;
    padding: 50rpx 30rpx 55rpx 30rpx;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
  }
  
  .introduce-flex-column-top {
    font-size: 32rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  .introduce-flex-column-middle {
    margin-top: 37rpx;
    font-size: 28rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #333333;
  }
  
  
  /* 关联项目 */
  .content-flex-column {
    padding: 24rpx 30rpx 0 30rpx;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
  }
  
  .content-flex-column-top {
    padding-top: 49rpx;
    padding-bottom: 41rpx;
    font-size: 32rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #333333;
  }
  
  .content-flex-column-middle {
    display: flex;
    justify-content: space-between;
  }
  
  .content-flex-row-left {
    width: 240rpx;
    height: 190rpx;
    background-color: pink;
    display: flex;
    border-radius: 8rpx;
  }
  
  .content-flex-row-left image {
    margin: 152rpx 12rpx 0 12rpx;
    width: 26rpx;
    height: 26rpx;
  }
  
  .content-flex-row-left view {
    margin-top: 152rpx;
    font-size: 24rpx;
    font-weight: 400;
    color: #FFFFFF;
  }
  
  
  .content-flex-row-right {
    width: 420rpx;
    display: flex;
    flex-direction: column;
  }
  
  .content-flex-top {
    font-size: 32rpx;
    font-weight: bold;
    color: #333333;
  }
  
  .content-flex-middle-top {
    display: flex;
    margin: 16rpx 0 0 0;
    font-size: 26rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #666666;
  }
  
  .content-flex-middle-bottom {
    display: flex;
    margin: 17rpx 0 0 0;
  }
  
  .content-status {
    display: flex;
    margin-right: 10rpx;
    height: 34rpx;
    background: #FFF2E6;
    border-radius: 4rpx;
    align-items: center;
    justify-content: center;
  }
  
  .content-status view {
    margin-left: 10rpx;
    margin-right: 10rpx;
    font-size: 20rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #FF9935;
  }
  
  .content-status:first-child {
    height: 34rpx;
    background: #CCCCCC;
    border-radius: 4rpx;
  }
  
  .content-status:first-child view {
    font-size: 20rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #FFFFFF;
  }
  
  .content-flex-bottom {
    margin-top: 20rpx;
    font-size: 26rpx;
    font-family: Source Han Sans CN;
    font-weight: bold;
    color: #B20700;
  }
  
  
  
  .content-flex-column-bottom {
    margin: 20rpx 30rpx 0 30rpx;
    height: 30rpx;
    border-bottom: 1px solid #DDDDDD;
  }
  
  .content-flex-middle-bottom .content-status-two {
    background: #FFF2E6;
  }
  
  .content-flex-middle-bottom .content-status-two view {
    color: #FF9935;
  }
  
  .container-bottom {
    height: 100rpx;
  }
  
  /* 底部 */
  .content-bottom {
    position: fixed;
    bottom: 0rpx;
    width: 100%;
    height: 110rpx;
    margin-top: 17rpx;
    background-color: #FFFFFF;
  }
  
  .bacconttent-bottom {
    display: flex;
    flex-direction: row;
    margin: 0 30rpx 0 30rpx;
  }
  
  .bottom-collection {
    margin-top: 11rpx;
    width: 56rpx;
    height: 80rpx;
  }
  
  .bottom-share {
    margin-top: 11rpx;
    margin-left: 54rpx;
    margin-right: 32rpx;
    width: 56rpx;
    height: 80rpx;
  }
  
  .font-top {
    width: 52rpx;
    height: 52rpx;
  }
  
  .font-bottom {
    margin-left: 8rpx;
    float: left;
    width: 50rpx;
    height: 19rpx;
    font-size: 20rpx;
    font-family: Source Han Sans CN;
    font-weight: 400;
    color: #666666;
    line-height: 30rpx;
  }
  
  .bottom-button-common {
    margin-top: 17rpx;
    margin-left: 24rpx;
    width: 470rpx;
    height: 74rpx;
  }
  
  .bottom-button-left {
    background-color: #FF9834;
  }
  
  .bottom-button-left view {
    font-size: 30rpx;
    font-weight: 400;
    color: #FFFFFF;
    line-height: 74rpx;
    text-align: center;
  }
  
  .bottom-button-right {
    background-color: #B20700;
  }
  
  .bottom-button-right view {
    font-size: 30rpx;
    font-weight: 400;
    color: #FFFFFF;
    line-height: 74rpx;
    text-align: center;
  }
  
  .bottom-share-two {
    position: absolute;
    top: 21rpx;
    left: 142rpx;
    width: 50rpx;
    height: 71rpx;
    z-index: 3;
    background-color: transparent;
    border: none;
  }
  
  .bottom-share-two::after {
    border: none;
  }
  
  .form{
    width:750rpx;
    box-sizing: border-box;
    padding:50rpx 30rpx 30rpx 30rpx;
  }
  
  .form .footer{
    margin-top:20rpx;
  }