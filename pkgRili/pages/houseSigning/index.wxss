page {
    height: 100%;
    width: 100%;
    background: #FFF;
    --primary-color: #9e1d1d;
}

.header {
    width: 750rpx;
    height: 300rpx;
    /* background-image: url(https://qiniucdn.udeve.cn/fang2021/c90c767f-4b8a-4ce2-ac5a-f23968094f40.png); */
    background-size: 100% 100%;
    padding-top: 75rpx;
}

.header-goback {
    width: 50rpx;
    height: 50rpx;
    position: absolute;
    top: 100rpx;
    left: 20rpx;
}

.header-title {
    width: 610rpx;
    height: 50rpx;
    margin: 0 auto;
    /* display: flex;
    justify-content: space-between;
    align-items: center; */
    font-size: 46rpx;
    font-weight: bold;
    text-align: center;
}

.header-yun {
    width: 80rpx;
    height: 40rpx;
}


.btn-row {
    height: 70rpx;
    line-height: 70rpx;
    font-size: 24rpx;
    margin-bottom: 20rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 90rpx;
}

.btn-row text {
    display: inline-block;
    height: 30rpx;
    text-align: center;
    line-height: 30rpx;
    font-weight: bold;
    font-size: 28rpx;
    /* color: #FFF; */
}

.btn-row view {
    font-weight: bold;
    font-size: 28rpx;
    /* color: #FFF; */
}

.week-row {
    width: 100%;
    height: 100rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 50rpx;
    background-color: #dddddd;
}

.week-item {
    /* width: 55rpx; */
    height: 50rpx;
    text-align: center;
    line-height: 50rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #333333;
}

.day-row {
    width: 690rpx;
    min-height: 70rpx;
    margin: 0 auto;
    /* border: 1rpx solid #999999; */
    border-radius: 8rpx;
    display: flex;
    justify-content: space-around;
    /* align-items: center; */
    margin-top: 20rpx;
}

.day-item {
    width: 90rpx;
    /* height: 70rpx; */
    min-height: 70rpx;
    text-align: center;
    line-height: 70rpx;
    font-size: 28rpx;
    font-weight: 400;
    color: #333333;
    box-sizing: border-box;
}

.day-today {
    background: #dddddd;
    border: 1rpx solid #CB1623;
    color: #CB1623;
}

.day-otherMonth {
    color: #cdcdcd;
    visibility: hidden;
}

.today-bg {
    /* width: 88rpx; */
    height: 30rpx;
    color: #FFF;
    background-color: #FFF;
    text-align: center;
    font-size: 24rpx;
    line-height: 30rpx;
}

.xiangm-item {
    width: 87rpx;
    /* height: 140rpx; */
    /* border: 1rpx solid #CCCCCC; */
    box-shadow: 0 0 10rpx #cfcfcf; /* 水平偏移量 垂直偏移量 模糊半径 阴影颜色 */
    color: #cb1623;
    font-weight: bold;
    border-radius: 6rpx;
    margin-top: 10rpx;
}

.xiangm-item-title {
    width: 84rpx;
    height: 40rpx;
    font-size: 20rpx;
    text-align: center;
    line-height: 40rpx;
    color: #FFF;
    background-color: #CB1623;
    border-radius: 6rpx 6rpx 0 0;
}

.xiangm-item-body {
    width: 84rpx;
    height: 100rpx;
    font-size: 20rpx;
    color: #333333;
    text-align: center;
    line-height: 26rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
}

.summary-container {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 30rpx;
}

.summary-icon {
  width: 10rpx;
  height: 30rpx;
  margin: 0 30rpx;
  border-radius: 5rpx;
}

.summary-text {
  flex: 1;
}

.tip {
  text-align: center;
  font-size: 20rpx;
  margin-top: 15rpx;
}

.spacer {
  height: 30rpx;
}
