
.header-block .bg{
    width:750rpx;
    height:750rpx; 
    z-index:-1;
    position: absolute;
    top:-266rpx;
    left:0;
}

.header-block {
    position: relative;
    width:750rpx; 
    height:300rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #000;
    letter-spacing: 2.5rpx;
    
}

.header-block .title {
    font-size: 48rpx;
    margin-bottom: 20rpx;
}

.header-block .desc{
    width:400rpx;
    text-align: center;
}

.window {  
    margin-top:100rpx;
    padding: 20rpx;
    box-sizing: border-box;
    border-radius: 20rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction:column;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
}


.window .submit-btn {
    width: 100%;
}

.window .result{
    display: flex;
    flex-direction:column;
    justify-content: flex-start;
    align-items: center;
    box-sizing: border-box;
}

.window .result .icon{
  margin-top:30rpx;
  margin-bottom:30rpx;
}

.window .result .title {
  font-size:40rpx;
  color:#000;
  font-weight: bolder;
  margin-bottom:40rpx;
}

.window .result .text{
  color:#000;
  font-size:28rpx;
}

.window .uploader{
  display:flex;
  flex-direction:column;
  justify-content:flex-start;
  align-items:center;
  margin-bottom:40rpx;
}


.plan {
    width: 100%;
    margin-top: 20rpx;
}

.steps {
    margin-top: 40rpx;
}

.form-header{
    margin:30rpx 30rpx 30rpx 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size:28rpx;
    border-bottom:2rpx solid #f9f9f9;

}

.form-header .submit {
    color:#1989FA;
}

.form-header .cancle{
    color:#333333;
}

    