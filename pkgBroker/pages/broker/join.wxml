<view class="outer">
    <image class="banner" src="https://qiniucdn.udeve.net/fang/broker-join-bg.png"></image>
    <block wx:if="{{userstate.join_status==-1}}">
      <van-notice-bar wrapable scrollable="{{ false }}" text="审核状态：暂未通过！请修改资料重新提交\n拒绝原因：{{userstate.info}}">
    </van-notice-bar>
    </block>

    <view class="body">

        <van-cell-group title="基本信息">
            <van-field center required label="手机号" use-button-slot model:value="{{ mobile }}" readonly="{{mobileLock}}" disabled="{{mobileLock}}" placeholder="请填写手机号">
                <sms-button wx:if="{{!mobileLock}}" slot="button" mobile="{{mobile}}" />
                <view style="color:{{primaryColor}};" wx:else slot="button">
                    <van-icon bindtap="changeMobile" name="edit"></van-icon>
                    修改
                </view>
            </van-field>

            <van-field wx:if="{{!mobileLock}}" label="验证码" required model:value="{{ smsCode }}" placeholder="短信验证码" />


            <van-field required use-button-slot label="姓名" model:value="{{name}}" placeholder="请输入真实姓名">

                <choose-block slot="button" class="choose" options="{{sexOptions}}" model:value="{{sex}}" bindchangeStatus="changeSex"></choose-block>

            </van-field>

            <van-field required label="微信号" model:value="{{wechat}}" placeholder="请输入微信号" />
            <van-field required label="选择身份" bindtap="showUserGroupSelector" value="{{groupName}}" placeholder="点击选择身份" is-link disabled="{{true}}"> </van-field>

        </van-cell-group>
    </view>


</view>
<view class="footer">
    <van-button block type="primary" color="{{btnColor}}" bindtap="submitHandle">申请入驻</van-button>
</view>



<broker-group-selector bind:change="groupChange" id="broker-group-selector"></broker-group-selector>
