page{
    background-color: #fff !important;
}
.profile-image1{
    width:750rpx ;
    height:400rpx ;
    position: absolute;
    top: 0;
    z-index: -1;
}
.profile-card{
    width: 710rpx;
    margin: 0 auto;
    margin-top: 120rpx;
}
.profile-image2{
    width:163rpx ;
    height:163rpx ;
    border-radius: 50%;
    border:6rpx solid #FDEBBD ;
    margin-left: 35rpx;
    z-index: 5;
    position: relative;
}
.profile-image3{
    width: 710rpx;
    height:315rpx ;
    margin-top: -80rpx;
}
.card-message{
    width: 300rpx;
    height: 180rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: absolute;
    top: 294rpx;
    left: 70rpx;
}
.card-message-top{
    width: 300rpx;
    height: 90rpx;
}
.card-message-bottom{
    width:220rpx ;
    height: 55rpx;
    font-size: 22rpx;
    color: #3F3F3F;
    font-weight: bold;
}
.card-name{
    width: 300rpx;
    height: 55rpx;
    display: flex;
    align-items: center;
    font-size: 38rpx;
    color: #333333;
    justify-content: space-around;
}
.card-wechat{
    font-size:24rpx ;
    color: #333333;
    width:262rpx ;
    height:32rpx ;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.card-wechat image{
    width: 25rpx;
    height: 25rpx;
}
.profile-image4,.profile-image5,.profile-image6,.profile-image7{
    width:35rpx ;
    height:35rpx ;
}
.profile-text1{
    font-size: 24rpx;
    color: #3F3F3F;
    position: absolute;
    top: 301rpx;
    right: 89rpx;
}
.profile-position{
    width: 303rpx;
    height: 110rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: absolute;
    top: 371rpx;
    right: 63rpx;
}
.profile-position-top,.profile-position-bottom{
    display: flex;
    justify-content: space-between;
    font-size: 24rpx;
    color: #3F3F3F;
}
.profile-position-bottom{
    width:310rpx ;
}
.profile-position-bottom-nav{
    width:80rpx ;
    display: flex;
    justify-content: space-around;
}
.profile-position-top view:nth-of-type(1),.profile-position-top view:nth-of-type(2){
    width: 66rpx;
    height:66rpx ;
    border-radius: 50%;
}
button{
    width: 66rpx;
    height:66rpx ;
    border-radius: 50%;
    background-color: transparent;
}
button::after {
    border: none;
  }
.profile-text2{
    color: white;
    margin-left: 4rpx;
}
.profile-house{
    font-size:34rpx ;
    font-weight: bold;
    color: #333333;
    margin-top: 50rpx;
}
.profile-fun{
    width: 750rpx;
    height:150rpx ;
    padding-top: 30rpx;
}
.profile-fun image{
    width:327rpx ;
    height:92rpx ;
}
.profile-fun image:nth-of-type(1){
    margin-right: 55rpx;
}