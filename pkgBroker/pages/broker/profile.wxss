page{
    background-color: #fff !important;
}

.header{ 
    background-size: 750rpx 270rpx; 
    width: 750rpx; 
    height: 390rpx;
    padding-top:20rpx;
    background-repeat: no-repeat;

}

.profile-fun{
    width: 750rpx;
    height:150rpx ;
    position: fixed;
    bottom: 0;
