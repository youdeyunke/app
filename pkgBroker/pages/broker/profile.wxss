page{
  background:#fff !important;
  padding-bottom:140rpx !important;
}


.card-wrapper{
  width:750rpx;
  height:480rpx;
  position:relative;
  overflow:hidden;
}

.card-wrapper-bg{
  width:1500rpx;
  height:1500rpx;
  position:absolute;
  top:-500rpx;
  left:-400rpx;
  z-index:1;
  filter:blur(20px);
}

.card-wrapper .card{
  z-index:999;
  position:absolute;
  top:40rpx;
  left:45rpx;
}


.body{
  width: 100%;
  padding-top:0rpx;
}


.btns.fixed-footer{
  display:flex;
  justify-content:space-between;
  align-items:center;
  width:100%;
  box-sizing:border-box;
  padding:0 30rpx;
  height:160rpx;
}

.btns .btn{
    font-size:32rpx;
    width:335rpx;
    font-weight: bold;
    height:100rpx;
}

.btns .btn-call{
  background:var(--color-a);
}
.btns .btn-share{
  background:var(--color-b);

}
