    background-color: #fff;
    padding-left: 30rpx;
    display: flex;
    justify-content: space-around; 
    align-items: center;
}
.profile-fun image{
    width:327rpx ;
    height:92rpx ;
}
.profile-fun image:nth-of-type(1){
    margin-right: 55rpx;
}