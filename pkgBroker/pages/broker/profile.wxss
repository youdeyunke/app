.profile-text2{
    color: white;
    margin-left: 4rpx;
}
.profile-house{
    font-size:34rpx ;
    font-weight: bold;
    color: #333333;
    margin-top: 50rpx;
}
.profile-fun{
    width: 750rpx;
    height:150rpx ;
    position: fixed;
    bottom: 0;
