<!--pkgBroker/pages/broker/audit/index.wxml-->
<view class="audit-box">
  <block wx:if="{{state.join_status==1}}">
    <image class="image1" src="{{auditbgt}}"></image>
    <image class="image2" src="{{auditicon}}"></image>
    <view class="audit-message">
      <text>{{state.info}}</text>
    </view>
  </block>
  <block wx:if="{{state.join_status==2}}">
    <image class="image1" src="{{passbgt}}"></image>
    <image class="image2" src="{{passicon}}"></image>
    <view class="audit-message">
      <text>{{state.info}}</text>
    </view>
  </block>
  <block wx:if="{{state==0}}">
    <image class="image1" src="{{passbgt}}"></image>
    <image class="image2" src="{{passicon}}"></image>
    <view class="audit-message">
      <text>已经收到您的提交信息，我们将在三个工作日为您审核</text>
    </view>
  </block>

  <view class="audit-submit" bindtap="submitHandle">
    返回主页
  </view>
</view>