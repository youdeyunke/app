<block wx:if="{{userInfo}}">

  <view class="card-wrapper">
    <image src="{{userInfo.avatar}}" class="card-wrapper-bg" />
    <view class="card"><namecard user-info="{{userInfo}}" /> </view>
  </view>



  <view class="body">
    <van-tabs wx:if="{{tabs.length > 1}}" animated swipeable  type="line" color="#00ae66" bind:change="tabChange">
      <van-tab wx:for="{{tabs}}" wx:for-item="tab" title="{{tab.name}}">
      </van-tab>
    </van-tabs> 


    <view style="height:30rpx;" class="blank"></view>
    <box padding="0" width="700">
      <items kw="" wx:if="{{filter}}" page="{{page}}" filter="{{filter}}" />
    </box>

  </view>
</block>

<form report-submit bindsubmit="submit">
  <view class="fixed-footer btns">
  <button hover-class="none" form-type="submit" data-action="callme" bindtap="callMe" class="fake btn btn-call" open-type="">电话咨询</button>
  <button hover-class="none" form-type="submit" data-action="share" open-type="share" class="fake btn btn-share" >分享名片</button>
  </view>
</form>

<cr />
