/* pages/post/event-button.wxss */

.action {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 100%;
    /* height: 88rpx; */
    width: 120rpx;
}

.action .icon {
    width: 46rpx;
    height: 52rpx;
    margin-bottom: 10rpx;
}

.action .status-text {
    width: 120rpx;
    /* height: 50rpx; */
    border-radius: 10rpx;
    /* background-color: #ffffff; */
    line-height: 50rpx;
    font-size: 26rpx;
    /* font-weight: bold; */
    /* margin-top: 8rpx; */
}

.action.dark {
    color: #333;
}

.action van-icon {
    margin-right: 6rpx;
}

.dialog {
    width: 568rpx;
    padding: 60rpx;
    background: #ffffff;
}

.dialog .title {
    font-size: 40rpx;
    color: #333;
    margin-bottom: 60rpx;
    margin-top: 30rpx;
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.dialog .title image {
    width: 56rpx;
    height: 56rpx;
    margin-right: 10rpx;
    margin-bottom: 0;
    vertical-align: middle;
}

.dialog .desc {
    font-size: 28rpx;
    color: #333;
    line-height: 40rpx;
    margin-bottom: 20rpx;
}

.dialog .tips {
    margin-top: 0rpx;
    margin-bottom: 40rpx;
    font-size: 24rpx;
    color: #cecece;
}

.dialog .tip {
    margin-top: 10rpx;
}

/* .dialog .confirm .b {} */

.confirm {
    margin-top: 30rpx;
    font-size: 24rpx;
    color: #cecece;
}

checkbox {
    margin-right: 10rpx;
}

checkbox .wx-checkbox-input {
    width: 20rpx;
    height: 20rpx;
}