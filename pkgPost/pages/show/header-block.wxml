<view class="outer">
    <view class="title-block">
        <view class="first-left">
            <view class="left-title">{{post.title}}</view>
            <view class="left-tags">
                <view class="left-tag" wx:for="{{post.tags}}" wx:for-item="tag" wx:for-key="tag.id">
                    {{tag.name}}
                </view>
            </view>
        </view>
        <view class="event-button">
            <event-button cat="open" pid="{{post.id}}"></event-button>
        </view>
    </view>
    <view class="cell-group">
        <cell custom-style="cell-item" pid="{{post.id}}"  icon="location" title="{{post.address}}" bindtap="gotoLocation"></cell>
        <cell wx:if="{{post.rank_info.show}}" pid="{{post.id}}"  custom-style="cell-item" icon="bang" title="{{post.rank_info.text}}" url="{{post.rank_info.url}}"></cell>
        <cell wx:if="{{post.brokage_info.show}}" pid="{{post.id}}"   custom-style="cell-item" icon="yong" title="{{post.brokage_info.text}}" url="{{post.brokage_info.url}}"></cell>
    </view>
    <view class="navs">
        <navigator url="{{nav.path}}" hover-class="none" class="nav-item" wx:for="{{navs}}" wx:for-item="nav">
            <image src="../../icons/navs/{{nav.id}}.png" />
            <view>{{nav.name}}</view>
        </navigator>
    </view>
</view>