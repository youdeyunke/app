<view class="outer">
    <view class="title-block" style="background-image: url({{bgImgUrl}});">
        <view class="first-left">
            <view class="left-title">{{post.title}}</view>
            <view class="left-tags">
                <view class="left-tag" style="color: {{color}};border: 1rpx solid {{color}};" wx:for="{{post.tags}}" wx:if="{{index <= 2}}" wx:for-item="tag" wx:key="id">
                    <text>{{tag.name}}</text>
                </view>
            </view>
        </view>
        <view class="event-button">
            <event-button cat="open" pid="{{post.id}}" color="{{color}}"></event-button>
        </view>
    </view>
