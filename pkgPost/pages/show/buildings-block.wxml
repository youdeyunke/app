<block>
    <block-box width="750" title="一房一价" url="{{value.more_url}}" sub-title="{{value.more_title}}">
        <scroll-view scroll-with-animation="{{true}}" scroll-x style="width:100%">
            <view class="buildings">
                <navigator hover-class="none" url="/pkgBuilding/pages/building/index?building_id={{item.id}}&post_id={{item.post_id}}" class="building" wx:for="{{value.items}}" wx:key="id">
                    <view class="cover">
                        <view class="zoom">
                            <van-icon name="search" />
                        </view>
                        <image width="165px" height="110px" data-index="{{index}}" src="{{item.image ? item.image  : 'https://qiniucdn.udeve.cn/wefang-sass/type-image-none.jpg'  }}?imageView2/1/w/165/h/110"></image>
                    </view>
                    <view class="meta">
                        <view class="name">{{item.name}}</view>
                    </view>
                </navigator>
            </view>
        </scroll-view>
    </block-box>
</block>