.cell {
    height: 80rpx;
    width: 100%;
    box-sizing: border-box;
    padding: 0 20rpx;
    display: flex;
    justify-content: space-between;
    border-bottom: 2rpx solid #f0f0f0;
    align-items: center;
}

.cell .body {
    font-size: 28rpx;
    line-height: 28rpx;
    color: #333333;
    width: 640rpx;
}

.body text{
    width: 610rpx;
    overflow: hidden;
    white-space: nowrap;
    display: inline-block;
    text-overflow: ellipsis;
}

.cell .icon {
    width: 28rpx;
    height: 28rpx;
    margin-right: 0rpx;
    vertical-align: middle;
}
