.outer {
    background-color: #fff;
    color: #333;
    font-size: 24rpx;
    border-top-left-radius: 20rpx;
    border-top-right-radius: 20rpx;
    margin-top: 487rpx;
}

.first-left {
    width: 600rpx;
}

.title-block {
    border-top-left-radius: 20rpx;
    border-top-right-radius: 20rpx;
    background: linear-gradient(180deg, #FEEB85 0%, #FEFEFE 100%);
    padding: 25rpx 20rpx 0 20rpx;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.left-title {
    color: #333;
    font-weight: 600;
    font-size: 40rpx;
}

.address {
    display: flex;
    align-items: center;
    font-size: 28rpx;
    height: 80rpx;
    line-height: 80rpx;
    display: flex;
    justify-content: space-between;
    width: 710rpx;
    margin: 0 auto;
}

.address image {
    width: 28rpx;
    height: 28rpx;
    margin-right: 0rpx;
    vertical-align: middle;
}

.left-tags {
    display: flex;
    flex-wrap: wrap;
    height: 46rpx;
    overflow: hidden;
    margin-top: 20rpx;
    justify-content: flex-start;
}

.left-tag {
    color: #666666;
    padding: 6rpx 14rpx;
    border-radius: 6rpx;
    background: #E4E4E4;
    margin-right: 16rpx;
    font-size: 24rpx;
}

.event-button {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.event-button image {
    width: 52rpx;
    height: 52rpx;
    margin-bottom: 10rpx;
}

.navs {
    background-color: #fff;
    padding: 0 20rpx 30rpx 20rpx;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    align-items: center;
}

.nav-item {
    width: 20%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.nav-item:nth-child(-n+5) {
    margin-bottom: 30rpx;
}

.nav-item image {
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 10rpx;
}

.block-third {
    border-top: 1rpx solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    padding: 22rpx 20rpx;
    align-items: center;
}

.thrid-left {
    display: flex;
    justify-content: flex-start;
}

.thrid-left image {
    width: 32rpx;
    height: 32rpx;
    margin-right: 10rpx;
}