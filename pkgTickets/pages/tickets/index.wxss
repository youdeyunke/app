/* pkgTickets/pages/tickets/index.wxss */
.none{
    width: 100%;
    text-align: center;
    padding: 20rpx 0;
}
.bgimage{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height:300rpx ;
    z-index: -2;
}
.title{
    font-size:36rpx ;
    color: #fff;
    padding: 31rpx 30rpx 20rpx 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.title image{
    width:15rpx ;
    height: 28rpx;
}
.van-tabs__scroll{
    background-color: rgb(242, 242, 242,0) !important ;
}
.search{
    padding: 20rpx;
    font-size: 26rpx;
    color: #1989FA;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 15rpx;
    margin-top: 20rpx;
}
.sousuo{
    color: #fff;
}
input{
    width:500rpx ;
    background-color: #fff;
    display: inline-block;
    margin-left: 15rpx;
    color: #333333;
}
.input-box{
    width:624rpx ;
    height: 70rpx;
    background-color: #fff;
    border-radius: 50rpx;
    line-height: 70rpx;
    padding-left: 40rpx;
    font-size: 24rpx;
    display: flex;
    align-items: center;
    position: relative;
}
.input-box image{
    width:26rpx ;
    height: 26rpx;
}
.image-box{
    width: 100rpx;
    height: 100rpx;
    position: absolute;
    top: -20rpx;
    right: -10rpx;
}