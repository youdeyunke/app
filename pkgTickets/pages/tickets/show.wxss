.main{
    width:100%;
    height:860rpx;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    position: relative;
}

.main .bg{
    width:750rpx;
    position: absolute; 
    top:0; 
    left:0;
    z-index:1;
    height: 100%;
}

.main .info{ 
    z-index:10;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    color: #fff; 
    text-align: center;
}

.main .info .title{
    padding-top:160rpx;
    font-size: 36rpx;
}

.main .info .ranking{
    font-size: 48rpx; 
    color: #846B3D;
    padding-top:330rpx;
}

.main .info .name{
    font-size:48rpx;
    padding-top:54rpx;
}


.footer{ 
    width:750rpx;
}





.bottom{
    display: flex;
    justify-content: space-evenly;
    font-size: 24rpx;
    align-items: center;
    font-weight: bold;
    margin:0 auto;
    width:100%;
    z-index: 55;
    position: fixed; 
    left:0;
    bottom: 80rpx;
}