.info{
  display: flex;
  justify-content: space-between;
  align-items: center;
  height:160rpx;
  box-sizing: border-box;
  width: 750rpx;
  background:#fff;
  padding:30rpx 30rpx;
  margin-bottom:20rpx;
}

.info .text{
  width: 540rpx;
  height: 100%;
  display: flex;
  padding:12rpx 0;
  box-sizing:border-box;
  
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
}

.info .text .name{
  font-size:30rpx;
  color: #000;
  margin-bottom:10rpx;
  font-weight: bolder;
  display: flex;
  justify-content: center;
  align-items: center;
}

.info .text .name text{
  margin-right:30rpx;
}

.info .text .desc{
  font-size:28rpx;
  color: #333;
}

.info .avatar{
  height: 100rpx;
  width: 100rpx;
  border-radius: 100rpx;
  border:2rpx solid #cecece;
  padding:2rpx;
  overflow: hidden;
  margin-right:20rpx;
}

button.detail{
  border:none;
  background:none;
}
