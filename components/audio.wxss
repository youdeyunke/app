.player{
  

  background: #fff;
  border-radius: 10rpx;
  margin-bottom:20rpx;
  padding:10rpx 30rpx;
  width: calc(100% - 60rpx);
  height: 140rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.player .player_header{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  position: relative;
}

.player .player_header .avatar{
  width:102rpx;
  height:102rpx;
  border:4rpx solid #fff;
  border-radius: 100%;
  position:absolute;
  left:calc(50% - 50rpx);
  top:-50rpx;

}

.player .player_header .name{
  color: #000;
  font-size:32rpx;
}

.player .player_header .qa{
  width: 135rpx;
  height:   30rpx;
  font-size:20rpx;
  border:2rpx solid #ffd900;
  border-radius: 10rpx;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
}

.player .player_body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.player .player_body .status{
  width: 45rpx;
  height: 45rpx;
}


.player .player_body .status image{
  width: 45rpx;
  height: 45rpx;
}

.player .player_body .progress-box{
  width: calc(100% - 65rpx);
  background: #cecece;
  height: 4rpx;
}

.player .player_body .progress-box .progress-bar{
  height: 100%;
  background: #ffd900;
}

.player .player_foot{
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  color: #999;
  font-size:24rpx;
}