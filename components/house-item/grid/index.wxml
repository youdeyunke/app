<navigator hover-class="none" class="post" url="/pkgPost/pages/show/index?id={{post.id}}">

  <post-cover wx:if="{{post}}" item="{{post}}"></post-cover>
  <view class="title">{{post.title}}</view>
  <view class="price red">
    {{post.price_value}}{{post.price_unit}}
  </view>
  <view class="position">
    <block wx:if="{{post.has_live==true}}">
      <image class="img" src="/assets/icons/post/live.png"></image>
    </block>
    <block wx:if="{{post.has_video==true}}">
      <image class="img" src="/assets/icons/post/video.png"></image>
    </block>
    <block wx:if="{{post.has_vr==true}}">
      <image class="img" src="/assets/icons/post/VR.png"></image>
    </block>
  </view>
</navigator>