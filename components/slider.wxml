<!--index.wxml-->
<swiper class="swiper home" indicator-dots="true" autoplay="true" interval="5000"
duration="500" circular="true" indicator-color="rgba(255,255,255,0.7)" autoplay indicator-active-color="#fff" >
<swiper-item wx:for="{{items}}" bindtap="goto" data-index="{{index}}">
    <image src="{{item.image.url}}"></image>
</swiper-item>   
</swiper>
