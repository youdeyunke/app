/* components/textarea.wxss */

textarea {
    padding: 20rpx;
    width: 100%;
    box-sizing: border-box;
    font-size: 28rpx;
    box-sizing: border-box;
    background: #f8f8f8;
    border-radius: 6rpx;
}

.counter {
    position: absolute;
    right: 10rpx;
    bottom: 10rpx;
    font-size: 26rpx;
    color: #cecece;
}