<!-- components/broker-item/index.wxml -->
<block>
    <login-window class="loginwindow"></login-window>
    <view class="outer" style="background:{{bg}}">
        <view class="avatar" bindtap="gotoProfile">
            <image src="{{item.avatar}}?imageView2/5/w/200/h/200" class="user" />
         
        </view>
        <view class="name">
            <view class="fullname">{{ item.name}}</view>
        </view>
        <view class="actions">
            <view style="background:{{secondaryBtnColor}}" class="btn chat" bindtap="chatHandle">
              <van-icon name="comment"></van-icon> 聊天
            </view>
            
            <view style="background:{{primaryBtnColor}}" class="btn phone" bindtap="phoneHandle">
                <van-icon name="phone"></van-icon> 电话
            </view>
        </view>
    </view>

</block>