<!-- components/broker-item/index.wxml -->
<block>
    <login-window class="loginwindow"></login-window>
    <view class="outer" style="background:{{bg}}">
        <view style="display: flex;align-items: center;">
            <view class="avatar" bindtap="gotoProfile">
            
                    <avatar border="{{avatarColors[item.level-1]}}" size="92" src="{{item.avatar}}"/>
    
            </view>
            <view class="name">
                <view class="fullname">{{ item.name}}</view>
                <view class="broker-level">{{levelName}}</view>
            </view>
            <image class="broker-level-icon" src="/assets/icons/broker/jiangpai{{item.level}}.png"></image>
        </view>
        <view class="actions">
            <image bindtap="chatHandle" src="/assets/icons/broker/message.png"></image>
            <image bindtap="phoneHandle" src="/assets/icons/broker/phone.png"></image>
        </view>
    </view>

</block>