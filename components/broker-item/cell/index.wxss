/* components/broker-item/index.wxss */

.outer {
    box-sizing: border-box;
    height: 130rpx;
    width: 100%;
    padding: 0 20rpx;
    background: linear-gradient(111.48deg, #F7F7F7 17.42%, #F2FAFF 88.05%);
    border-radius: 10rpx;
    overflow: hidden;
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.name {
    width: 206rpx;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 10rpx 0;
}

.name .fullname {
    font-size: 28rpx;
    color: #333;
    font-weight: bold;
    margin-bottom:8rpx;
}



.image1 {
    width: 24rpx;
    height: 24rpx;
    margin-right: 5rpx;
}

.name-nav .n{
    margin:0 20rpx 0 6rpx;
}

.name-nav {
    font-size: 24rpx;
    color: #999999;
    display: flex;
    justify-content: flex-start;
    align-items: center;
}


.avatar {
    margin-right: 40rpx;
    position: relative;
}

.avatar image.user {
    border: 2rpx solid #fff;
    border-radius: 95rpx;
    width: 95rpx;
    height: 95rpx;
    overflow: hidden;
}

.avatar image.badge {
    width: 127rpx;
    height: 34rpx;
    position: absolute;
    left: -13rpx;
    bottom: 0rpx;
}

.actions {
    width: 260rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.btn .img {
    width: 120rpx;
    height: 50rpx;
}