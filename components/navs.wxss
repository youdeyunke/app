/* components/home-navs.wxss */

.navs{
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  box-sizing: border-box;
  margin-top:30rpx;

}

.navs navigator{
  width:20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin:5rpx 0 15rpx 0;
}


.navs .icon-cover{
  width:84rpx;
  height:84rpx;
  margin-bottom:8rpx;
  border-radius:100%;
  box-shadow: 1px 1px 2px rgba(0,0,0, 0.1);
  display:flex;
  justify-content:center;
  align-items:center;
}

.navs navigator image{
  width:84rpx;
  height:84rpx;
  border-radius: 84rpx;
  overflow: hidden;
}

.navs navigator text{
  color: #000;
  margin-top:10rpx;
  font-size:24rpx;
  font-weight: bolder;
}
