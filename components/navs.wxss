/* components/home-navs.wxss */

.navs{
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items:space-between;
  box-sizing: border-box;
}

.navs navigator{
  width:20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}


.navs .icon-cover{
  width:94rpx;
  height:94rpx;
  margin-bottom:8rpx;
  display:flex;
  justify-content:center;
  align-items:center;
}

.navs navigator image{
  width:94rpx;
  height:94rpx;
  overflow: hidden;
}

.navs navigator text{
  color: #000;
  margin-top:10rpx;
  font-size:24rpx;
  font-weight: bolder;
}
