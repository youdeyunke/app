/* components/pagemaker/news/style0.wxss */

.item-list {
    width: 100%;
    margin: 0 auto 20rpx auto;
    padding: 0rpx 20rpx;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
}

.item {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    height: 152rpx;
    margin: 10rpx 0rpx;
    border-bottom: 2rpx solid #f0f0f0;
    padding: 20rpx;
}

.item:last-child {
    border: none;
    margin-bottom: none;
}

.item .left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    width:550rpx;
    height: 152rpx;
    padding: 16rpx 0;
}

.item .footer {
    font-size: 24rpx;
    display: flex;
    justify-content: space-between;
    width: 100%;
    align-items: bottom;
}

.item .author {
    color: #666;
}

.item .date {
    color: #999;
}

.item .title {
    font-size: 26rpx;
    height: 72rpx;
    font-weight: bold;
    color: 333;
}

.item .cover {
    margin-right:30rpx;
}

.item .cover image {
    width: 210rpx;
    height: 135rpx;
    border-radius: 10rpx;
}