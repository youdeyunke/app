<!-- components/pagemaker/index.wxml -->
<view class="pagemaker">
    <block wx:for="{{modules}}">
        <module-box config="{{item}}" shadow="{{pageConfig.shadowValue }}" radius="{{pageConfig.radius}}" width="{{pageConfig.width}}">
            <header-module config="{{item}}" wx:if="{{item.name === 'header'}}"></header-module>
            <image-module config="{{item}}" wx:elif="{{item.name === 'image'}}"></image-module>
            <video-module config="{{item}}" wx:elif="{{item.name === 'video'}}"></video-module>
            <brokers-module config="{{item}}" wx:elif="{{item.name === 'brokers'}}"></brokers-module>
            <searchbar-module config="{{item}}" wx:elif="{{item.name === 'searchbar'}}"></searchbar-module>
            <banners-module config="{{item}}" wx:elif="{{item.name === 'banners'}}"></banners-module>
            <navs-module config="{{item}}" wx:elif="{{item.name === 'navs'}}"></navs-module>
            <posts-module config="{{item}}" wx:elif="{{item.name === 'posts'}}"></posts-module>
            <blank-module config="{{item}}" wx:elif="{{item.name === 'blank'}}"></blank-module>
            <follow-module config="{{item}}" wx:elif="{{item.name === 'follow'}}"></follow-module>
            <text-module config="{{item}}" wx:elif="{{item.name === 'text'}}"></text-module>
            <notice-module config="{{item}}" wx:elif="{{item.name === 'notice'}}"></notice-module>
            <blocknavs-module config="{{item}}" wx:elif="{{item.name === 'blocknavs'}}"></blocknavs-module>
            <tours-module config="{{item}}" wx:elif="{{item.name === 'tours'}}"></tours-module>
            <news-module config="{{item}}" wx:elif="{{item.name === 'news'}}"></news-module>
        </module-box>
    </block>
    <view class="pagemaker-bg" style="background-color: {{pageConfig.bg.color}}">
        <image style="width:100%;" mode="widthFix" wx:if="{{pageConfig.bg.image}}" src="{{pageConfig.bg.image }}" />
    </view>
</view>
