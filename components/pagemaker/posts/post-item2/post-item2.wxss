/* components/pagemaker/posts/post-item2/post-item2.wxss */
.post {
    font-size: 24rpx;
    height: 524rpx;
    margin-bottom:20rpx
}
.post .cover {
    height: 400rpx;
    position: relative;
}

.post .top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20rpx;
    margin-bottom: 10rpx;
}

.post .cover image {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
}

.post .tags {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-size: 20rpx;
    margin-bottom: 10rpx;
}
.post .tag-item:last-child {
    margin-right: 0;
}
.tag-item{
    font-size: 20rpx !important;
}
.post .tag-item {
    border: 2rpx solid #999;
    color: #999;
    padding: 6rpx 10rpx;
    margin-right: 10rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}
.post .cover .address {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 10;
    height: 60rpx;
    box-sizing: border-box;
    padding: 0 20rpx;
    color: #fff;
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.post .top text {
    color: red;
}

.post .title {
    color: #000;
    font-size: 32rpx;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    overflow-x: hidden;
    overflow-y: hidden;
    
}