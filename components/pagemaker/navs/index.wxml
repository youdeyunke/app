<view class="list mode-{{config.styleName}}">
    <view wx:for="{{navs}}" class="item">
        <view data-index="{{index}}" config="{{item.link}}" class="link" hover-class="none" bindtap="clickHandle">
            <view class="icon">
                <image src="{{item.url}}" />
                <view  class="count">
         
                    <counter album-id="{{item.albumId}}"></counter>
                </view>
            </view>
            <view class="name" style="color: {{ item.color || '#333333' }}">{{item.title}}</view>
        </view>
    </view>
</view>