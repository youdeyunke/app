/* components/pagemaker/navs/index.wxss */

.list {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
}

.list .item .icon {
    width: 100rpx;
    height: 100rpx;
    position: relative;
}

.list .item .icon image {
    width: 100rpx;
    height: 100rpx;
}

.list .item .count {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
    z-index: 10;
    font-weight: bold;
    font-size: 30rpx;
}

.list .item .name {
    font-size: 24rpx;
    color: #333;
    font-weight: bold;
    min-width: 100rpx;
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    overflow-x: hidden;
    overflow-y: hidden;
    margin-top: 11rpx;
}

.list .item {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    width: 100rpx;
    margin-top: 10rpx;
}

.list .item .link {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
}

.list.mode-5 .item {
    margin-right: calc((100% - 500rpx) /4);
}

.list.mode-5 .item:nth-child(5n) {
    margin-right: 0rpx;
}

.list.mode-5 .item:nth-child(-n+5) {
    margin-top: 0;
}

.list.mode-4 .item {
    margin-right: calc((100% - 500rpx) /3);
}

.list.mode-4 .item:nth-child(4n) {
    margin-right: 0rpx;
}

.list.mode-4 .item:nth-child(-n+4) {
    margin-top: 0;
}