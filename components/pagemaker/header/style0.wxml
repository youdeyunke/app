<!-- components/pagemaker/header/style0.wxml -->
<view class="header">
    <view class="title">
        <view class="hat"></view>
        {{title}}
    </view>
    <view class="subtitle" bind:tap="linkHandle">
        {{subtitle}}
        <view class="arrow" wx:if="{{link}}">
            <van-icon name="arrow" />
        </view>
    </view>
</view>