<!-- components/pagemaker/header/index.wxml -->
<block wx:if="{{config}}">
    <view class="header-container">
        <style0 title="{{title}}" subtitle="{{subtitle}}" link="{{link}}" wx:if="{{config.style === 0}}" />
        <style1 title="{{title}}" subtitle="{{subtitle}}" link="{{link}}" wx:if="{{config.style === 1}}" />
        <style2 title="{{title}}" subtitle="{{subtitle}}" link="{{link}}" wx:if="{{config.style === 2}}" />
    </view>
</block>