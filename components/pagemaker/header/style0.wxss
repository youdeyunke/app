/* components/pagemaker/header/style0.wxss */

.header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    height: 80rpx;
    width: 100%;
}

.title {
    font-size: 28rpx;
    color: #000;
    display: flex;
    align-items: center;
}

.title .hat {
    height: 16px;
    width: 8rpx;
    background-color: #1989fa;
    margin-right: 6rpx;
}

.subtitle {
    font-size: 12px;
    color: #999;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.subtitle .arrow {
    margin-left: 6rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    vertical-align: middle;
}