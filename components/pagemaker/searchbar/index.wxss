/* components/pagemaker/searchbar/index.wxss */

.searchbar {
    width:100%;
    margin:0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 24rpx;
}

.searchbar .body {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    height: 100%;
    width: 500rpx;
    padding: 0 20rpx;
}

.body-style-0 {
    border-radius: 8rpx;
    background: #F4F4F4;

}
.body-style-1 {
    border-radius: 8rpx;
    border:2rpx solid #f0f0f0;
    box-shadow: 0 0 20rpx rgba(0,0,0, 0.15);
    background:#fff;
}



.searchbar .footer {

    height: 40rpx;
    border-left: 2rpx solid #C1C1C1;
    padding:0rpx 20rpx 0 20rpx;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    color: #1989fa;
}

.searchbar .footer image{
    height:30rpx;
    width:30rpx;
    margin-right:8rpx;
}

.left-part {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}