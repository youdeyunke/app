/* components/pagemaker/index.wxss */

.pagemaker {
    display: flex;
    justify-content: flex-start;
    flex-direction: column;
    align-items: center;
    padding:0;
    margin:0;
    /* padding-bottom: calc(100rpx + env(safe-area-inset-bottom)) ; */
    width:750rpx;
}

.pagemaker-bg {
    width: 100%;
    height: 100%;
    position: fixed;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
}

.pagemaker-bg image {
    width: 100%;
    height: 100%;
}