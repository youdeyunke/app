

.item {
    width: 710rpx;

    box-sizing: border-box;
 
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-sizing: border-box;
    position: relative;
    border-bottom: 1rpx solid #f2f2f2;
    padding:0 20rpx 20rpx 20rpx; 
    margin:0 auto 20rpx 0;
}

.item .summary{
    font-size:24rpx; 
    columns: #333333;
    line-height:36rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    height:70rpx;
    margin:8rpx 0;
    display: -webkit-box;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2; 
  

}

.item .badge {
    width: 120rpx;
    height: 110rpx;
    position: absolute;
    top: -30rpx;
    left: -24rpx;
    z-index: 10;
}
.item .cover {
    width: 214rpx;
    height: 136rpx;
    border-radius: 0rpx;
    overflow: hidden;
    position: relative;
    margin-right:20rpx;
}
.item .cover image{
    width: 100%;
    height: 100%;
    border-radius: 10rpx;

}

.item .title {
    font-size: 28rpx;
    color: #333;
    font-weight: bolder;
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    width: 448rpx;
}

.item .title-block {
    height: 100%;
    display: flex;
    width: 450rpx;
    flex-direction: column;
    justify-content: space-between;
    padding: 10rpx 20rpx 10rpx 0;
    box-sizing: border-box;
}

.item .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #666;
    font-size: 20rpx;
    width: 100%;

}

.item .date {
    font-size: 22rpx;
    color: #A0A0A0;
}

.item .author {
    font-size: 22rpx;
    color: #666666;
}


.item .views{
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
}



.video-item{
    width:710rpx; 
    height:320rpx;
    margin:0 auto 20rpx auto; 
    position: relative;
    border-radius: 20rpx;
    overflow: hidden;
}

.video-item .cover{
    width:100%;
    height:100%;
    position: absolute; 
    top:0; 
    left:0;

    z-index:1;
}

.video-item .video-item{
    width:70rpx; 
    height:70rpx;
}

.video-item .title-block{
    z-index:2;
    position: absolute;
    top:0; 
    left:0; 
    width:100%; 
    height:100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color:#fff;
    padding:30rpx;
    background-image:  linear-gradient(to top  ,  rgba(0,0,0, 0.4), rgba(0,0,0, 0.8));
}

.video-item .meta{
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size:24rpx;
}
.video-item .summary{
    display:none;
}

.video-item .title{
    font-size:32rpx;
}

.video-item .views{
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.video-item image.play{
    width:70rpx; 
    height:70rpx;
    position: absolute;
    left:calc(50% - 35rpx); 
    top:calc(50% - 35rpx);
    z-index:10;
}