<!--components/broker-link.wxml-->
<block bindtap="gotoUser">
  <view class="info">
    <image class="avatar" src="{{broker.avatar}}"></image>
    <view class="text">
      <view class="name"><text>{{broker.name}}</text> <van-tag color="#ff911b" plain>已认证</van-tag> </view>
      <view class="desc">
        <text wx:if="{{broker.mobile}}">联系电话：{{broker.mobile}}</text>
      </view>
    </view>
    <button class="btn primary plain mini">进入店铺</button>
  </view>
</block>