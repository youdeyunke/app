/* components/slider.wxss */

 .myswiper swiper, .myswiper image{
  width:750rpx;
  height: 320rpx;
  margin:0 auto;
  border-radius: 0rpx;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
}

.myswiper {
  position:relative;
}


.myswiper .search-box{
  position:absolute;
  background:#fff;
  height:80rpx;
  line-height:80rpx;
  border-radius:4rpx;
  color:#cecece;
  padding-left:20rpx;
  box-sizing:border-box;
  width:700rpx;
  margin:0 auto;
  top:30rpx;
  left:25rpx;
}
