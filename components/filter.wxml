<!--components/filter.wxml-->
<view class="sfilter-group">

    <view class="sfilter">
      <picker class="sfilter-item"  bindchange="cityHandle" value="{{cityIndex}}" range="{{cities}}" range-key="name" >
      <view class="sfilter-item-wrapper">
        <view>{{ cityIndex > 0 ? cityName : '城市' }}</view>
        <view class="sfilter-item-arrow"></view>
      </view>     
    </picker>

      <picker class="sfilter-item"  bindchange="districtHandle" value="{{districtIndex}}" range="{{districts}}" range-key="name" >
      <view class="sfilter-item-wrapper">
        <view>{{ districtIndex > 0 ? districtName : '区县' }}</view>
        <view class="sfilter-item-arrow"></view>
      </view>     
    </picker>

    <picker class="sfilter-item" mode="multiSelector" bindchange="priceHandle" bindcolumnchange="bindMultiPickerColumnChange" value="{{multiIndex}}" range="{{priceRange}}">
      <view class="sfilter-item-wrapper">
        <view>价格</view>
        <view class="sfilter-item-arrow"></view>
      </view>       
    </picker>


    </view>
</view>

