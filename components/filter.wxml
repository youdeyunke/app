<!--components/filter.wxml-->
<view class="sfilter-group">
    <view class="search">
            <mysearch bindclear="clearHandle" value="{{text}}" initmode="2" fake="1" />
    </view>
    <view class="sfilter">
      <view class="sfilter-item"  bindtap="cityFilterClick" >
        <view class="sfilter-item-wrapper">
          <view>{{ cityDistrictName ? cityDistrictName : '区域' }}</view>
          <view class="sfilter-item-arrow"></view>
        </view>     
      </view>


      <view wx:if="{{group == 'zufang'}}" class="sfilter-item"  bindtap="typeFilterClick" >
        <view class="sfilter-item-wrapper">
          <view>{{  s ? s.name : '户型' }}</view>
          <view class="sfilter-item-arrow"></view>
        </view>     
      </view>

      <view wx:if="{{group == 'zufang'}}" class="sfilter-item"  bindtap="priceFilterClick" >
        <view class="sfilter-item-wrapper">
          <view>{{ priceRange ? priceRange.name : '价格' }}</view>
          <view class="sfilter-item-arrow"></view>
        </view>     
      </view>


      <view class="sfilter-item"  bindtap="orderClick" >
        <view class="sfilter-item-wrapper">
          <view>排序</view>
          <view class="sfilter-item-arrow"></view>
        </view>     
      </view>      

    </view>

    <city-picker wx:if="{{cities}}" position="top" bind:change="cityChange" show="{{showCitySelect}}" />
    <price-filter bindchange="priceChange" show="{{showPriceFilter}}" />
    <order show="{{showOrder}}" bind:change="orderChange" />
    <type-filter show="{{showTypeFilter}}" bind:change="typeChange" />
</view>

