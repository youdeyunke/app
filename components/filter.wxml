<!--components/filter.wxml-->
<view class="sfilter-group">
    <view class="sfilter">
            <view hover-class='none' bindtap='filterItemHandle' wx:for="{{keys}}" class="sfilter-item" data-target="{{item[1]}}">
                    {{item[0]}}

            <view class="arrow"></view>
        </view>
    </view>
            <view class="city panel options" wx:if="{{ current_panel == 'city' }}">
                <view wx:for="{{cities}}" bindtap="cityHandle" data-index="{{index}}"  class="option-item {{ item.id == city.id ? 'active' : '' }} ">{{item.name}}</view>
            </view>

            <view class="district panel options" wx:if="{{ current_panel == 'district' }}">
                <view wx:for="{{districts}}" bindtap="districtHandle" data-index="{{index}}"  class="option-item">{{item.name}}</view>
            </view>

</view>

