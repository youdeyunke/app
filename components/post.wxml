<navigator hover-class="none" class="post {{item.group == 'new' && item.coupon_enable ? '' : 'coupon-none'}} {{type}} {{ shadow ? 'shado' : 'shadow-none'}} {{ border ? 'border' : 'border-none'}}" open-type="navigate" url="/pages/post/post?id={{item.id}}" >
        <badge wx:if="{{item.coupon_enable}}">{{item.coupon_desc}}</badge>
      <view class="cover">
        <image class="i" src="{{ item.cover || '/assets/images/cover-none.png' }}?imageView2/2/w/750"></image>
        <image wx:if="{{item.vr_url}}" class="play-btn" src="/assets/icons/vr.png"></image>
      </view>
      <view class="meta">
        <text class="item-title" >{{ item.title }}</text>
        <mytags mini="true" items="{{item.tags_list}}" max="3"></mytags>

        <view class="area-price">
              <text class="area" >{{item.area_info.label}}: {{item.area_info.text}}</text>
              <text class="price" >{{item.price_info.label}}：<text class="red">{{item.price_info.text}}</text></text>            
        </view>
    

      </view>

</navigator>
