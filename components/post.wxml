<navigator hover-class="none" class="post {{item.group == 'new' && item.coupon_enable ? '' : 'coupon-none'}} {{type}} {{ shadow ? 'shado' : 'shadow-none'}} {{ border ? 'border' : 'border-none'}}" open-type="navigate" url="/pages/post/post?id={{item.id}}" >
        <badge wx:if="{{item.coupon_enable}}">{{item.coupon_desc}}</badge>
      <view class="cover">
        <image class="i" src="{{ item.cover || '/assets/images/cover-none.png' }}?imageView2/2/w/250"></image>
        <image wx:if="{{false}}" class="play-btn" src="/assets/images/play-btn.png"></image>
      </view>
      <view class="meta">
        <text class="item-title">{{ item.group == 'new' ? item.block_name : item.title }}</text>
        <mytags mini="true" items="{{item.tags_list}}" max="3"></mytags>

        <view class="area-price">
            <text class="area" >建面: {{item.area_info.text}}</text>
        </view>
           <text class="price" >总价：{{item.price_info.text}}</text>

      </view>

</navigator>
