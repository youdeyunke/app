.need{
  width:710rpx;
  padding:30rpx 30rpx;
  box-sizing:border-box;
  background:#fff;
  margin-bottom:0px;
  border-bottom:1px solid #f4f4f4;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.need .avatar, .need .avatar image{
   width:120rpx;
   height:120rpx;
   border-radius:120rpx;
   border:1px solid #f4f4f4;
}

.need .body{
  width:375rpx;
  margin-left:20rpx;
}


.need .body view.name{
  display:flex;
  margin-bottom:20rpx;

}

.need .body text.name{
  font-weight:bolder;
  color:#000000;
  font-size:40rpx;
}

.need .body .blank{
  width:15rpx;
}


.need .body .position{
  font-size:28rpx;
  color:#333;
  margin-bottom:10rpx;

}

.need .body .price{
  margin-bottom:10rpx;
}

.need .body .price text{
 color:red;
 font-weight:bolder;
 font-size:28rpx;
 font-weight:bolder;
}

.need .tags{
 margin-bottom:10rpx;
 display:flex;
}

.need .footer{
  display:flex;
  justify-content:flex-start;
  align-items:center;
  color:#cecece;
}
