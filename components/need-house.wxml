<!--components/need-house.wxml-->
    <box padding="30" >
        <view bindtap="itemClick" class="need">
          <view class="header">
              <view class="user">
                 <view class="avatar"><image src="{{item.user_info.avatar}}" /></view>
                 <view class="nickname">{{item.user_info.nickname}}</view>
              </view>
              <view class="time">  <howlong date="{{item.updated_at}}"/> </view>
          </view>

          <view class="body">
            <view class="content line-limit">要求：{{item.content}}</view>
            <view class="meta">
              <view class="budget">
                预算{{item.budget_min}}~{{item.budget_max}}
              </view>
              <view class="position">
                {{ item.position }}
              </view>
            </view>
          </view>
        </view>
    </box>
