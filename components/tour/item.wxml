<navigator hover-class="none" class="item" url="/pkgTour/pages/tour/show?id={{item.id}}">
  <image class="cover" src="{{item.cover }}?imageView2/2/w/250"></image>
  <view class="item-title-block">
    <view class="title">{{item.title}}</view>
    <view class="meta">
      <view class="date">{{item.created_at_pretty}}</view>
      <view class="views"><van-icon name="eye-o" />{{ item.view_nums }}</view>
    </view>
  </view>
</navigator>
