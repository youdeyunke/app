/* components/video-uploader/index.wxss */
.uploader{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
}

.uploader .item{
  width: 200rpx;
  height: 200rpx;
  padding:15rpx;
  box-sizing: border-box;
  border:2rpx dashed #cecece;
  margin:10rpx 5rpx 10rpx 5rpx;
  display: flex;
  justify-content: center;
  align-items: center;   
  overflow: hidden;
}

.uploader .item image{
  max-width: 160rpx;
  max-height: 160rpx;
}


.uploader .item.video video{
  max-width: 180rpx;
  max-height: 180rpx;

}

.uploader .item.add-video{
  display: flex;
  justify-content: center;
  align-items: center;
  font-size:24rpx;
  flex-direction: column;
  text-align: center;
}
