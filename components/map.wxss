/* components/map.wxss */
.mymap{
  width:750rpx;
  height:400rpx;
  background:#fff;
  position:relative;
  margin-bottom:30rpx;
  padding-bottom:30rpx;t
}

.mymap image{
    width:100%;
    height:100%;
}


.mymap .label{
   position:absolute;
   left:calc(50% - 150rpx);
   bottom:calc(50% + 20rpx);
   width:300rpx;
   padding:30rpx;
   background:#fff;
   border:1px solid #f4f4f4;
   box-shadow: 1rpx 2rpx 2rpx rgba(0,0,0, 0.125);
   border-radius:2rpx;
   font-size:24rpx;
}
