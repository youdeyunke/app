<scroll-view class="outer" scroll-x>

  <view class="tabs">

        <view class="tab {{activeIndex == index ? 'active' : ''}} " wx:for="{{data}}" data-index='{{index}}' bind:tap="tabChange">
            <view class="name">{{item.name || item.title || item.label}}</view>
            <view wx:if="{{activeIndex === index }}" class="border" ></view>
        </view>
    </view>
</scroll-view>
