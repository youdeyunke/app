<!-- pages/post/filter/index.wxml -->
<view class="post-filter-index">
    <old-post-filter wx:if="{{postGroup == 'old'}}" options="{{filterOptions}}" filter="{{filter}}" bind:change="filterChange" />
    <new-post-filter wx:if="{{postGroup == 'new'}}" options="{{filterOptions}}" filter="{{filter}}" bind:change="filterChange" />
    <rental-post-filter wx:if="{{postGroup == 'rental'}}" options="{{filterOptions}}" filter="{{filter}}" bind:change="filterChange" />
    <shop-post-filter wx:if="{{postGroup == 'shop'}}" options="{{filterOptions}}" filter="{{filter}}" bind:change="filterChange" />
    <auction-post-filter wx:if="{{postGroup == 'auction'}}" options="{{filterOptions}}" filter="{{filter}}" bind:change="filterChange" />
</view>
