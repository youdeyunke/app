<!--components/map.wxml-->

<form style="width:100%;" report-submit class="myfav-wrapper"  bindsubmit="clickHandle">
  <button hover-class="none" form-type="submit" class="fake mymap">
    <image src="{{image}}"></image>
    <view class="map-layer">
      <view class="map-layer-inner">
        <view class="content"><text class="name">{{name || '未知地点'}}</text></view>
        <view class="circle"></view>
      </view>
    </view>  
</button>
</form>


