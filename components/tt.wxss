.item {
    width: 100%;
    height: 140rpx;
    background: #fff;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    box-sizing: border-box;
    position: relative;
    border-bottom: 2rpx solid #f9f9f9;
    margin-bottom: 20rpx;
    padding-bottom: 20rpx;
}

.item .badge {
    width: 120rpx;
    height: 110rpx;
    position: absolute;
    top: -30rpx;
    left: -24rpx;
    z-index: 10;
}
.cover {
    width: 200rpx;
    height: 120rpx;
    border-radius: 0rpx;
    overflow: hidden;
    position: relative;
}
.cover image{
    width: 100%;
    height: 100%;
}
.bofang{
    position: absolute;
    width: 50rpx !important;
    height: 50rpx  !important;
    left: 0;
top: 0;
right: 0;
bottom: 0;
margin: auto; 
}

.item .title {
    font-size: 28rpx;
    color: #333;
    line-height: 36rpx;
    display: -webkit-box;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
}

.item .item-title-block {
    height: 100%;
    display: flex;
    width: 450rpx;
    flex-direction: column;
    justify-content: space-between;
    margin-left: 20rpx;
}

.item .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #666;
    font-size: 20rpx;
    width: 100%;
}

.item .date {
    font-size: 22rpx;
    color: #333;
}

.item .author {
    font-size: 22rpx;
    color: #666;
}