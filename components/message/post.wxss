/* components/message/post.wxss */
.post-wrapper{
 width:100%;
 display:flex;
 flex-direction: column;
 justify-items: center;
 align-items: center;
}

.post-wrapper text{
  font-size:22rpx;
  margin-bottom:10rpx;
  margin-top:20rpx;
}


.block{
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;   
    width:400rpx;
    background:#fff;
    padding:10rpx 20rpx;
    border-radius:10rpx;
    box-sizing:border-box;

}

.block .cover{
    width: 100%;
    height: 290rpx;
}
.block .type-info{
    color: #333;
    width:100%;
    margin:10rpx 0;
    font-weight:bolder;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.block .sub-name{
    font-size:24rpx;
    color: #999;
}

.block .price-info{
    display: flex;
    justify-content: flex-start;
    align-items: flex-end;
    margin:10rpx 0;
}


.block .price-info .total{
    color: red;
    font-size: 28rpx;
}

.block .price-info .average{
    font-size:24rpx;
    color: #999;
    margin-left:20rpx;
}
