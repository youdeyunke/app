
.text-wrapper{
  border-radius: 8rpx;
  padding:22rpx 18rpx;
  position: relative;
  max-width:400rpx;  
}

.msg-left .text-wrapper{
  background:#fff;
}

.msg-right .text-wrapper{
  background: #95CD5E;
}

.msg-left .text-wrapper::after{
  content: "";
  position: absolute;
  top:calc(var(--height) * 0.5 - 12rpx );
  left:-8rpx;
  z-index: 20;
  width:0;
  height: 0;
  border-style: solid;
  border-color: transparent #fff transparent transparent;
  border-width: 10rpx 10rpx 10rpx 0;
}


.msg-right .text-wrapper::after{
  content: "";
  position: absolute;
  top:calc(var(--height) * 0.5 - 12rpx );
  right:-8rpx;
  z-index: 20;
  width:0;
  height: 0;
  border-style: solid;
  border-color: transparent transparent transparent #95CD5E;
  border-width: 10rpx 0rpx 10rpx 10rpx;
}

.text{
  font-size:24rpx;
  color: #000;
  line-height: 1.6;
}
