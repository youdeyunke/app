<view class="card {{ shadow ? 'shado' : 'shadow-none'}} {{ border ? 'border' : 'border-none'}}">
  <view class="card-header">
    <view class="card-header-title">
            <view class="h2">{{title}}
              <text wx:if="{{number>0}}">({{number}})</text>
            </view>
    </view>
    <view wx:if="{{url}}" class="card-header-action" bindtap='actionHandle'>
      <text class="card-header-action-name">{{action}}</text>
      <image class="card-header-action-image" src="/assets/icons/right-arrow.png"></image> 
    </view>
  </view>
  <view class="card-body">
    <slot></slot>
  </view>
  <view class="card-footer"></view>
</view>
