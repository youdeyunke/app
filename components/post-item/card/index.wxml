<navigator hover-class="none" class="post" url="/pkgPost/pages/show/index?id={{post.id}}">
    <view class="cover">
        <image style="border-radius:5rpx" src="{{post.cover}}?imageView2/1/w/750/h/400" />
        <view class="address">{{post.address}}</view>
    </view>
    <view class="footer">
        <view class="title">{{post.title}}</view>
        <view class="top">
            <view class="tags">
                <van-tag text-color="{{item.text_color }}" size="mini" plain wx:for="{{post.tag_objs}}" wx:key="item.id">
                    {{item.name}}
                </van-tag>
            </view>
            <view class="price">
                <view class="left">{{post.average_price_info.label}}:</view>
                <view class="right">{{post.average_price_info.text}}{{post.average_price_info.px}}</view>
            </view>
        </view>
    </view>
</navigator>