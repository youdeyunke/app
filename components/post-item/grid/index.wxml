<navigator hover-class="none" class="post" url="/pkgPost/pages/show/index?id={{post.id}}">
  <image class="cover" src="{{post.cover}}" />
  <view class="title">{{post.title}}</view>
  <view class="price red">
    {{post.average_price_info.text}}{{post.average_price_info.px}}
  </view>
  <view class="position">
    <image class="position-image1" src="/assets/icons/post/live.png"></image>
    <image class="position-image2" src="/assets/icons/post/video.png"></image>
    <image class="position-image3" src="/assets/icons/post/VR.png"></image>
  </view>
</navigator>