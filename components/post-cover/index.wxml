<view class="cover" style="width:{{width}}rpx;height:{{height}}rpx;">

<image style="width:{{width}}rpx;height:{{height}}rpx;" class="img" src="{{item.cover}}?imageView2/2/w/400" mode="aspectFill" lazy-load="{{true}}" />
<view class="views" wx:if="{{views}}">
    <image class="vr" src="{{eyeIcon}}"></image>
    {{views}}
</view>
<view class="icons">

    <image wx:if="{{item.has_vr}}" class="vr" src="{{vrIcon}}"></image>
    <image wx:if="{{item.has_video}}" class="video" src="{{videoIcon}}"></image>
</view>
</view>