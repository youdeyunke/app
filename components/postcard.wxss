/* components/postcard.wxss */

.post-card{
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
  border-radius: 10rpx;
}

.post-card .cover{
  width: calc(100% - 2rpx);
  height: 380rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  border-bottom-left-radius: 0rpx;
  border-bottom-right-radius: 0rpx;
  overflow: hidden;
  position:relative;
}


.post-card .address{
  height:60rpx;
  color:rgba(255,255,255, 0.5);
  position:absolute;
  right:10rpx;
  bottom:0rpx;
  display:flex;
  justify-content:flex-start;
  align-items:center;
  box-size:border-box;
  font-size:var(--font-xs);
}

.post-card .count{
  color:#fff;
  background:rgba(0,0,0, 0.1);
  position:absolute;
  padding:5rpx 18rpx;
  border-radius:40rpx;
  font-size:var(--font-xs);
  z-index:999;
  display:flex;
  letter-spacing:1rpx;
  justify-content:center;
  align-items:center;
  top:50rpx;
  right:10rpx;
}

.post-card .cover image{
  width: 100%;
  height: 400rpx;
}


.post-card .info{
  width:100%;
  box-sizing:border-box;
  background:#fff;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  align-items:flex-start;
  padding:20rpx 30rpx;
}

.post-card .info .name{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.post-card .info image.pos{
  width:32rpx;
  height:34rpx;
}

.post-card .info .price{
  margin-left:30rpx;
}


.post-card .info .title-block{
  margin-top:20rpx;
   display:flex;
   justify-content: space-between;
   align-items: center;
   width:100%;
}

.post-card .info .title{
  font-size:34rpx;
  color: #333;
  font-weight: bold;
  width: calc(100% - 110rpx);

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;  
}

.post-card .info .view{
  width:90rpx;
  height:38rpx;
  border:1px solid var(--color-a);
  border-radius:6rpx;
  color:var(--color-a);
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:var(--font-xs);
}

.post-card  badge{
    position:absolute;
    top:50rpx;
    left:-9rpx;
}
