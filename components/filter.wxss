/* components/filter.wxss */

.sfilter-group{
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  align-items:center;
  width: 100%;
  position: fixed;
  top:0rpx;
  left:0rpx;
  right:0rpx;
  z-index:99;
  box-sizing: border-box;
  background:#fff;
  box-shadow: 0 1rpx 1rpx rgba(0,0,0, 0.2);  
}

.sfilter-group .search{
  width:100%;
  height:80rpx;
  border-radius:10rpx;
}
.sfilter{
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 60rpx;
  padding:0rpx 40rpx;
  box-sizing: border-box;
  width:100%;
  background:#fff;
}

.sfilter-item-wrapper{
  display: flex;
  justify-content: center;
  align-items: center;
}

.sfilter-item-arrow{
  height: 0rpx;
  width: 0rpx;
  margin-left:10rpx;
  border-top:10rpx solid #333;
  border-left:10rpx solid #fff;
  border-right:10rpx solid #fff;
}


.sfilter-group .panel{
  position:fixed;
  left:0rpx;
  top:62rpx;
  right:0rpx;
  background:#fff;
  z-index:100;
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  padding:0 30rpx;
}

.sfilter-group .options.panel{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.sfilter-group .option-item{
  height: 70rpx;
  border-bottom:1px solid #f1f1f1;
  width: 100%;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  font-size:var(--font-l);
}


.sfilter-group .option-item.active{
  color: var(--color-a);
}

