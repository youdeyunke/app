
<view style="width: 100%;padding-bottom: 20rpx;">
    <view wx:if="{{ status == 1 }}">
        <view class="jiage-1" style="color: {{primaryColor}};">{{budget_min}}-{{budget_max}}万{{budget_max == 300 ? '+' : ''}}</view>
        <view class="slider-1">
            <van-slider min="30" max="300" value="{{value}}" range='true' bar-height="6rpx" active-color="{{primaryColor}}" bind:change="onChange"  use-button-slot>
                <view slot="left-button" class="slider-button-1" style="border: 5rpx solid {{primaryColor}};"></view>
                <view slot="right-button" class="slider-button-1" style="border: 5rpx solid {{primaryColor}};"></view>
            </van-slider>
        </view>
        <view class="slider-ruler-1">
            <view wx:for="{{valueRuler}}">{{item}}万</view>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="nextPage">一键找房</view>
    </view>
    <view wx:if="{{ status == 2 }}">
        <view class="item-header">区域</view>
        <view class="item-body">
            <view class="tags-list">
                <view class="tag-item" wx:for="{{positionList}}">
                    <van-tag size="large" color="{{primaryColor}}" custom-style="height:50rpx;" bindtap="positionHandle" data-index="{{index}}" type="primary" plain="{{item.selected ? false : true}}">
                        <view class="tags-list-name">{{item.text}}</view>
                    </van-tag>
                </view>
            </view>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="quyuNextPage">下一步</view>
    </view>
    <view wx:if="{{ status == 3 }}">
        <view class="item-header">户型</view>
        <view class="item-body">
            <view class="tags-list">
                <view class="tag-item" wx:for="{{housetypeList}}">
                    <van-tag size="large" color="{{primaryColor}}" custom-style="height:50rpx;" bindtap="housetypeHandle" data-index="{{index}}" type="primary" plain="{{item.selected ? false : true}}">
                        <view class="tags-list-name">{{item.name}}</view>
                    </van-tag>
                </view>
            </view>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="huxinNextPage">下一步</view>
    </view>
    <view wx:if="{{ status == 4 }}">
        <view class="item-header">面积</view>
        <view class="item-body">
            <view class="tags-list">
                <view class="tag-item" wx:for="{{areaList}}">
                    <van-tag size="large" color="{{primaryColor}}" custom-style="height:50rpx;" bindtap="areaHandle" data-index="{{index}}" type="primary" plain="{{item.selected ? false : true}}">
                        <view class="tags-list-name">{{item.name}}</view>
                    </van-tag>
                </view>
            </view>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="mianjiNextPage">下一步</view>
    </view>
    <view wx:if="{{ status == 5 }}">
        <view class="item-header">买房用途</view>
        <view class="item-body">
            <view class="tags-list">
                <view class="tag-item" wx:for="{{purposeList}}">
                    <van-tag size="large" color="{{primaryColor}}" custom-style="height:50rpx;" bindtap="purposeHandle" data-index="{{index}}" type="primary" plain="{{item.selected ? false : true}}">
                        <view class="tags-list-name">{{item.name}}</view>
                    </van-tag>
                </view>
            </view>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="yongtuNextPage">下一步</view>
    </view>
    <view wx:if="{{ status == 6 && !isDone}}">
        <view class="item-header">联系方式</view>
        <view class="item-body">
            <van-cell-group>
                <van-field bindchange="inputChange" center required label="手机号" value="{{ contact_mobile }}" readonly="{{contact_mobile_lock}}" disabled="{{contact_mobile_lock}}" placeholder="用于专属顾问联系您" data-name="contact_mobile">
                    <sms-button wx:if="{{!contact_mobile_lock}}" slot="button" mobile="{{contact_mobile}}" />
                    <view style="color:{{primaryColor}};" bindtap="changeMobile" wx:else slot="button">
                        <van-icon name="edit"></van-icon>
                        修改
                    </view>
                </van-field>

                <van-field wx:if="{{!contact_mobile_lock}}" bindchange="inputChange" label="验证码" required value="{{ sms_code }}" placeholder="短信验证码" data-name="sms_code" />
                <van-field bindchange="inputChange" label="姓名" required value="{{ contact_name }}" placeholder="怎么称呼您" data-name="contact_name" />
                <van-field label="性别" readonly required value="{{ contact_sex == 1 ? '先生' : '女士' }}" placeholder="怎么称呼您">
                    <view slot="button">
                        <van-button bindtap="sexToggle" color="{{primaryColor}}" size="mini" type="info" plain="{{ contact_sex != 1 }}">先生</van-button>

                        <van-button bindtap="sexToggle" color="{{primaryColor}}" size="mini" type="info" plain="{{ contact_sex != 0 }}">女士</van-button>
                    </view>
                </van-field>
            </van-cell-group>
        </view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="submitHandle">提交需求，帮我找房</view>
    </view>
    <view wx:if="{{isDone}}">
        <view class="item-header">提交成功</view>
        <view class="item-body">我们已经收到您的找房要求，系统正在为您分配置业顾问，2个工作日内会有专属置业顾问与您电话联系，请注意接听</view>
        <view class="zhaof-btn-1" style="background: {{primaryBtnColor}};" bindtap="reWrite">重新填写</view>
    </view>
</view>
