/* components/post/booking.wxss */

.mytabs{
  padding:0;
  margin:0 !important;
}

.dialog{
  width:600rpx;
  box-sizing:border-box;
  padding:60rpx;
  background:#fff;
}

.title{
  font-size:40rpx;
  color:#333;
  margin-bottom:40rpx;
}

.actions{
  margin-top:40rpx;
}

.desc{
  font-size:28rpx;
  color: #666;
}

.form .title{
  display:flex;
}

.success .title, .success .desc{
  text-align:center;
}

.success .title{
  color:#1989fa;
}

.success .icon{
  margin-top:40rpx;
}

.form .desc{
  margin:20rpx 0;
}


.times{
  display:flex;
  justify-content: space-between;
  align-items:center;
  flex-wrap:wrap;
  margin-top:0rpx;
}

.times .mytag{
  width:120rpx;
  text-align:center;
  margin:10rpx 0rpx;
}

