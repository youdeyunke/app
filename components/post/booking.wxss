/* components/post/booking.wxss */

.mytabs{
  padding:0;
  margin:0 !important;
}

.dialog{
  box-sizing:border-box;
  padding:80rpx 60rpx 60rpx 60rpx;
  background:#fff;
}

.title{
  font-size:40rpx;
  color:#000;
  font-weight: bolder;
  margin-bottom:40rpx;
}

.actions{
  margin-top:40rpx;
  width:100%;
  box-sizing:border-box;
}

.desc{
  font-size:30rpx;
  color: #000;
}

.form .title{
  display:flex;
}


.success {
  display:flex;
  flex-direction:column;
  justify-content:flex-start;
  align-items:center;
}

.success .title, .success .desc{
  text-align:center;
}

.success .title{
  color:#1989fa;
}

.success .icon{
  margin-top:40rpx;
}

.form .desc{
  margin:20rpx 0;
}


.dates{
  display:flex;
  justify-content:flex-start;
  align-items:center;
  width:100%;
}


.times{
  display:flex;
  justify-content: space-between;
  align-items:center;
  flex-wrap:wrap;
  margin-top:0rpx;
}

.dialog .mytag{
  width:120rpx;
  text-align:center;
  justify-content:center;
  align-items:center;
  margin:10rpx 0rpx;
  padding:20rpx 10rpx;
}

.dialog .dates .mytag{
  margin-right:10rpx;
  border-radius:0;
  padding-left:15rpx;
  padding-right:15rpx;
}


button.fake, button.fake::after{
  padding:0;
  margin:0;
  display:inline-block;
  border:none;
  background:none;
  overflow:visible;
}
