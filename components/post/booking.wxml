<van-popup closeable bind:close="closeHandle"  show="{{show}}" duration="500" custom-style="background:none;border-radius:30rpx;"   >
<form  report-submit bindsubmit="formidHandle">
  <view class="dialog">
    <view class="form" wx:if="{{!booked}}">
      <view class="title"><van-icon name="clock-o" color="#000000"  style="margin-right:10rpx;" />  预约看房</view>

      <view class="desc">请选择日期</view>

<scroll-view class="dates" scroll-with-animation="{{true}}" scroll-x style="width:100%;white-space:nowrap;">
         <button plain class="fake" form-type="submit" wx:for="{{dates}}" data-index="{{index}}" wx:for-item="date" bindtap="dateClick"  >
            <van-tag custom-class="mytag" size="large" type="primary" plain="{{currentDateIndex != index}}" >{{ date.label }}</van-tag>

        </button>

</scroll-view>

      <view class="desc">请选择时间</view>
      <view class="times">
          <button bindtap="timeClick" data-index="{{index}}" form-type="submit" class="fake" wx:for="{{dates[currentDateIndex].times}}" wx:for-item="time">
            <van-tag custom-class="mytag" size="large" wx:if="{{time.disabled}}" type="default" plain >{{ time.label }}</van-tag>

            <van-tag custom-class="mytag"  size="large" wx:else  plain="{{ currentTimeIndex != index }}" data-index="{{index}}" type="primary" >{{time.label}}</van-tag>
          </button>
      </view>

      <view class="desc">怎么称呼您</view>
      <van-field value="{{user.name}}" placeholder="请输入姓名" bind:change="nameChange"  />

      <view class="actions">
        <van-button bindtap="submitHandle" block="{{true}}" loading="{{loading}}" loading-text="加载中"  type="info" round disabled="{{ currentDateIndex == null || currentTimeIndex == null || !name }}">确认预约</van-button>
      </view>

    </view>

    <view class="success" wx:else>
      <view class="title">预约成功！</view>
      <view class="desc">经纪人已收到您的预约看房请求</view>
      <view class="icon"> <van-icon color="#1989fa" name="passed" size="200rpx;"></van-icon> </view>

      <view class="actions">
        <van-button bindtap="closeHandle" block="{{true}}"  type="default" plain round >好的</van-button>
      </view>

    </view>
  </view>
</form>
</van-popup>
