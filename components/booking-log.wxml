<block>

<van-panel title="客户：{{item.mobile}}"  status="{{ statusName[item.status]  }}" use-footer-slot  >
  <view style="height:30rpx;"> </view>
  <post-item style="" item="{{post}}" border="{{false}}" shadow="{{false}}" />

  <view slot="footer"  class="footer">
     <view class="time"><van-icon color="#000" style="margin-right:10rpx;" size="28rpx"  name="clock-o" />{{ item.date }} {{ item.time }}</view>
     <view class="btns">
        <van-button size="small" bindtap="callHandle"  type="info" style="margin-right:20rpx;" >拨打电话</van-button>
        <van-button size="small" bindtap="menuToggle"  type="primary" >管理</van-button>

     </view>
  </view>
</van-panel>


<van-action-sheet
  title="管理菜单"
  cancle-text="取消"
  show="{{ showMenu }}"
  actions="{{ actions }}"
  bind:close="menuToggle"
  bind:select="onSelect"
/>

</block>
