
.post{
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin:0rpx auto 0rpx auto;
}


.post.shadow-none{
  box-shadow:none;
}

.post.border-none{
  border:none;
}


.tags {
  font-size:30rpx;
  color: 333;
}

.post .cover{
  position: relative;
  width:296rpx;
  height: 184rpx;  
  border-radius:10rpx;
  overflow:hidden;
}
.post .badge{
    position: absolute;
    color: #fff;
    background-color:var(--color-b);  
    left:-10rpx;
    bottom:20rpx;
    padding:10rpx 15rpx;
    line-height: 100%;
    box-sizing: border-box;
    max-width: 296rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;    
    font-size:24rpx;
}

.post.coupon-none .badge{
        display:none;
}

.post.coupon-none .badge-arrow{
        display:none;
}
 .post .badge-arrow{
  width: 10rpx;
  height: 10rpx;
  position: absolute;
  left: -9rpx;
  bottom: 10rpx;
}

.post .cover .i{
  width:100%;
  height: 100%;
}
.post .play-btn{
  position: absolute;
  width:36rpx;
  height: 36rpx;
  left:calc(266rpx * 0.5 - 36rpx * 0.5);
  top:calc(184rpx * 0.5 - 36rpx * 0.5);

}
 .post .meta{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width:320rpx;
}

.post .meta .item-title{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width:320rpx;
  font-size:32rpx;
  color: #000;
  font-weight: bold;
}

.post .meta .area-price{
  font-size:24rpx;
  display: flex;
  justify-content: space-between; 
  align-items: flex-end;
}

.post .meta .location{
  font-size:24rpx;
}

.post .meta .area-price .area{
  color:#000;
}
.post .meta .area-price .price{
    color:var(--color-c);
    font-weight: bold;
    font-size: 32rpx;
}

@import "/components/tags.wxss";
