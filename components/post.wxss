
.post{
  position:relative;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin:0rpx auto 20rpx auto;
  border-bottom:1rpx solid #f4f4f4;
  padding-bottom:20rpx;
}


.post.shadow-none{
  box-shadow:none;
}

.post.border-none{
  border:none;
}


.tags {
  font-size:30rpx;
  color: 333;
}

.post .cover{
  position: relative;
  width:296rpx;
  height: 184rpx;  
  border-radius:10rpx;
  overflow:hidden;
  z-index:1;
}

.post badge{
  position:absolute;
  top:30rpx;
  left:-9rpx;
  z-index:2;
}

.post .cover .i{
  width:100%;
  height: 100%;
}
.post .play-btn{
  position: absolute;
  width:36rpx;
  height: 36rpx;
  left:calc(266rpx * 0.5 - 36rpx * 0.5);
  top:calc(184rpx * 0.5 - 36rpx * 0.5);

}
 .post .meta{
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width:360rpx;
}

.post .meta .item-title{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width:320rpx;
  font-size:32rpx;
  color: #000;
  font-weight: bold;
}

.post .meta .area-price{
  display: flex;
  justify-content: space-between; 
  align-items: flex-end;
}

.post .meta .location{
  font-size:24rpx;
}

.post .meta .area-price .area{
  color:#000;
}
.post .meta .area-price .price{
    color:var(--color-b);
    font-weight: bold;
    font-size: 32rpx;
}
