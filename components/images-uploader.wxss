/* components/images-uploader.wxss */
.uploader{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
}

.uploader .item{
  width: 200rpx;
  height: 200rpx;
  border:2rpx solid #f4f4f4;
  margin:10rpx 10rpx 10rpx 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;   
}

.uploader .item image{
  width: 200rpx;
  height: 200rpx;

}

.uploader .item.add::after{
  content: "+";
  font-size:40rpx;
  color: #f4f4f4;

}