/* components/images-uploader.wxss */
.uploader{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
}

.uploader .item{
  width: 200rpx;
  height: 200rpx;
  padding:20rpx;
  box-sizing: border-box;
  border:2rpx dashed #cecece;
  margin:10rpx 10rpx 10rpx 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;   
}

.uploader .item.image.main{
  position: relative;
  border:2rpx solid var(--color-a);
}

.uploader .item.image.main .title::after{
  content: '主图';
  position:absolute;
  width:80rpx;
  height:40rpx;
  background:var(--color-a);
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  left:0;
  top:0;

}

.uploader .item image{
  width: 160rpx;
  height: 160rpx;
}


.uploader .item.video video{
  max-width: 200rpx;
  max-height: 200rpx;

}

.uploader .item.add-image::after{
  content: "+";
  font-size:80rpx;
  color: #f4f4f4;

}

.uploader .item.add-video{
  display: flex;
  justify-content: center;
  align-items: center;
  font-size:24rpx;
  text-align: center;
}
