<box radius="10" width="710" padding="0">
<navigator hover-class='none' open-type='navigateTo' url="/pages/post/post?id={{item.id}}" class="post-card">

  <view class="cover">
          <view class="count" wx:if="{{item.images_count > 1}}">共{{item.images_count }} 张</view>
    <image src="{{item.cover}}"></image>
  </view>

  <badge size="big" wx:if="{{item.coupon_enable}}">{{item.coupon_desc}}</badge>

  <view class="info">
     <view class="name">
       <mytags wx:if="{{item.tags_list}}"  items="{{item.tags_list}}"></mytags>
       <image class="pos" src="/assets/icons/location.png"></image>
       <view>{{item.city.name}} {{item.district.name}} {{ item.street }}</view>
      </view>
    <view class="title-block">
      <view class="title line-limit">{{item.title}}{{ item.group == 'new' ? item.block_name : item.area_name }}</view>
      <view class="view">
              查看
      </view>
    </view>


  </view>

</navigator>
</box>
