
.broker-bar{
    height: 160rpx;
}

.broker-bar ul{
  display: flex;
  flex-wrap: nowrap;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 100%;
  box-sizing:border-box;
  padding:0 40rpx;
}


.broker-bar li.staff{
   display:flex;
   justify-content:flex-start;
   width:260rpx;
   letter-spacing:0.5rpx;
   padding:10rpx 0rpx;
   box-sizing:border-box;
}

.broker-bar li button image{
  width: 34rpx;
  height: 34rpx;
}

.broker-bar li button{
    font-size:32rpx;
    font-weight: bold;
    height:90rpx;
}

.broker-bar .staff-info{
    display:flex;
    flex-direction:column;
    justify-content:space-around;
    align-items:flex-start;
    margin-left:20rpx;
}

.broker-bar .staff-avatar{
        display:flex;
        justify-content:center;
        align-items:center;
}
.broker-bar .staff-avatar image{
   width:100rpx;
   height:100rpx;
   border-radius:100%;
   overflow:hidden;
   border:2rpx solid #cecece;
}

.broker-bar .staff-name{
    width:150rpx;
    font-size:30rpx;
    color:#000;
    font-weight: bolder;
}

.broker-bar .staff-desc{
    width:150rpx;
    font-size:var(--font-xs);
    color:#666;
}
