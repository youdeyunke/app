.box {
  width: 100%;
  height: 100%;
  display: flex;
  justify-items: center;
  align-items: center;
  flex-direction: column;
}
.box .title {
  width: 710rpx;
  height: 90rpx;
  background: #ffff;
  border-radius: 10rpx;
  margin: 20rpx;
  padding:26rpx 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.box .title .ziti {
  color: #666666;
  font-size: 28rpx;
}
.box .ziti1 {
  font-size: 28rpx;
  color: #333333;
}
.box .content {
  white-space: pre-line;
  margin: 20rpx;
  width: 710rpx;
  background: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx 30rpx 26rpx 30rpx;
}
.box .content .yjgz {
  padding-bottom: 10rpx;
}
.button {
  position: relative;
  width: 750rpx;
  height: 90rpx;
  position: fixed;
  bottom: 0;
  display: flex;
  justify-content: center;
  justify-items: center;
  align-items: center;
  background: #1989FA;
  text-align: center;
  vertical-align: middle;
}
.buttons {
  font-size: 30rpx;
  color: #ffffff;
}
