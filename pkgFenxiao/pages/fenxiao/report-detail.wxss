.box {
  width: 100%;
  height: 100%;
  display: flex;
  justify-items: center;
  justify-content: center;
  flex-direction: column;
}
.box .title {
  width: 710rpx;
  background: #ffff;
  border-radius: 10rpx;
  margin-top: 24rpx;
  margin-left:20rpx;
  margin-right: 20rpx;
  padding:26rpx 30rpx;
  word-wrap: break-word;
  display: flex;
  justify-items: center;
  align-items: center;

}
.ziti {
  color: #666666;
  font-size: 28rpx;
  flex:3;
  
}
.box .ziti1 {
  font-size: 28rpx;
  color: #333333;
}
.box .content {
  white-space: pre-line;
  margin-top: 24rpx;
  margin-left:20rpx;
  margin-right: 20rpx;
  width: 710rpx;
  background: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx 30rpx 26rpx 30rpx;
}
.box .content .yjgz {
  padding-bottom: 10rpx;
}
.button {
  width: 710rpx;
  height: 90rpx;
  display: flex;
  margin-left:20rpx;
  justify-content: center;
  justify-items: center;
  align-items: center;
  background: #1989FA;
  text-align: center;
  vertical-align: middle;
  border-radius: 10rpx;
}
.buttons {
  font-size: 30rpx;
  color: #ffffff;
  text-align: center;
}
