/* pages/fenxiao/customer-item.wxss */

.outer {
    width: 710rpx;
    margin: 0 auto;
    margin-bottom: 20rpx;
}

.outer .content {
    padding: 0 30rpx 30rpx 30rpx;
}

.header {
    font-weight: bolder;
}

.attrs {}

.attrs .attr {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    margin-bottom: 10rpx;
}

.attrs .attr .label {
    color: #999;
    width: 150rpx;
}

.attrs .attr .value {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    width: 426rpx;
}

.content .deal-status {
    margin: 20rpx 0;
}

.deal-status image{
    width:100%; 
    height:40rpx;
}