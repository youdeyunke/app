/* pages/fenxiao/report.wxss */

.actions {
    margin: auto 20rpx;
    width: 710rpx;
}

.radio-value-class {
    flex: none !important;
}

.post-item {
    display: flex;
    justify-content: flex-start;
    align-items: center;
}

.item-image image{
    width: 220rpx;
    height: 166rpx;
    margin-right: 30rpx;
    border-radius: 10rpx;
}
.item-content{
    height: 166rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #333;
    font-size: 26rpx;
}
.content-title{
    font-weight: bold;
}
.content-address{
    color: #A0A0A0;
}
.content-tags{
    display: flex;
    justify-content: flex-start;
}
.tag{
    border-radius: 5rpx;
    border: 1rpx solid #A0A0A0;
    padding: 6rpx;
    color: #A0A0A0;
    text-align: center;
    margin-right: 10rpx;
}
.price{
    color: #E82525;
    font-weight: bold;
}
.content-price{
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.post-selector{
    width: 100%;
    height: 100%;
}
.fangText{
    position: absolute;
    top: 24rpx;
    right: 20rpx;
}
.fangText image{
    width: 118rpx;
    height: 50rpx;
}
.forms{
    width: 710rpx;
    margin: 20rpx auto;
    box-sizing: border-box;
    border-radius: 20rpx;
    background: #FFFFFF;
    padding: 30rpx;
}
.form-title{
    justify-content: space-between;
    align-items: center;
    width: 100%;
    color: #666;
    font-size: 28rpx;
    display: flex;
}
.form-input{
    color: #B4B4B4;
}
.form-title text{
    flex:3;
    color: #666;
    font-weight: bold;
}
.form-content{
    margin: 48rpx 0;
}
.form-flex{
    margin-top: 34rpx ;
    display:flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1rpx solid #B4B4B4;
    padding-bottom: 20rpx;
    margin-bottom: 82rpx;
}
.form-choose{
    display:block;
    float: left;
}
.form-choose:nth-child(1){
    border-radius: 5rpx 0rpx 0rpx 5rpx;
}
.form-choose:nth-last-child(1){
    border-radius: 0rpx 5rpx 5rpx 0rpx;
}
.right{
    flex: 1;
}
.mobile{
    width: 100%;
    border-bottom:1rpx solid #b4b4b4 ;
    color: #B4B4B4;
    font-size: 28rpx;
    padding-bottom: 20rpx;
}