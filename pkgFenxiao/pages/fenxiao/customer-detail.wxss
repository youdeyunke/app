/* pkgFenxiao/pages/fenxiao/customer-detail.wxss */
.box{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-items: center;
    align-items: center;
    vertical-align: middle;
}
.title-bg{
    width: 710rpx;
    height: 210rpx;
    margin-top: 20rpx;

}
.title-bg image{
    width: 100%;
    height: 100%;
}
.detail{
    border-radius: 20rpx;
    background: #FFFFFF;
    width: 710rpx;
    margin: 20rpx; 

}
.detail-title{
    color: #333333;
    font-weight: bold;
    font-size: 28rpx;
    padding: 28rpx 20rpx;
    border-bottom: 1px solid #EAEAEA;
    display: flex;
    align-items: center;
}
.title-icon{
    width:28rpx;height:28rpx;
    margin-right: 6rpx;
}
.detail-content{
    padding:60rpx  58rpx 60rpx 58rpx;
}
.contents{
    font-size: 26rpx;
    font-weight: bold;
    color: #333;
    display: flex;
    height: 144rpx;
    position: relative;
}
.content-data{
    margin-top: 2rpx;
}
.xmtitle{
    color:#A0A0A0 !important;
}
.text{
    float:left;
    color:#1989FA;
}
.content-circle{
    width: 22rpx;
    height: 22rpx;
    border-radius: 50%;
    background-color: #F0F0F0;
    margin-left: 34rpx;
    margin-right: 34rpx;
    margin-top: 10rpx;
    z-index: 5;
}
.active{
    background-color: #1989fa !important;
}
.content-desc{
    margin-top: -1rpx;
}
.desc-title{
    font-size: 30rpx;
}
.desc-detail{
    color: #A0A0A0;
    font-weight: normal;
    white-space: pre-line;
}
.content-border{
    width: 10rpx;
    margin-top: 48rpx;
    margin-left: -45rpx;
    margin-right: 10rpx;
    height: 104rpx;
    z-index: 4;
    background-image: linear-gradient(to bottom, #e0e0e0 0%, #e0e0e0 50%, transparent 50%);
    background-size: 4rpx 26rpx;
    background-repeat: repeat-Y;
}
.desc{
    margin-left: -27rpx;
}