/* pkgFenxiao/pages/fenxiao/qr.wxss */

page {
    padding-top: 20rpx;
}

.tips {
    width: 100%;
    color: #999999;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    font-size: 30rpx;
}

.main {
    width: 600rpx;
    height: 600rpx;
    margin: auto;
    display: flex;
    justify-content: center;
    align-items: center;
}

.main .qr {
    width: 600rpx;
    height: 600rpx;
    margin-bottom: 20rpx;
}

.counter {
    margin: 40rpx auto auto auto;
    width: 100%;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
}

.counter .link {
    color: #1989fa;
}

.footer {
    height: 120rpx;
    width: 100%;
    background: #ffffff;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    border-top: 2rpx solid #cecece;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 30rpx;
    box-sizing: border-box;
}