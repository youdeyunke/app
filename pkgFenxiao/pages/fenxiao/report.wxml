<van-tabs style="width:100%" animated swipeable type="line" color="#1989fa" bind:change="tabChange">
    <van-tab wx:for="{{tabs}}" wx:for-item="tab" title="{{tab.name}}"></van-tab>
</van-tabs>
<mycard style="margin-top:20rpx;" width="710" title="客户信息" hat="{{false}}">
    <van-field size="large" focus="{{true}}" data-name="name" input-align="left" label="姓名" model:value="{{name}}" maxlength="5" placeholder="请输入客户姓名">
        <view slot="button">
            <cell-radio size="large" value="{{sex}}" options="{{ sexOptions}}" bind:change="sexChange" />
        </view>
    </van-field>
    <van-field wx:if="{{ mobileType == 'full'  }}" size="large" data-name="mobile" input-align="right" label="手机全号" placeholder="请输入11位手机全号" model:value="{{mobile}}" minlength="11" maxlength="11"></van-field>
    <van-cell wx:else size="large" name="mobile" input-align="left" title="手机隐号">
        <protected-mobile-input value="{{mobile}}" bind:change="mobileChange" />
    </van-cell>
</mycard>
<mycard width="710" title="客户意向" hat="{{false}}">
    <view class="post-item" wx:if="{{pid}}">
        <post-item item="{{post}}" />
    </view>
    <view class="fangText" bind:tap="fangChange">
        <van-icon name="edit" size='38rpx'/>
        <text class="">点击{{  pid ? '修改' : '选择'  }}房源</text>
    </view>
    <post-selector bind:change='pidChange' class="post-selector" show="{{popupShow}}"></post-selector>
</mycard>
<view class="actions">
    <van-button bindtap="submitHandle" type="info" block>提交报备</van-button>
    <van-button custom-style="margin-top:10rpx;" type="default" block bindtap="backHandle">
        取消
    </van-button>
</view>
<flow-tips title="报备流程" steps="{{setpsText}}" />