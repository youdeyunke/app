@import './weui.wxss';
@import "/components/tags.wxss";
@import "/utils/wxParse/wxParse.wxss";

page{
  padding-top:30rpx;
  height: auto;
  background: #f4f4f4;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  background: #f4f4f4;
  font-size:32rpx;
  color:#333;
  font-weight:normal;
  --color-green: #1AAD19;
}

.blak-1x{
  height:10rpx;
  width:100%;
  display:block;
}

.blank-2x{
  height:20rpx;
  width:100%;
  display:block;
}

.container {
  background:#fff;
  width:730rpx;
  margin:0 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 0;
  box-sizing: border-box;
  border-radius: 6rpx;
  position: relative;
  box-shadow: 0 1px 2px rgba(150, 150, 150, 0.3);  
  margin-bottom:30rpx;
} 

page .container.container-padding-none{
  padding:none !important;
}

.container-bg-none{
  background:none;
  
}

textarea{
  width:100%;
}

.weui-panel{
  width:100%;
}

h1,.h2{
  color: var(--color-title);
  width:100%;
}
.h1{

  font-size: 38rpx;
}
.h2{
  font-size: 34rpx;
}

.weui-loadmore{
  margin:0 auto
}

.weui-loadmore__tips_in-line{
  background:none !important;
}


.loading-more{
  width:100%;
  text-align: center;
  align-items: center;
  font-size:24rpx;
  color:#333;
}

.data-end{
  width:100%;
  text-align: center;
  align-items: center;
  font-size:24rpx;
  color:#333;
  border-bottom:1px solid #333

}


.cats{
  height:100rpx;
  display:flex;
  justify-content:flex-start;
  align-items:center;
  border-bottom:2rpx solid #f4f4f4;
  padding: 0 20rpx;
  background:#fff;
  width:100%;
  position:fixed;
  top:0rpx;
  z-index:99;
}

.cats .item{
  height:calc(100% - 2rpx);
  border-bottom:2rpx solid #f4f4f4;
  display:flex;
  flex-direction:column;
  padding:0 20rpx;
  justify-content:center;
}

.cats .item.active{
  border-bottom:2rpx solid var(--color-green);
}


.tags{
  display: flex;
  flex-direction: row;
  align-items: center;  
  padding:0 ;
}

.tags .item{
  color: #666;
  border-radius: 0rpx;
  height: 40rpx;
  display: inline-block;
  line-height: 39rpx;
  padding:15rpx 30rpx;
  background: #f4f4f4;
  margin-right:15rpx;
  font-size:28rpx;
}

.tags .item.active{
  background: var(--color-green);
  color:#fff;
}

.tags-left{
  justify-content: flex-start;
}

.tags-right{
  justify-content: flex-end;
}

.tags-left text{
  margin-right:15rpx;
}

.tags-right text{
  margin-left:15rpx;
}


.line-limit{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;  
}


.comments .item.box{
  border-radius: 10rpx;
  background:#fff;
  padding:25rpx 20rpx;
  box-shadow: 6rpx 6rpx 18rpx rgba(0,0,0, 0.1);
  position: relative;
}

.comments .item.box .comment-like{
  display: flex;
  justify-content: flex-start;
  align-content: center;
}

.comments .item.box .comment-like image{
  width:36rpx;
  height: 36rpx;
}


.comments .item.box {
  display: flex;
  flex-wrap: nowrap;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
}


.comments .item .user{
  width: 60rpx;
  height: 60rpx;
  background: darkgray;
  border-radius: 100%;
  overflow: hidden;
}

.comments .item .meta{
  font-size:24rpx;
  width: calc(100% - 60rpx - 30rpx);
}

.comments .item .meta  .nickname{
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.comments .item .meta  .nickname .uname{
  color: #000;
  font-weight: bold;
}

.comments .item .meta  .nickname .cat{
  background: #ffd900;
  padding:0 35rpx;
  color: #000;
  margin-left:30rpx;
  border-radius: 30rpx;
}

.comments .item .meta  .score{
    width:100%;
    border-bottom:1rpx solid #f4f4f4;
    display:flex;
    justify-content:flex-start;
    align-items:center;
    height:40rpx;
    padding:15rpx 0;
    margin-bottom:15rpx;
}

.comments .item .meta .target{
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-top:30rpx;
}

.comments .item .meta .target .red{
  color: red;
  margin-left: 20rpx;
}


.comments .item .meta .score .start-text{
  margin-left:30rpx;
}

.comments .item .meta .content{
    min-height: 100rpx;
}

.comments .item .meta .datetime{
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.comments .item .meta .datetime .time{
  color: #f4f4f4;
}


myfav image{
  width:28rpx;
  height: 28rpx;
}

myfav{
  padding-left:10rpx;
  padding-right:5rpx;
  width:84rpx;
  height: 34rpx;
  font-size:20rpx;
  color:#fff;
  background: rgba(0,0, 0, 0.5);
  border-top-left-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
  position: absolute;
  right:10rpx;
  top:0rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: nowrap;
  justify-content: space-between;
}


.gohome{
  font-size:24rpx;
  height: 36rpx;
  line-height: 100%;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 130rpx;
  background: #ffd900;
  border-top-left-radius: 30rpx;
  border-bottom-left-radius: 30rpx;
  position: fixed;
  top:40rpx;
  right:0rpx;
}

.btn-mini{
  font-size:24rpx;
  height: 60rpx;
}
