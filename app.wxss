@import "/vant/common/index.wxss";

page{
  height: auto;

  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  font-size:28rpx;
  color:#333;
  font-weight:normal;
  --color-bg-dark: #f4f4f4;
  --color-a: #00ae66;
  --color-b: #ff911b;
  --color-c: red;
  --font-xl: 32rpx;
  --font-l: 32rpx;
  --font-s: 28rpx;
  --font-xs: 22rpx;
  background: var(--color-bg-dark);
  
}

van-icon{
    padding:0;
  margin:0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn{
  display: flex;
  justify-content:center;
  align-items:center;
  color:#fff;
  border-radius:10rpx;
  margin:0 ;
  font-size:var(--font-s);
  text-align:center;
}

.btn.mini{
  height:50rpx;
  font-size:var(--font-xs);
}

.btn.primary {
  color: #FFF;
  background: var(--color-a);
}

.btn.info {
  color: #FFF;
  background: var(--color-b);
}

.btn.plain {
  border:1rpx solid var(--color-a);
  color: var(--color-a);
  background:#fff;
}

.btn.round{
  border-radius:50rpx;
}

.btn image{
  width:35rpx;
  height:35rpx;
  margin-right:10rpx;
}

.i{
    color: var(--color-b) !important;
    font-weight: bold !important;
}


.container {
  background:#fff;
  width:750rpx;
  margin:0 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-around;

  position: relative;
  margin-bottom:20rpx;
  box-sizing: border-box;
  padding:30rpx 30rpx;
  border-radius: 0;
} 


textarea{
  width:100%;
}

.h1,.h2{ 
    color:#333; 
    width:100%;
    box-sizing: border-box;
}
.h1{
  font-size:var(--font-xl);
}
.h2{
  font-size:var(--font-l);
}

.cats{
  height:100rpx;
  display:flex;
  justify-content:flex-start;
  align-items:center;
  border-bottom:2rpx solid #f4f4f4;
  padding: 0 20rpx;
  background:#fff;
  width:100%;
  top:0rpx;
  z-index:99;
}

.cats .item{
  height:calc(100% - 2rpx);
  border-bottom:2rpx solid #f4f4f4;
  display:flex;
  flex-direction:column;
  padding:0 20rpx;
  justify-content:center;
}

.cats .item.active{
  border-bottom:2rpx solid var(--color-a);
}



.line-limit{
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;  
}



.empty{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  letter-spacing: 4rpx;
  color: #999;
}

.waiting image{
 width:256rpx;
 height:140rpx;
}

.fixed-footer{
  background: #fff;
  width:100%;
  padding:0rpx 0rpx;
  position: fixed;
  bottom:0rpx;
  border-top:none;
  height: 100rpx;
  z-index:20;
  border-top:1px solid #f1f1f1;
  left:0rpx;
  right:0rpx;

}


.input-group .input-item{
  display:flex;
  justify-content: space-between;
  align-items: center;
}

.input-group .input-item{
  border-bottom:1px solid #f1f1f1;
  padding:10rpx 15rpx;
  margin:15rpx 0;
}

.form-tags{
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
}
.form-tag-item{
  margin:10rpx 15rpx 15rpx 10rpx;
  padding:10rpx 20rpx;
  background: #fff;
  color: var(--color-a);
  border:1rpx solid var(--color-a);
  font-size:var(--font-xs);
}


.form-tag-item-active{
  background:var(--color-a);
  color:#fff;
}


 .typeinfo{
  display:flex;
  justify-content:space-between;
  align-items:center;
  box-sizing:border-box;
  width:100%;
  padding-left:30rpx;
}

 .typeinfo .item{
  width:33.333%;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:flex-start;
}


 .typeinfo .item .value{
  font-size:38rpx;
  color:red;
  margin-top:10rpx;
} 
.typeinfo .item .value .px{
  font-size:20rpx;
  color: #666;
}
  
 .typeinfo .item .key{
  font-size:var(--font-xs);
  color: #999;
}

 .typeinfo .item.border{
  border-right:1px solid #f1f1f1;
  margin-right:30rpx;
} 


.more-btn{
    width: 660rpx;
    height: 100rpx;
    font-size:30rpx;
    text-align: center;
    margin:20rpx auto;
    display: flex;
    justify-content: center;
    align-items: center;
    vertical-align: middle;
    background: #F8F8F8;
    color: #333;
    letter-spacing: 1.6rpx;
    font-weight: bolder;
    border-radius: 6rpx;
}

.search-box .van-cell  {
  background:#F6F7FB ;
  border-radius: 15rpx;
  display: flex;
  justify-content: center;
  align-items:  center;
  height: 80rpx;
}


.rich-text-p{
  display:flex;
  flex-direction:column;
  line-height: 2.1;
  justify-content:flex-start;
}

.rich-text-img{
  width:100%;
  height:auto;
  margin:0 auto;
  line-height:0;
  padding:0;
}
