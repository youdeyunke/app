<box width='750'>
    <view class="items"  >
        <media-item item="{{item}}" custom-class="" wx:for="{{images}}"></media-item>
    </view>
</box>
<view class="footer">
    <upload-btn  bindchange='loadData' mediaid="{{media_cat_id}}" fileType='image'></upload-btn>
    <upload-btn  bindchange='loadData' mediaid="{{media_cat_id}}" fileType='video'></upload-btn>
</view>
