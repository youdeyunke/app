/* pkgAdmin/pages/clue/index.wxss */

.item{
  width:710rpx; 
  border:15rpx; 
  background-color:#fff;
  overflow: hidden;
  margin:0 auto 20rpx auto;
  border-radius: 15rpx;
  padding:10rpx 15rpx;
  box-sizing: border-box;

}

.header{
  display: flex;
  justify-content: space-between;
}


.content{
  height:100rpx;
  padding-top:20rpx;
}

.content.empty{ 
    display: flex;
    justify-content: center;
    align-items: center;
    color:#999; 
    font-size:24rpx;
}

.header .date{
  color:#999; 
  font-size:24rpx;
}

.header .name{
  margin-bottom:20rpx;
}

image.sex{
  width:28rpx;
  height:28rpx;
  vertical-align: middle;
}

 .header .name text{
  font-size:32rpx; 
  color:#000;  
  margin-left:10rpx;
}