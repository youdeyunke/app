<box padding="30">

  <mytextarea value="{{content}}" bind:input="contentChange" max-length="500" min-length="5" placeholder="请输入问题" />
  <view class="actions">
    <van-button   disabled="{{ content.length < minLength || loading }}" loading="{{loading}}" bindtap="submitHandle" type="info" block  >我要提问</van-button>
    <view style="height:20rpx;display:block;"></view>
    <van-button   bindtap="backHandle" type="default" block  >返回</van-button>
  </view>
</box>

<mycard title="你可以这样问" hat="{{false}}" padding="{{false}}">
  <van-cell size="large" wx:for="{{commonQs}}" wx:for-item="text">
    <view slot="title">{{text}}</view>
    <van-button bindtap="quickHandle" type="info" round size="small" plain data-index="{{index}}">去提问</van-button>
  </van-cell>

</mycard>



