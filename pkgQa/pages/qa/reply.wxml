<box padding="30">

    <textarea disabled="{{ questionContent.length >= maxLength }}" bindinput="inputHandle" maxlength="200" name="content" placeholder='输入内容'>
      <view class="counter">
          {{ content.length }}/{{ maxLength }}
      </view>
        
    </textarea>

  <view class="actions">
    <van-button   disabled="{{loading || content.length < minLength || content.length >= maxLength }}" loading="{{loading}}" bindtap="submitHandle" type="info" block  >提交</van-button>
    <view style="height:20rpx;display:block;"></view>
    <van-button   bindtap="backHandle" type="default" block  >返回</van-button>
  </view>
</box>

